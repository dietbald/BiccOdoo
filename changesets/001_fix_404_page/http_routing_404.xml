<t name="Page Not Found" t-name="http_routing.404">
    <!-- Maintained via OdooAiDeployer changeset 001_fix_404_page -->
    <t t-call="web.frontend_layout">
        <div id="wrap">
            <t t-out="0"/>
            <t t-set="req_path" t-value="(request and request.httprequest.path) or ''"/>
            <t t-set="is_job_url" t-value="req_path.startswith('/jobs/') and req_path.count('/') == 2"/>
            <section class="s_text_block pt96 pb96 o_colored_level" data-snippet="s_text_block" data-name="404 Helpful">
                <div class="container text-center">

                    <h1 class="h3 fw-normal mx-auto mb-5" style="max-width: 760px; line-height: 1.5;">
                        <t t-if="is_job_url">
                            This position has already been filled. If you're still interested in joining our team, you can browse our current openings below.
                        </t>
                        <t t-else="">
                            The link you followed may have expired, been moved, or the position has already been filled. Here are a few places where you might find what you're looking for.
                        </t>
                    </h1>

                    <div class="row g-4 justify-content-center">

                        <div class="col-md-4">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body p-4 d-flex flex-column">
                                    <h4 class="card-title fw-semibold mb-2">Open positions</h4>
                                    <p class="card-text text-muted mb-4">Browse our current career opportunities and apply online.</p>
                                    <a href="/jobs" class="btn btn-primary mt-auto">View open jobs</a>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body p-4 d-flex flex-column">
                                    <h4 class="card-title fw-semibold mb-2">About us</h4>
                                    <p class="card-text text-muted mb-4">Learn more about our company, our values, and the projects we deliver.</p>
                                    <a href="/" class="btn btn-outline-primary mt-auto">Visit homepage</a>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card h-100 border-0 shadow-sm">
                                <div class="card-body p-4 d-flex flex-column">
                                    <h4 class="card-title fw-semibold mb-2">Get in touch</h4>
                                    <p class="card-text text-muted mb-4">Reach out to our team for inquiries, partnerships, or general questions.</p>
                                    <a href="/contactus" class="btn btn-outline-primary mt-auto">Contact us</a>
                                </div>
                            </div>
                        </div>

                    </div>

                </div>
            </section>
        </div>
    </t>
</t>
