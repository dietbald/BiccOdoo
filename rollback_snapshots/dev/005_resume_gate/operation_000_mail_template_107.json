{
  "auto_delete": false,
  "body_html": "<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"border-collapse:collapse;background-color:#f2f2f2;margin:0;padding:0;\">\n  <tbody>\n    <tr>\n      <td align=\"center\" style=\"padding:20px 0;\">\n        <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"600\" style=\"border-collapse:collapse;max-width:600px;background-color:#ffffff;color:#101820;font-family:'Roboto',sans-serif;font-size:13px;line-height:1.6;\">\n          <tbody>\n            <tr>\n              <td style=\"padding:20px;\">\n                <p style=\"margin:0;padding:0;font-size:13px;\">\n                  Hi <t t-out=\"object.partner_name or 'there'\"/>,\n                  <br/><br/>\n                  Thanks for your interest in the <b><t t-out=\"object.job_id.name or 'open'\"/></b> position at <t t-out=\"object.company_id.name or 'Our Company'\"/>!\n                  <br/><br/>\n                  We noticed your application came through without a resume or CV attached. To move forward, we'll need a copy of your updated resume.\n                  <br/><br/>\n                  Please reply to this email with your resume attached (PDF or Word format).\n                  <br/><br/>\n                  We look forward to reviewing your qualifications.\n                  <br/><br/>\n                  Best regards,<br/>\n                  <t t-out=\"object.company_id.name or 'Our Company'\"/> Recruitment Team<br/>\n                  <a t-att-href=\"object.company_id.website\" style=\"text-decoration:none;color:#374151;\">\n                    <t t-out=\"object.company_id.website\"/>\n                  </a>\n                </p>\n              </td>\n            </tr>\n          </tbody>\n        </table>\n      </td>\n    </tr>\n  </tbody>\n</table>\n",
  "email_from": "{{ object.company_id.x_studio_short_name }} <{{ object.company_id.alias_domain_id.default_from_email }}>",
  "email_to": "{{ object.email_from }}",
  "lang": "{{ object.partner_id.lang }}",
  "model_id": false,
  "name": "Recruitment: Request for Resume (Missing Attachment)",
  "subject": "Your application for {{ object.job_id.name }}: resume needed"
}