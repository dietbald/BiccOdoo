{
  "arch_db": "<form string=\"Send SMS Reminder\">\n    <sheet>\n        <div class=\"oe_title\">\n            <h2><field name=\"partner_name\" readonly=\"1\" nolabel=\"1\"/></h2>\n        </div>\n        <group>\n            <field name=\"partner_phone\" readonly=\"1\" string=\"Mobile\"/>\n            <field name=\"x_studio_sms_preview\" readonly=\"1\" string=\"SMS to send\" widget=\"text\"/>\n        </group>\n        <p class=\"text-muted\" style=\"margin-top:12px;\">\n            Triple-click any line to select it, then copy.\n            \"SMS Sent\" stamps the matching reminder date and closes this popup.\n        </p>\n    </sheet>\n    <footer>\n        <button name=\"bicc_recruitment.mark_sms_sent\" type=\"action\" string=\"SMS Sent\" class=\"btn-primary\"/>\n        <button special=\"cancel\" string=\"Cancel\" class=\"btn-secondary\"/>\n    </footer>\n</form>",
  "model": "hr.applicant",
  "name": "bicc_recruitment.sms_wizard_form_view",
  "type": "form"
