  "payload": {
    "body_html": "<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"border-radius:0px;border-style:none;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-collapse:collapse;caption-side:bottom;background-color: #f2f2f2; margin: 0; padding: 0;\" data-oe-version=\"1.0\">\n  <tbody style=\"border-radius:0px;border-style:solid;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;\"><tr style=\"border-radius:0px;border-style:solid;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;\">\n    <td align=\"center\" style=\"border-radius:0px;border-style:solid;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;padding: 20px 0;\">\n\n      \n      <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"600\" style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-collapse:collapse;caption-side:bottom;max-width: 600px; background-color: #ffffff; &#10;                    color: #101820; font-family: 'Roboto', sans-serif; &#10;                    font-size: 13px; line-height: 1.6;\">\n        <tbody style=\"border-radius:0px;border-style:solid;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;\"><tr style=\"border-radius:0px;border-style:solid;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;\">\n          <td style=\"border-radius:0px;border-style:solid;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;padding: 20px;\">\n\n            \n            \n            <p style=\"border-radius:0px;border-style:none;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;margin: 0; padding: 0; font-size: 13px;\">\n              Dear <t t-out=\"object.partner_id.name or 'Applicant'\"/>,\n              <br/><br/>\n              Thank you for applying for the \n              <t t-esc=\"object.applicant_id.job_id.name or 'Position'\"/>\n              position at <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\"><t t-out=\"object.applicant_id.job_id.company_id.name or 'Our Company'\"/></b>.\n              We appreciate your interest in joining our team!\n              <br/><br/>\n\n              \n              As part of our process, we invite you to complete\n              <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">three short assessments</b> designed to help us better understand your:\n            </p>\n\n            <ul style=\"border-radius:0px;border-style:none;padding:0 0 0 20px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;list-style-type:disc;padding-left: 20px; margin: 8px 0;\">\n              <li>Logical reasoning</li>\n              <li>Emotional intelligence</li>\n              <li>Technical skills</li>\n            </ul>\n\n            <p style=\"border-radius:0px;border-style:none;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;margin: 0; padding: 0; font-size: 13px;\">\n              These assessments will give us valuable insights into how you approach \n              problem-solving and handle various scenarios, ensuring we give every \n              applicant a fair and thorough evaluation.\n              <br/><br/>\n\n              <!-- Assessment Details -->\n              <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;font-family: 'Teko', sans-serif; font-size: 18px;\">\n                Assessment Details\n              </b>\n              <br/>\n            </p>\n            <ul style=\"border-radius:0px;border-style:none;padding:0 0 0 20px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;list-style-type:disc;padding-left: 20px; margin: 8px 0;\">\n              <li>\n                Each assessment takes about <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">5\u201310 minutes</b>, \n                with up to <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">20 minutes</b> available if needed.\n              </li>\n              <li>\n                All three must be submitted \n                <t t-esc=\"'before ' + str(ctx.get('deadline')) &#10;                            if ctx.get('deadline') &#10;                            else 'within the next 7 days'\"/>\n              </li>\n              <li>\n                They are <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">multiple-choice</b>, \n                so we recommend a quiet, distraction-free environment \n                while you complete them.\n              </li>\n            </ul>\n\n            <!-- Store URLs in QWeb variables -->\n            <t t-set=\"logical_test\" t-value=\"ctx.get('logical_test')\"/>\n            <t t-set=\"emotional_test\" t-value=\"ctx.get('emotional_test')\"/>\n            <t t-set=\"technical_test\" t-value=\"ctx.get('technical_test')\"/>\n\n            <!-- Assessment Links -->\n            <div style=\"margin: 16px 5px;\">\n              <a t-att-href=\"(logical_test)\" style=\"color: #101820; border-style: none; margin: 0px; box-sizing: border-box; border-width: 0px; display: inline-block; background-color: #ec008c; padding: 10px 20px; text-decoration: none; border-radius: 5px; font-size: 13px;\"><font style=\"color: #ffffff;\">\n                 Logical Reasoning Test&nbsp;</font></a>\n            </div>\n            <div style=\"margin: 16px 5px;\">\n              <a t-att-href=\"(emotional_test)\" style=\"color: #101820; border-style: none; margin: 0px; box-sizing: border-box; border-width: 0px; display: inline-block; background-color: #ec008c; padding: 10px 20px; text-decoration: none; border-radius: 5px; font-size: 13px;\"><font style=\"color: #ffffff;\">\n                 Emotional Intelligence Test&nbsp;</font></a>\n            </div>\n            <div style=\"margin: 16px 5px;\">\n              <a t-att-href=\"(technical_test)\" style=\"color: #101820; border-style: none; margin: 0px; box-sizing: border-box; border-width: 0px; display: inline-block; background-color: #ec008c; padding: 10px 20px; text-decoration: none; border-radius: 5px; font-size: 13px;\"><font style=\"color: #ffffff;\">\n                 Technical Skills Test&nbsp;</font></a>\n            </div>\n\n            <!-- Next Steps & Closing -->\n            <p style=\"border-radius:0px;border-style:none;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;margin: 0; padding: 0; font-size: 13px;\">\n              Once you finish all three assessments, we will review your results \n              and contact you regarding the <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">next steps</b> in the hiring process.\n              <br/><br/>\n              If you encounter any issues or have any questions,\nplease reply directly to this email.\n<br/><br/>\nWe look forward to learning more about you and appreciate\nthe time you invest in this process.\n<br/><br/>\n              Best regards,<br/>\n              The Recruitment Team<br/>\n              <t t-out=\"object.applicant_id.job_id.company_id.name or 'Our Company'\"/><br/>\n              <a t-att-href=\"(object.applicant_id.job_id.company_id.website)\" style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;text-decoration: none; color: #374151;\">\n                 <t t-out=\"object.applicant_id.job_id.company_id.website\"/>\n              </a>\n            </p>\n            <!-- Your content ends here -->\n\n          </td>\n        </tr>\n      </tbody></table>\n    </td>\n  </tr>\n</tbody></table>\n",
