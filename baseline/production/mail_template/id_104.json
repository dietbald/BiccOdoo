ng:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\"><t t-out=\"object.job_id.name or 'Position'\"/></b> role at \n                  <b style=\"border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\"><t t-out=\"object.company_id.name or 'Our Company'\"/></b>.\n                </p>\n\n                \n                <p style=\"border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-radius:0px;border-style:none;padding:0px;margin:0px 0 16px 0;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;\">\n                  We appreciate the time you took to apply and share your qualifications with us.\n                  However, we understand that you are not available to work on Saturdays. This role\n                  follows our standard working schedule, which includes Monday to Saturday. Since\n                  Saturday availability is required for this position, we are unable to proceed with\n                  your application at this time.\n                </p>\n\n                \n                <p style=\"border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-radius:0px;border-style:none;padding:0px;margin:0px 0 16px 0;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;\">\n                  While we may not be able to move forward at this moment, we truly value your\n                  interest and encourage you to stay connected. If your availability changes, or if\n                  a suitable opportunity opens in the future with a different schedule, we would be\n                  happy to revisit your application.\n                </p>\n\n                \n                <p style=\"border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-radius:0px;border-style:none;padding:0px;margin:0px 0 16px 0;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;\">\n                  We sincerely appreciate your time and effort, and we wish you all the best in\n                  your job search and future career endeavors.\n                </p>\n\n                \n                <hr width=\"97%\" style=\"border-top-color:#101820;border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-style:none;border-top-width:0px;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-radius: 0px; padding: 0px; box-sizing: border-box; color: #101820; border: none; background-color: #ec008c; height: 1px; margin: 16px 0px; opacity: 0.7;\"/>\n\n                \n                <p style=\"border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-radius:0px;border-style:none;padding:0px;margin:20px 0 16px 0;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;margin-top: 20px;\">\n                  Best regards,<br/>\n                  <b style=\"border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">The Recruitment Team</b><br/>\n                  <t t-out=\"object.company_id.name or 'Our Company'\"/><br/>\n                  <a t-att-href=\"object.company_id.website\" style=\"border-color: 