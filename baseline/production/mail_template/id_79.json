    "body_html": "<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"border-radius:0px;border-style:none;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;caption-side:bottom;border:none; border-collapse:collapse; background-color: #f2f2f2; margin:0; padding:0;\" data-oe-version=\"1.0\">\n  <tbody style=\"border-radius:0px;border-style:solid;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;\">\n    <tr style=\"border-radius:0px;border-style:solid;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;\">\n      <td align=\"center\" style=\"border-radius:0px;border-style:solid;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;padding:20px 0;\">\n        <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"600\" style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-collapse:collapse;caption-side:bottom;max-width:600px; background-color:#ffffff; color:#101820;&#10;                      font-family:'Roboto', sans-serif; font-size:13px; line-height:1.6;\">\n          <tbody style=\"border-radius:0px;border-style:solid;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;\">\n            <tr style=\"border-radius:0px;border-style:solid;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;\">\n              <td style=\"border-radius:0px;border-style:solid;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;padding:20px;\">\n\n                \n                <p style=\"border-radius:0px;border-style:none;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;margin:0; padding:0;\">\n                  Dear \n                  <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">\n                    <!-- For hr.applicant, partner_name is often the candidate's name;\n                         fallback to a literal 'Applicant' if empty -->\n                    <t t-esc=\"object.partner_name or 'Applicant'\"/>\n                  </b>,\n                  <br/><br/>\n                  Thank you for applying for the \n                  <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">\n                    <!-- For hr.applicant, job_id is the applied position -->\n                    <t t-esc=\"object.job_id.name or 'Position'\"/>\n                  </b> position at \n                  <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">\n                    <!-- The company linked to that job -->\n                    <t t-esc=\"object.job_id.company_id.name or 'Our Company'\"/>\n                  </b>.\n                  To proceed with your application, we kindly ask you to verify\n                  your details by completing a short form.\n                </p>\n\n                <br/>\n\n                <!-- Why is this important? -->\n                <p style=\"border-radius:0px;border-style:none;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;margin:0; padding:0;\">\n                  <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">Why is this important?</b><br/>\n                  - Ensure the accuracy of your application.<br/>\n                  - Streamline our recruitment process.<br/>\n                  - Facilitate better communication with you.\n                </p>\n\n                <br/>\n\n                <!-- What to expect -->\n                <p style=\"border-radius:0px;border-style:none;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;margin:0; padding:0;\">\n                  <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">What to expect:</b><br/>\n                  - <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">Time Commitment:</b> The form takes approximately <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">5 minutes</b> to complete.<br/>\n                  - <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">Information Requested:</b> We will ask you to confirm your personal details.<br/>\n                  - <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">Data Privacy:</b> Your responses will be kept confidential and used only for recruitment purposes.\n                </p>\n\n                <br/>\n\n                <!-- Survey Link Variable -->\n                <t t-set=\"survey_link\" t-value=\"ctx.get('survey_link') or '#'\"/>\n\n                <!-- Verify Information Button -->\n                <div style=\"padding:16px 8px;\">\n                  <a t-att-href=\"survey_link\" style=\"box-sizing: border-box; color: #101820; border: none; margin: 0px; background-color: #ec008c; text-decoration: none; padding: 8px 16px; border-radius: 5px; font-weight: bold;\">\n                    <font style=\"color:#ffffff;\">\n                      Verify Your Information&nbsp;&nbsp;</font>\n                  </a></div>\n\n                <!-- Contact & Closing -->\n                <p style=\"border-radius:0px;border-style:none;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;margin:0; padding:0;\">\n                  If you have any questions or need assistance, simply reply to this email.\n                </p>\n                <br/>\n                <p style=\"border-radius:0px;border-style:none;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;margin:0; padding:0;\">\n                  Thank you for your prompt response. We look forward to reviewing your information.\n                </p>\n\n                <br/>\n\n                <!-- Regards -->\n                <p style=\"border-radius:0px;border-style:none;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;margin:0; padding:0;\">\n                  Best regards,<br/>\n                  <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">The Recruitment Team</b>\n                </p>\n\n              </td>\n            </tr>\n          </tbody>\n        </table>\n      </td>\n    </tr>\n  </tbody>\n</table>\n",
    "email_from": "{{ object.company_id.x_studio_short_name }} <{{ object.company_id.alias_domain_id.default_from_email }}>",
