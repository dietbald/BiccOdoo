    "body_html": "<div style=\"margin: 0px; padding: 0px;\">\n                <p>\n                    Dear <t t-out=\"object.company_id.name\">YourCompany</t>,\n                </p>\n                <p>\n                    Based on the documents and information received, the VAT return of <t t-out=\"object.company_id.name\">YourCompany</t>\n                    for period <t t-out=\"object.type_id._get_period_name(object.company_id, object.date_from, object.date_to)\"/> has been submitted.\n                </p>\n                <p>\n                    It has been determined that an amount of <t t-out=\"format_amount(object.total_amount_to_pay, object.amount_to_pay_currency_id)\"/> remains payable.\n                </p>\n                <table style=\"border:1px solid black; padding:20px; text-align:left; border-spacing: 16px;\">\n                    <tr>\n                        <td>Amount to Pay</td>\n                        <td><t t-out=\"format_amount(object.total_amount_to_pay, object.amount_to_pay_currency_id)\"/></td>\n                    </tr>\n                    <tr>\n                        <td>Due By</td>\n                        <td><t t-out=\"format_date(object.date_deadline)\"/></td>\n                    </tr>\n                </table>\n                <p>Kind regards,</p>\n                <p><t t-out=\"user.name\">Mitchell Admin</t></p>\n            </div>\n        ",
