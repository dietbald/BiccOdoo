  "payload": {
    "body_html": "<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:100%; margin:0px auto;\"><tbody>\n        <t t-set=\"document_access_link\" t-value=\"object.document_access_url\"/>\n        <tr><td valign=\"top\" style=\"text-align: left; font-size: 14px;\">\n            Dear <t t-out=\"object.employee_id.name\"/>, a new payslip is available for you.<br/><br/>\n            <t t-if=\"object.employee_id.user_id\">Please find the PDF in your employee portal.<br/><br/></t>\n            <div t-if=\"document_access_link\" style=\"text-align: center; padding: 16px 0px 16px 0px; font-size: 14px;\">\n                <a t-attf-href=\"{{ document_access_link }}\" target=\"_blank\" style=\"background-color: #875A7B; padding: 8px 16px 8px 16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;\">\n                    Your Payslip\n                </a>\n            </div>\n            Have a nice day,<br/>\n            The HR Team\n        </td></tr>\n    </tbody></table>\n                ",
    "email_from": "{{ user.email_formatted }}",
    "email_to": "{{ object.employee_id.private_email or object.employee_id.work_email }}",
    "lang": "{{ object.employee_id.lang }}",
    "model_id": [
