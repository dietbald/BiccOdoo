{
  "exported_at": "2026-05-10T12:35:52Z",
  "id": 54,
  "model": "mail.template",
  "payload": {
    "body_html": "<div style=\"font-size: 13px; color: #374151;\">\n    <t t-set=\"recurrent\" t-value=\"object.recurrence_id and not ctx.get('calendar_template_ignore_recurrence')\"/>\n    <t t-set=\"mail_tz\" t-value=\"object._get_mail_tz() or ctx.get('mail_tz')\"/>\n    <t t-set=\"appointment_booker_name\" t-value=\"object.appointment_booker_id.display_name\"/>\n    <h1 style=\"font-size: 18px; font-weight: bold; color: #374151;\">\n        <t t-if=\"not object.appointment_type_id.is_always_confirm and object.appointment_status == 'request'\">Appointment requested</t>\n        <t t-else=\"\">\n            Booking confirmed\n            <img src=\"/calendar/static/src/img/check-circle.png\" style=\"border:0; width: 24px; height: 24px; margin-left: 10px; text-decoration:none; vertical-align: bottom;\"/>\n        </t>\n    </h1>\n    <p style=\"margin: 0;\">\n        <span style=\"display: block; margin-top: 8px;\">\n            <t t-out=\"appointment_booker_name or ''\">John Booker</t>\n            <t t-if=\"not object.appointment_type_id.is_always_confirm and object.appointment_status == 'request'\"> has requested </t>\n            <t t-else=\"\"> has booked </t>\n            an appointment: <t t-out=\"object.appointment_type_id.name or ''\">Technical Demo</t>\n            <t t-if=\"object.appointment_type_id.category not in ['custom', 'anytime'] and object.appointment_type_id.schedule_based_on == 'users' and object.partner_id\">\n                with <t t-out=\"object.partner_id.name or ''\">Brandon Freeman</t>\n            </t>.\n        </span>\n    </p>\n    <div style=\"text-align: center; padding: 16px 0px 16px 0px; margin-top: 16px;\">\n        <a t-attf-href=\"/calendar/meeting/join?token={{ object.access_token }}\" t-attf-style=\"display: inline-block; padding: 7px 14px; color: {{user.company_id.email_primary_color or '#FFFFFF'}}; text-decoration: none; background-color: {{user.company_id.email_secondary_color or '#875A7B'}}; border-radius: 3px\">\n            Join</a>\n        <a t-attf-href=\"/odoo/calendar.event/{{ object.id }}\" t-attf-style=\"display: inline-block; margin-left: 12px; padding: 7px 14px; color: #111827; text-decoration: none; background-color: #E7E9ED; border-radius: 3px;\">\n            View</a>\n    </div>\n    <div style=\"margin: 16px 0 0;\">\n        <h2 t-attf-style=\"margin-bottom: 12px; font-size: 14px; font-weight: bold; color: {{user.company_id.email_secondary_color or '#875A7B'}};\">Details</h2>\n        <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"font-size: 13px; color: #374151;\">\n            <tr>\n                <td style=\"width: 100px; color: #676F7B;\">Date &amp; Time</td>\n                <td style=\"font-weight: bold;\">\n                    <t t-out=\"format_datetime(dt=object.start, tz=mail_tz if not object.allday else None, dt_format='EEEE', lang_code=object.env.lang) or ''\">Wednesday</t>\n                    <t t-out=\"format_datetime(dt=object.start, tz=mail_tz if not object.allday else None, dt_format='d', lang_code=object.env.lang) or ''\">1</t>\n                    <t t-out=\"format_datetime(dt=object.start, tz=mail_tz if not object.allday else None, dt_format='MMMM y', lang_code=object.env.lang) or ''\">January 2020</t>\n                    <t t-if=\"not object.allday\">\n                        <t t-out=\"format_time(time=object.start, tz=mail_tz, time_format='short', lang_code=object.env.lang) or ''\">8:00</t>\n                        <t t-if=\"not object.appointment_type_id.hide_timezone and mail_tz\">\n                            <span style=\"font-size: 11px; font-weight: normal;\">\n                                (<t t-out=\"mail_tz\"/>)\n                            </span>\n                        </t>\n                    </t>\n                </td>\n            </tr>\n            <tr t-if=\"recurrent\">\n                <td style=\"width: 100px; padding-top: 6px; color: #676F7B;\">When</td>\n                <td style=\"padding-top: 6px;\"><t t-out=\"object.recurrence_id.name or ''\">Every 1 Weeks, for 3 events</t></td>\n            </tr>\n            <tr t-if=\"not object.appointment_type_id.hide_duration and not object.allday and object.duration\">\n                <td style=\"width: 100px; padding-top: 6px; color: #676F7B;\">Duration</td>\n                <td style=\"padding-top: 6px;\"><t t-out=\"('%dH%02d' % (object.duration,round(object.duration*60)%60)) or ''\">0H30</t></td>\n            </tr>\n            <tr t-if=\"object.location\">\n                <td style=\"width: 100px; padding-top: 6px; color: #676F7B; vertical-align: top;\">Location</td>\n                <td style=\"padding-top: 6px;\">\n                    <t t-out=\"object.location or ''\">Bruxelles</t>\n                    <a target=\"_blank\" t-if=\"object.location != object.appointment_type_id.location_id.name\" t-attf-href=\"http://maps.google.com/maps?oi=map&amp;q={{ object.location }}\" style=\"margin-left: 12px; font-size: 12px; color: #008f8c; text-decoration: underline;\">View Map</a>\n                </td>\n            </tr>\n            <tr t-if=\"object.appointment_type_id.manage_capacity\">\n                <td style=\"width: 100px; padding-top: 6px; color: #676F7B;\">For</td>\n                <td style=\"padding-top: 6px;\"><t t-out=\"object.total_capacity_reserved\"/> people</td>\n            </tr>\n            <tr t-if=\"not object.appointment_type_id.is_auto_assign and object.appointment_resource_ids\">\n                <td style=\"width: 100px; padding-top: 6px; color: #676F7B; vertical-align: top;\">Resources</td>\n                <td style=\"padding-top: 6px;\">\n                    <ul style=\"padding: 0 15px;\">\n                        <li t-foreach=\"object.appointment_resource_ids\" t-as=\"resource\">\n                            <span style=\"margin-left:5px\" t-out=\"resource.name or ''\">Table 1</span>\n                        </li>\n                    </ul>\n                </td>\n            </tr>\n            <tr t-if=\"object.videocall_redirection\">\n                <td style=\"width: 100px; padding-top: 6px; color: #676F7B;\">\n                    <t t-if=\"object.videocall_source == 'discuss'\">Join with</t>\n                    <t t-else=\"\">Join</t>\n                </td>\n                <td style=\"padding-top: 6px;\">\n                    <a t-attf-href=\"{{ object.videocall_redirection }}\" target=\"_blank\" style=\"color: #008f8c;\">\n                        <t t-if=\"object.videocall_source == 'discuss'\">Odoo Discuss</t>\n                        <t t-else=\"\">Video meeting</t>\n                    </a>\n                </td>\n            </tr>\n        </table>\n    </div>\n    <div style=\"margin: 32px 0 0;\">\n        <h2 t-attf-style=\"margin-bottom: 12px; font-size: 14px; font-weight: bold; color: {{user.company_id.email_secondary_color or '#875A7B'}};\">Attendees</h2>\n        <div t-foreach=\"object.attendee_ids\" t-as=\"attendee\" style=\"margin-bottom: 5px;\">\n            <img t-if=\"attendee.state\" t-attf-src=\"/calendar/static/src/img/state_{{ attendee.state }}.png\" style=\"border:0; width: 15px; height: 15px; vertical-align: text-bottom;\"/>\n            <t t-if=\"attendee.common_name\">\n                <span style=\"margin-left: 5px\" t-out=\"attendee.common_name or ''\">Mitchell Admin</span>\n            </t>\n            <t t-else=\"\">\n                <span style=\"margin-left:5px\">You</span>\n            </t>\n        </div>\n    </div>\n    <div t-if=\"not is_html_empty(object.description)\" style=\"margin: 32px 0 0;\">\n        <h2 t-attf-style=\"margin-bottom: 12px; font-size: 14px; font-weight: bold; color: {{user.company_id.email_secondary_color or '#875A7B'}};\">Description of the event</h2>\n        <div t-out=\"object.description\"/>\n    </div>\n    <t t-set=\"upcoming_appointments\" t-value=\"(object.appointment_booker_id.upcoming_appointment_ids - object).sorted('start')\"/>\n    <div t-if=\"upcoming_appointments\" style=\"margin: 32px 0 0;\">\n        <t t-set=\"appointment_booker_id\" t-value=\"object.appointment_booker_id.id\"/>\n        <h2 t-attf-style=\"margin-bottom: 12px; font-size: 14px; font-weight: bold; color: {{user.company_id.email_secondary_color or '#875A7B'}};\">Your Other Upcoming Appointment(s)</h2>\n        <ul style=\"margin: 6px 0 0; padding: 0 18px;\">\n            <li style=\"margin-top: 6px;\" t-foreach=\"upcoming_appointments\" t-as=\"upcoming_appointment\">\n                <span t-out=\"upcoming_appointment.appointment_type_id.name or ''\">Technical Demo</span>\n                <span style=\"margin: 0 10px;\">-</span>\n                <span t-out=\"upcoming_appointment.start or ''\" t-options=\"{&quot;widget&quot;: &quot;datetime&quot;, &quot;format&quot;: &quot;medium&quot;, &quot;tz_name&quot;: mail_tz}\" style=\"font-weight: bold;\">June 20th, 15:00</span>\n                <a t-attf-href=\"/calendar/view/#{upcoming_appointment.access_token}?partner_id=#{appointment_booker_id}\" target=\"_blank\" style=\"margin-left: 10px; font-size: 12px; color: #008f8c; text-decoration: underline;\">View Details</a>\n            </li>\n        </ul>\n    </div>\n</div>\n            ",
    "email_from": "{{ (user.email_formatted or object.user_id.email_formatted) }}",
    "email_to": false,
    "lang": false,
    "model_id": [
      565,
      "Calendar Event"
    ],
    "name": "Appointment: Appointment Booked",
    "subject": "{{ 'Appointment Requested: ' if not object.appointment_type_id.is_always_confirm and object.appointment_status == 'request' else 'Appointment Booked: ' }}{{ object.appointment_type_id.name }}"
  },
  "payload_sha256": "4b1d775763dc0d5fbf122034a103d69add2b469de8887921ea38c44c679172be",
  "write_date": "2025-12-09 02:56:21",
  "xml_id": "appointment.appointment_booked_mail_template"
}
