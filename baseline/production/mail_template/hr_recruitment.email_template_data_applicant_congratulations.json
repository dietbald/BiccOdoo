  "payload": {
    "body_html": "<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"border-radius:0px;border-style:none;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-collapse:collapse;caption-side:bottom;background-color: #f2f2f2; margin: 0; padding: 0;\" data-oe-version=\"1.0\">\n  <tbody style=\"border-radius:0px;border-style:solid;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;\">\n    <tr style=\"border-radius:0px;border-style:solid;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;\">\n      <td align=\"center\" style=\"border-radius:0px;border-style:solid;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;padding: 20px 0;\">\n        <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"600\" style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-collapse:collapse;caption-side:bottom;max-width: 600px; background-color: #ffffff; color: #101820; font-family: 'Roboto', sans-serif; font-size: 13px; line-height: 1.6;\">\n          <tbody style=\"border-radius:0px;border-style:solid;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;\">\n            <tr style=\"border-radius:0px;border-style:solid;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;\">\n              <td style=\"border-radius:0px;border-style:solid;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;padding: 20px;\">\n                \n                <p style=\"border-radius:0px;border-style:none;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;margin: 0; padding: 0; font-size: 13px;\">\n                  Hello <t t-out=\"object.partner_id.complete_name or 'Applicant'\"/>,\n                  <br/><br/>\n                  We\u2019re pleased to confirm that we have successfully received your application for the <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">\n                    <a t-att-href=\"hasattr(object.job_id, 'website_url') and object.job_id.website_url or ''\" style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;text-decoration: none; color: #EC008C;\">\n                      <t t-out=\"object.job_id.name or 'Job Title'\"/>\n                    </a>\n                  </b> position at <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\"><t t-out=\"object.company_id.name or 'Company Name'\"/></b>.\n                  <br/><br/>\n                  Thank you for your interest in joining our team! We are currently reviewing your application and will get back to you soon.\n                  <br/><br/>\n\n                  \n                  <t t-if=\"'website_url' in object.job_id and object.job_id.website_url\">\n                    </t></p><div style=\"margin: 16px 5px;\">\n                      <a t-att-href=\"object.job_id.website_url\" style=\"color: #101820; border-style: none; margin: 0px; box-sizing: border-box; border-width: 0px; background-color: #ec008c; text-decoration: none; padding: 10px 20px; border-radius: 5px; font-size: 13px; display: inline-block;\"><font style=\"color: #ffffff;\">\n                        View Job Description&nbsp;</font></a>\n                    </div>\n                  \n\n                  \n                  If you have any questions or need faster feedback, feel free to reply to this email.\n                  <br/><br/>\n                  Kind regards,<br/>\n                  <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">The Recruitment Team</b><br/>\n                  <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\"><t t-out=\"object.company_id.name or 'Company Name'\"/></b><br/>\n                  <a t-att-href=\"object.company_id.website\" style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;text-decoration: none; color: #374151;\">\n                    <t t-out=\"object.company_id.website\"/>\n                  </a>\n                <p style=\"border-radius:0px;border-style:none;padding:0px;margin:0px 0 16px 0;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;\">\n              </p></td>\n            </tr>\n          </tbody>\n        </table>\n      </td>\n    </tr>\n  </tbody>\n</table>\n",
    "email_from": "{{ object.company_id.x_studio_short_name }} <{{ object.company_id.alias_domain_id.default_from_email }}>",
