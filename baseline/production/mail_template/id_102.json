r-right-color:#101820;border-top-color:#101820;border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">\n                    <t t-esc=\"object.job_id.name or 'Position'\"/>\n                  </b> position at\n                  <b style=\"border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">\n                    <t t-esc=\"object.job_id.company_id.name or 'Our Company'\"/>\n                  </b>.\n                </p>\n\n                <br/>\n\n                <p style=\"border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-radius:0px;border-style:none;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;margin:0; padding:0;\">\n                  To keep your application active, please complete the form within the next\n                  <b style=\"border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">48 hours</b>.\n                  If we do not receive your completed form by then, we will assume you are no longer interested and we will close your application.\n                </p>\n\n                <br/>\n\n                <t t-set=\"survey_link\" t-value=\"ctx.get('survey_link') or '#'\"/>\n\n                <div style=\"padding:16px 8px;\">\n                  <a t-att-href=\"survey_link\" style=\"color: #101820; box-sizing: border-box; border: none; margin: 0px; background-color: #ec008c; text-decoration: none; padding: 8px 16px; border-radius: 5px; font-weight: bold;\"><font style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;color: #101820;\">&nbsp;<font style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-color:#ffffff;border-bottom-color:#ffffff;border-right-color:#ffffff;border-top-color:#ffffff;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;color:#ffffff;\">Complete Form Now&nbsp;&nbsp;</font>&nbsp;</font></a></div>\n\n                <p style=\"border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-radius:0px;border-style:none;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;margin:0; padding:0;\">\n                  If you are having any difficulty accessing the form, simply reply to this email and we will help.\n                </p>\n\n                <br/>\n\n                <p style=\"border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-radius:0px;border-style:none;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;margin:0; padding:0;\">\n                  Best regards,<br/>\n                  <b style=\"border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">The Recruitment Team</b>\n                </p>\n\n              </td>\n            </tr>\n          </tbody>\n        </table>\n      </td>\n    </tr>\n  </tbody>\n</table>\n",
