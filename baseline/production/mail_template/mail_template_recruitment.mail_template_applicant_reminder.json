  "payload": {
    "body_html": "<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"100%\" style=\"border-left-color:#808080;border-bottom-color:#808080;border-right-color:#808080;border-top-color:#808080;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-radius: 0px;border-style:none; box-sizing: border-box; border-width: 0px; border-collapse: collapse; caption-side: bottom; margin: 0px; padding: 0px;\" data-oe-version=\"2.0\">\n  <tbody style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;\"><tr style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;\">\n    <td align=\"center\" style=\"border-left-color:#808080;border-bottom-color:#808080;border-right-color:#808080;border-top-color:#808080;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-radius: 0px;border-style:none; margin: 0px; box-sizing: border-box; border-width: 0px; border-color: inherit; padding: 20px 0px; background-color: #f2f2f2;\">\n\n      <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"600\" style=\"border-left-color:#808080;border-bottom-color:#808080;border-right-color:#808080;border-top-color:#808080;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-radius: 0px;border-style:none; padding: 0px; margin: 0px; box-sizing: border-box; border-width: 0px; border-collapse: collapse; caption-side: bottom; max-width: 600px; font-family: Roboto, sans-serif; font-size: 13px; line-height: 1.6;\">\n        <tbody style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;\"><tr style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-left-color:inherit;border-bottom-color:inherit;border-right-color:inherit;border-top-color:inherit;\">\n          <td style=\"border-top-color:#808080;border-right-color:#808080;border-bottom-color:#808080;border-left-color:#808080;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;border-radius: 0px;border-style:none; margin: 0px; box-sizing: border-box; border-width: 0px; border-color: inherit; padding: 20px; background-color: #f2f2f2; color: #101820;\">\n\n            <p style=\"border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-radius:0px;border-style:none;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;margin: 0; padding: 0; font-size: 13px;\">\n              Dear <t t-out=\"object.partner_id.name or object.partner_name or 'Applicant'\"/>,\n              <br/><br/>\n\n              This is a friendly reminder to complete the <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">assessment tests</b> we previously sent for your\n              <t t-esc=\"object.job_id.name or 'Position'\"/>\n              application at <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\"><t t-out=\"object.job_id.company_id.name or 'BICC'\"/></b>.\n              <br/><br/>\n\n              As part of our evaluation process, we ask you to complete the following\n              <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">three short assessments</b>:\n            </p>\n\n            <ul style=\"border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-radius:0px;border-style:none;padding:0 0 0 20px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;list-style-type:disc;padding-left: 20px; margin: 8px 0;\">\n              <li>Logical reasoning</li>\n              <li>Emotional intelligence</li>\n              <li>Technical skills</li>\n            </ul>\n\n            <p style=\"border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-radius:0px;border-style:none;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;margin: 0; padding: 0; font-size: 13px;\">\n              <b style=\"border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;font-family: 'Teko', sans-serif; font-size: 18px;\">\n                Assessment Details\n              </b>\n              <br/>\n            </p>\n\n            <ul style=\"border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-radius:0px;border-style:none;padding:0 0 0 20px;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;list-style-type:disc;padding-left: 20px; margin: 8px 0;\">\n              <li>\n                Each assessment takes about <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">5\u201310 minutes</b>, with up to <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">20 minutes</b> available if needed.\n              </li>\n              <li>\n                Please submit all three\n                <t t-esc=\"'before ' + str(ctx.get('deadline')) if ctx.get('deadline') else 'within the next 7 days'\"/>.\n              </li>\n              <li>\n                They are <b style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;font-weight:bolder;\">multiple-choice</b>. We recommend a quiet, distraction-free environment while completing them.\n              </li>\n            </ul>\n\n            \n            <t t-set=\"logical_test\" t-value=\"ctx.get('logical_test')\"/>\n            <t t-set=\"emotional_test\" t-value=\"ctx.get('emotional_test')\"/>\n            <t t-set=\"technical_test\" t-value=\"ctx.get('technical_test')\"/>\n\n            \n            <div style=\"margin: 16px 5px;\">\n              <a t-att-href=\"(logical_test)\" style=\"border-color: #008f8c; color: #101820; border-style: none; margin: 0px; box-sizing: border-box; border-width: 0px; display: inline-block; background-color: #ec008c; padding: 10px 20px; text-decoration: none; border-radius: 5px; font-size: 13px;\"><font style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-color:#ffffff;border-bottom-color:#ffffff;border-right-color:#ffffff;border-top-color:#ffffff;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;color: #ffffff;\">&nbsp;Logical Reasoning Test&nbsp;</font></a>\n            </div>\n            <div style=\"margin: 16px 5px;\">\n              <a t-att-href=\"(emotional_test)\" style=\"border-color: #008f8c; color: #101820; border-style: none; margin: 0px; box-sizing: border-box; border-width: 0px; display: inline-block; background-color: #ec008c; padding: 10px 20px; text-decoration: none; border-radius: 5px; font-size: 13px;\"><font style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-color:#ffffff;border-bottom-color:#ffffff;border-right-color:#ffffff;border-top-color:#ffffff;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;color: #ffffff;\">&nbsp;Emotional Intelligence Test&nbsp;</font></a>\n            </div>\n            <div style=\"margin: 16px 5px;\">\n              <a t-att-href=\"(technical_test)\" style=\"border-color: #008f8c; color: #101820; border-style: none; margin: 0px; box-sizing: border-box; border-width: 0px; display: inline-block; background-color: #ec008c; padding: 10px 20px; text-decoration: none; border-radius: 5px; font-size: 13px;\"><font style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-color:#ffffff;border-bottom-color:#ffffff;border-right-color:#ffffff;border-top-color:#ffffff;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;color: #ffffff;\">&nbsp;Technical Skills Test&nbsp;</font></a>\n            </div>\n\n            <p style=\"border-left-color:#101820;border-bottom-color:#101820;border-right-color:#101820;border-top-color:#101820;border-radius:0px;border-style:none;box-sizing:border-box;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;margin: 0; padding: 0; font-size: 13px;\">\n              Once you finish all three assessments, we will review your results and contact you regarding the next steps.\n              <br/><br/>\n              If you encounter any issues or have questions, please reply directly to this email.\n              <br/><br/>\n              Best regards,<br/>\n              The Recruitment Team<br/>\n              <t t-out=\"object.job_id.company_id.name or 'Our Company'\"/><br/>\n              <a t-att-href=\"(object.job_id.company_id.website)\" style=\"border-color: #008f8c; color: #101820; border-radius: 0px; border-style: none; padding: 0px; margin: 0px; box-sizing: border-box; border-width: 0px; text-decoration: none;\"><font style=\"border-radius:0px;border-style:none;padding:0px;margin:0px;box-sizing:border-box;border-left-color:#374151;border-bottom-color:#374151;border-right-color:#374151;border-top-color:#374151;border-left-width:0px;border-bottom-width:0px;border-right-width:0px;border-top-width:0px;color: #374151;\">&nbsp;<t t-out=\"object.job_id.company_id.website\"/>&nbsp;</font></a>\n            </p>\n\n          </td>\n        </tr>\n      </tbody></table>\n    </td>\n  </tr>\n</tbody></table>",
    "email_from": "{{ object.company_id.x_studio_short_name }} <{{ object.company_id.alias_domain_id.default_from_email }}>",
    "email_to": "{{ (object.partner_id.email_formatted or object.email_from) }}",
    "lang": "{{ object.partner_id.lang }}",
