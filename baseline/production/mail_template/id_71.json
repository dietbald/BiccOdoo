    "body_html": "<div style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n                <p style=\"box-sizing:border-box;margin: 0px; padding: 0px; font-size: 13px;\">\n                    Dear <t t-out=\"object.partner_id.name or 'applicant'\">[applicant name]</t><br/><br/>\n                    <t>\n                        Thank you for applying to join our team at <b style=\"box-sizing:border-box;font-weight:bolder;\"><t t-out=\"object.partner_id.company_id.name\"/></b> As part of our evaluation process,\n                        we kindly ask you to complete the following three assessments, which will help us gain better insights into your logical reasoning, emotional intelligence, and technical skills.\n                    </t><br/><br/>\n                    <t>\n                        <b style=\"box-sizing:border-box;font-weight:bolder;\">Assestment Details:</b>\n                    </t><br/>\n                    <t>\n                        You will have <b style=\"box-sizing:border-box;font-weight:bolder;\">20 minutes</b> to complete each test, though they should take you approximately <b style=\"box-sizing:border-box;font-weight:bolder;\">5 to 10 minutes</b> to finish.\n                    </t><br/>\n\n                    <t t-set=\"logical_test\" t-value=\"ctx.get('logical_test')\"/>\n                    <t t-set=\"emotional_test\" t-value=\"ctx.get('emotional_test')\"/>\n                    <t t-set=\"technical_test\" t-value=\"ctx.get('technical_test')\"/>\n                    </p><div style=\"margin: 16px 0px 16px 0px;\">\n                        <a t-att-href=\"(logical_test)\" style=\"box-sizing:border-box;background-color: #875A7B; padding: 8px 16px 8px 16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;\">\n                            <t>\n                                Logical Reasoning Test\n                            </t>\n                        </a>\n                    </div>\n                    <div style=\"margin: 16px 0px 16px 0px;\">\n                        <a t-att-href=\"(emotional_test)\" style=\"box-sizing:border-box;background-color: #875A7B; padding: 8px 16px 8px 16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;\">\n                            <t>\n                                Emotional Intelligence Test\n                            </t>\n                        </a>\n                    </div>\n                    <div style=\"margin: 16px 0px 16px 0px;\">\n                        <a t-att-href=\"(technical_test)\" style=\"box-sizing:border-box;background-color: #875A7B; padding: 8px 16px 8px 16px; text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;\">\n                            <t>\n                                Technical Skills Test\n                            </t>\n                        </a>\n                    </div><br/>\n                    <t>\n                        <b style=\"box-sizing:border-box;font-weight:bolder;\">Instructions Details:</b>\n                    </t><br/>\n                    <t>\n                        <ul style=\"padding:0 0 0 32px;margin:0px 0 16px 0;box-sizing:border-box;list-style-type:disc;\">\n                            <li>Each test is multiple-choice and must be completed within the allocated 20 minutes.</li>\n                            <li>We recommend you choose a quiet environment free from distractions to complete the tests efficiently.</li>\n                            <li>Please make sure to complete all three tests within [insert deadline date].</li>\n                        </ul>\n                    </t>\n                    <t>\n                        If you encounter any issues with the links or have any questions, feel free to reach out to us at recruitment@bicc.ph.\n                    </t><br/>\n                    <t>\n                        We look forward to reviewing your results and will be in touch soon regarding the next steps.\n                    </t><br/>\n                    <t>\n                        Thank you for your time and effort!\n                    </t><br/><br/>\n                    <t>\n                        Best regards, <br/>\n                        The Recruitment Team <br/>\n                        <t t-out=\"object.partner_id.company_id.name\"/><br/>\n                        <a t-att-href=\"(object.partner_id.company_id.website)\" style=\"text-decoration: none; box-sizing: border-box; color: #374151;\"><t t-out=\"object.partner_id.company_id.website\"/>\n                        </a>\n                    </t>\n                <p style=\"margin:0px 0 16px 0;box-sizing:border-box;\"/>\n            </div>\n        ",
    "email_from": false,
    "email_to": "{{ (object.partner_id.email_formatted or object.email_from) }}",
    "lang": "{{ object.partner_id.lang }}",
