                    <field name="product_tmpl_id" string="Product Template"/>
                </field>
                <filter name="group_by_categ_id" position="after">
                    <filter string="Product Template" name="group_by_product_tmpl_id" context="{'group_by':'product_tmpl_id'}"/>
                </filter>
            </data>