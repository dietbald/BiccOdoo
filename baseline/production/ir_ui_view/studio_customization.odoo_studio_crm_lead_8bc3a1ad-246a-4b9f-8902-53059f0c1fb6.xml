<data>
  <xpath expr="/list//field[@name='user_company_ids']" position="replace"/>
  <xpath expr="/list//field[@name='email_from']" position="after">
    <field name="x_studio_closing_date" optional="show"/>
    <field name="expected_revenue" optional="show"/>
    <field name="company_currency" optional="hide"/>
  </xpath>
  <xpath expr="/list//field[@name='priority']" position="after">
    <field name="x_studio_awarded_to" optional="hide"/>
  </xpath>
  <xpath expr="/list//button[@name='action_generate_leads']" position="after">
    <button string="New Button" type="action"/>
  </xpath>
  <xpath expr="/list//field[@name='date_deadline']" position="attributes">
    <attribute name="optional">show</attribute>
  </xpath>
  <xpath expr="/list//field[@name='partner_name']" position="attributes">
    <attribute name="optional">show</attribute>
  </xpath>
  <xpath expr="/list//field[@name='email_from']" position="attributes">
    <attribute name="optional">hide</attribute>
  </xpath>
  <xpath expr="/list//field[@name='city']" position="attributes">
    <attribute name="optional">hide</attribute>
  </xpath>
  <xpath expr="/list//field[@name='country_id']" position="attributes">
    <attribute name="optional">hide</attribute>
  </xpath>
  <xpath expr="/list//field[@name='user_id']" position="attributes">
    <attribute name="optional">hide</attribute>
  </xpath>
  <xpath expr="/list//field[@name='team_id']" position="attributes">
    <attribute name="optional">hide</attribute>
  </xpath>
  <xpath expr="/list//field[@name='priority']" position="attributes">
    <attribute name="optional">show</attribute>
  </xpath>
</data>