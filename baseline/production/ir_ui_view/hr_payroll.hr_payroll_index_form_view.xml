<form string="Contract indexing">
                <group colspan="4">
                    <field name="version_ids" widget="many2many_tags" invisible="not context.get('default_version_ids')" options="{'no_create': True}" domain="[('employee_id', '=', context.get('active_employee_id', False))]"/>
                    <field name="employee_ids" widget="many2many_tags" invisible="context.get('default_version_ids')" options="{'no_create': True}" domain="[('company_id', 'in', allowed_company_ids)]"/>
                    <field name="percentage" widget="percentage" class="o_hr_narrow_field"/>
                    <field name="description"/>
                </group>
                <div role="status" class="alert alert-info" invisible="not affected_version_ids or not context.get('default_version_ids')">
                    <field name="informative_message"/>
                </div>
                <div role="status" class="alert alert-info" invisible="context.get('default_version_ids')">
                    The current employee records for each employee will be indexed. All posterior records corresponding to the same contract will also be indexed.
                </div>
                <footer>
                    <button string="Confirm" name="action_confirm" invisible="not version_ids" type="object" class="oe_highlight" data-hotkey="q"/>
                    <button string="Confirm" name="action_confirm" invisible="version_ids" type="object" class="btn btn-primary disabled"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>