<data><page name="information" position="attributes">
                <attribute name="groups">hr_payroll.group_hr_payroll_user</attribute>
            </page>
            <group name="salary_info" position="after">
                <group groups="hr_payroll.group_hr_payroll_user" colspan="4">
                    <field name="payroll_properties" nolabel="1" colspan="4"/>
                    <button name="action_configure_template_inputs" type="object" icon="fa-plus" string="Add Inputs" class="btn btn-secondary text-break m-0"/>
                </group>
            </group>
            <label for="wage" position="before">
                <field name="wage_type"/>
                <field name="schedule_pay"/>
                <label for="hourly_wage" invisible="wage_type != 'hourly'"/>
                <div class="o_row" name="hourly_wage" invisible="wage_type != 'hourly'">
                    <field name="hourly_wage" class="o_hr_narrow_field"/>
                    <span>/ hour</span>
                </div>
            </label>
            <div name="wage_period_label" position="attributes">
                <attribute name="invisible">schedule_pay != 'monthly'</attribute>
            </div>
            <div name="wage_period_label" position="after">
                <span invisible="schedule_pay != 'annually'">/ year</span>
                <span invisible="schedule_pay != 'semi-annually'">/ half-year</span>
                <span invisible="schedule_pay != 'quarterly'">/ quarter</span>
                <span invisible="schedule_pay != 'bi-monthly'">/ two months</span>
                <span invisible="schedule_pay != 'semi-monthly'">/ half-month</span>
                <span invisible="schedule_pay != 'bi-weekly'">/ two weeks</span>
                <span invisible="schedule_pay != 'weekly'">/ week</span>
                <span invisible="schedule_pay != 'daily'">/ day</span>
            </div>
            <field name="resource_calendar_id" position="attributes">
                <attribute name="groups">hr.group_hr_manager</attribute>
            </field>
            <page name="information" position="attributes">
                <attribute name="groups">hr_payroll.group_hr_payroll_user</attribute>
            </page>
        </data>