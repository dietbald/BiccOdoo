<data><list position="attributes">
                <attribute name="default_order">state desc</attribute>
                <attribute name="decoration-muted">state == 'close'</attribute>
            </list>
            <list position="inside">
                <control>
                    <button string="Add a salary adjustment" name="action_open_employee_salary_attachment" class="btn-link" type="object" context="{&quot;new&quot;: 1}"/>
                </control>
                <button class="btn btn-link" string="Restart" icon="fa-play" type="object" name="action_open" invisible="state == 'open' or employee_count &gt; 1"/>
                <button class="btn btn-link" string="Stop" icon="fa-stop" type="object" name="action_close" invisible="state == 'close' or employee_count &gt; 1"/>
                <button class="btn btn-link" string="Split" icon="fa-scissors" type="object" name="action_split" invisible="employee_count &lt;= 1"/>
            </list>
            <field name="date_start" position="before">
                <field name="other_input_type_id" position="move"/>
            </field>
            <field name="employee_ids" position="replace">
            </field>
        </data>