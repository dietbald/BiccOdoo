<data inherit_id="account.report_invoice_document" primary="True">
        <xpath expr="//div[@id='qrcode']" position="replace">
            <t t-if="qr_code" t-call="account.report_invoice_qr_code_preview"/>
        </xpath>
        <xpath expr="//p[@name='payment_communication']//t[@t-if='o.partner_bank_id']" position="replace">
            <t t-if="account_number">
                <br/> on this account: <span t-out="account_number" class="fw-bold"/>
            </t>
        </xpath>
    <xpath expr="." position="attributes"><attribute name="t-name">account.report_invoice_document_preview</attribute></xpath></data>