<t name="Partner Details" t-name="website_partner.partner_detail">
    <div class="row mt-3" itemscope="itemscope" itemtype="http://schema.org/Organization">
        <div class="col-lg-3 col-md-4">
            <div t-field="partner.image_1920" t-options="{                 &quot;widget&quot;: &quot;image&quot;,                 &quot;preview_image&quot;: &quot;avatar_1920&quot;,                 &quot;style&quot;: &quot;object-fit: cover&quot;,                 &quot;class&quot;: &quot;w-100 mb-2 rounded-3 border o_partner_image oe_unremovable&quot;,                 &quot;itemprop&quot;: &quot;image&quot;             }"/>
            <t t-if="contact_details">
                <div class="o_wcrm_contact_details">
                    <div t-field="partner.self" t-options="{                         &quot;widget&quot;: &quot;contact&quot;,                         &quot;fields&quot;: [&quot;address&quot;, &quot;website&quot;, &quot;phone&quot;, &quot;email&quot;],                         &quot;with_microdata&quot;: True,                     }"/>
                    <t t-out="left_column or ''"/>
                </div>
            </t>
        </div>
        <div class="col-lg-9 col-md-8">
            <div class="d-flex align-items-center flex-wrap mb-4">
                <div class="flex-grow-1">
                    <h1 id="partner_name" t-field="partner.display_name" itemprop="name"/>
                </div>
            </div>
            <t t-if="partner">
                <div t-field="partner.website_description" class="mb-5"/>
            </t>
            <t t-out="right_column or ''"/>
        </div>
    </div>
</t>