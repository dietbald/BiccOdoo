<data><xpath expr="//div[hasclass('o_social_post_preview_container')]" position="inside">
                <field name="has_facebook_account" invisible="1"/>
                <field name="display_facebook_preview" invisible="1"/>
                <field name="facebook_preview" nolabel="1" colspan="2" widget="social_post_preview" media_type="facebook_preview" readonly="1" invisible="not display_facebook_preview" class="o_social_preview_wrapper m-0 px-4 py-4 bg-200"/>
            </xpath>
            <xpath expr="//notebook[@name='media_customization']" position="inside">
                <page string="Facebook" name="facebook_content" invisible="not has_facebook_account">
                    <group>
                        <group>
                            <field name="facebook_message" required="is_split_per_media and has_facebook_account and not facebook_image_ids" string="Message"/>
                            <field name="facebook_image_ids" widget="many2many_binary" required="is_split_per_media and has_facebook_account and not facebook_message" string="Images"/>
                        </group>
                        <group invisible="not display_facebook_preview">
                            <field name="facebook_preview" nolabel="1" widget="social_post_preview" media_type="facebook_preview" readonly="1" class="o_social_preview_wrapper m-0 px-4 py-4 bg-200"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </data>