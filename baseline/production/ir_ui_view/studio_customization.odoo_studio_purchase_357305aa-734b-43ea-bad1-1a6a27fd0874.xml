<data>
  <xpath expr="/form" position="attributes">
    <attribute name="delete">false</attribute>
  </xpath>
  <xpath expr="/form/header/button[@name='action_rfq_send']" position="attributes">
    <attribute name="invisible">True</attribute>
    <attribute name="studio_approval">True</attribute>
  </xpath>
  <xpath expr="/form/header/button[@name='action_rfq_send'][2]" position="attributes">
    <attribute name="invisible">True</attribute>
    <attribute name="studio_approval">True</attribute>
  </xpath>
  <xpath expr="/form/header/button[@name='action_rfq_send'][3]" position="attributes">
    <attribute name="invisible">True</attribute>
    <attribute name="studio_approval">True</attribute>
  </xpath>
  <xpath expr="/form//field[@name='picking_type_id']" position="after">
    <xpath expr="/form//field[@name='project_id']" position="move"/>
  </xpath>
  <xpath expr="/form//field[@name='project_id']" position="attributes">
    <attribute name="groups"/>
    <attribute name="required">True</attribute>
  </xpath>
  <xpath expr="/form/sheet/notebook/page[@name='products']/field[@name='order_line']/list//field[@name='price_subtotal']" position="after">
    <field name="price_total" optional="show"/>
  </xpath>
  <xpath expr="/form/sheet/notebook/page[@name='products']/field[@name='order_line']/list//field[@name='currency_id']" position="attributes">
    <attribute name="column_invisible">False</attribute>
    <attribute name="invisible">False</attribute>
  </xpath>
  <xpath expr="/form/sheet/notebook/page[@name='products']/field[@name='order_line']/list//field[@name='product_id']" position="attributes">
    <attribute name="options">{"no_create":true}</attribute>
  </xpath>
  <xpath expr="/form/sheet/notebook/page[@name='purchase_delivery_invoice']/group/group[@name='other_info']/field[@name='company_id']" position="after">
    <field widget="signature" name="x_studio_supplier_signature" force_save="1" readonly="True"/>
  </xpath>
  <xpath expr="/form//field[@name='fiscal_position_id']" position="after">
    <field name="write_uid"/>
  </xpath>
</data>