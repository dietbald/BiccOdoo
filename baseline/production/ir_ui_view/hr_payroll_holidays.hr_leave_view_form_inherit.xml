<data><xpath expr="//field[@name='holiday_status_id']" position="after">
                <field name="payslip_state" widget="state_selection" options="{'hide_label': False}" class="ms-auto mb-2" invisible="state == 'cancel' or not id"/>
            </xpath>
            <button name="action_back_to_approval" position="before">
                <button string="Report to Next Month" name="action_report_to_next_month" type="object" class="oe_highlight" groups="hr_payroll.group_hr_payroll_user" invisible="payslip_state != 'blocked' or state != 'validate'"/>
            </button>
        </data>