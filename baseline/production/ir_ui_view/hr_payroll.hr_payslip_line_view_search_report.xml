<search string="Search Payslip Lines">
                <field name="employee_id" domain="[('company_id', 'in', allowed_company_ids)]"/>
                <field name="name" string="Payslip Lines" filter_domain="['|',('name','ilike',self),('code','ilike',self)]"/>
                <field name="slip_id" string="Payslip Name"/>
                <filter string="Paid" name="is_paid" domain="[('slip_id.state', '=', 'paid')]"/>
                <filter string="Validated" name="is_validated" domain="[('slip_id.state', '=', 'validated')]"/>
                <filter string="Draft" name="is_draft" domain="[('slip_id.state', '=', 'draft')]"/>
                <separator/>
                <filter string="Date" name="date_from" date="date_from" default_period="year"/>
                <filter string="Salary Rule Category" name="category_id" context="{'group_by':'category_id'}"/>
                <filter string="Salary Rule" name="salary_rule_id" context="{'group_by': 'salary_rule_id'}"/>
            </search>