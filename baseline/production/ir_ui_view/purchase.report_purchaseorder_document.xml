<t t-name="purchase.report_purchaseorder_document">
    <t t-call="web.external_layout">
        <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang)"/>
        <t t-set="address">
            <div t-field="o.partner_id" t-options="{&quot;widget&quot;: &quot;contact&quot;, &quot;fields&quot;: [&quot;address&quot;, &quot;name&quot;, &quot;phone&quot;, &quot;vat&quot;], &quot;no_marker&quot;: True, &quot;phone_icons&quot;: True}"/>
        </t>
        <t t-if="o.dest_address_id">
            <t t-set="information_block">
                <strong class="d-block mt-3">Shipping address</strong>
                <div t-if="o.dest_address_id">
                    <div t-field="o.dest_address_id" t-options="{&quot;widget&quot;: &quot;contact&quot;, &quot;fields&quot;: [&quot;address&quot;, &quot;name&quot;, &quot;phone&quot;], &quot;no_marker&quot;: True, &quot;phone_icons&quot;: True}" name="purchase_shipping_address"/>
                </div>

            </t>
        </t>
        <div class="page" style="padding-top:0px; font-size:11px; font-family:'Roboto',sans-serif;">
            <div class="oe_structure"/>
            <!-- ─────────────────────────  HEADER  ───────────────────────── -->
            <div style="text-align:center; margin-bottom:6px;">
                <span style="font-family:'Teko',sans-serif; font-size:18px; font-weight:bold; color:#101820;">
                    <t t-if="o.state in ['draft', 'sent', 'To Approve']">Request for Quotation
                    </t>
                    <t t-if="o.state in ['purchase', 'done']">Purchase Order
                    </t>
                    <t t-if="o.state == 'cancel'">Cancelled Purchase Order
                    </t>
                </span>
            </div>
            <!-- PO meta + Billed-to + BIR (no flex, Bootstrap grid only) -->
            <div class="row mb-1">
                <!-- LEFT: Billed To + BIR (about 60%) -->
                <div class="col-7">
                    <!-- Billed To -->
                    <div class="row">
                        <div class="col-4" style="max-width:90px;">
                            <strong>Billed To:</strong>
                        </div>
                        <div class="col-8">
                            <div>
                                <span t-field="o.company_id.name"/>
                            </div>
                            <div>
                                <span t-field="o.company_id.partner_id.street"/>
                            </div>
                            <div>
                                <span t-field="o.company_id.partner_id.city"/>,
                                
                                <span t-field="o.company_id.partner_id.zip"/>
                            </div>
                            <t t-if="o.company_id.phone">
                                <div>Phone: 
                                    <span t-field="o.company_id.phone"/>
                                </div>
                            </t>
                            <t t-if="o.company_id.email">
                                <div>Email: 
                                    <span t-field="o.company_id.email"/>
                                </div>
                            </t>
                        </div>
                    </div>
                    <!-- BIR TIN -->
                    <div class="row" style="margin-top:2px;">
                        <div class="col-4" style="max-width:90px;">
                            <strong>TIN No.:</strong>
                        </div>
                        <div class="col-8">
                            <span t-field="o.company_id.vat"/>
                        </div>
                    </div>
                    <!-- Project ID -->
                    <div class="row" style="margin-top:2px;">
                        <div class="col-4" style="max-width:90px;">
                            <strong>Project :</strong>
                        </div>
                        <div class="col-8">
                            <span t-field="o.project_id.name"/>
                        </div>
                    </div>
                </div>
                <!-- RIGHT: PO # and Date (about 40%) -->
                <div class="col-5 text-end">
                    <div>
                        <strong>PO #:</strong>
                        <span t-field="o.name"/>
                    </div>
                    <div>
                        <strong>Date:</strong>
                        <span t-field="o.date_order" t-options="{'date_only': True}"/>
                    </div>
                </div>
            </div>
            <!-- ───────────────────  VENDOR & SHIP-TO PANELS  ────────────────── -->
            <div class="d-flex justify-content-between mt-4" style="gap: 12px;">
                <!-- VENDOR -->
                <div style="width: 49%;">
                    <div t-att-style="'background-color: %s; color: white; font-family: Montserrat, sans-serif; padding: 6px 10px;'  % ((o.company_id.primary_color or env.company.primary_color or '#EC008C'))">
                        <strong>VENDOR</strong>
                    </div>
                    <div style="border: 1px solid #101820; border-top: none; padding: 10px; font-size: 11px;">
                        <div class="row">
                            <div style="width: 30%;">
                                <strong>Company:</strong>
                            </div>
                            <div style="width: 70%;">
                                <t t-if="o.partner_id.parent_id">
                                    <span t-field="o.partner_id.parent_id.name"/>
                                </t>
                                <t t-else="">
                                    <span t-field="o.partner_id.name"/>
                                </t>
                            </div>
                        </div>
                        <t t-if="o.partner_id.parent_id">
                            <div class="row">
                                <div style="width: 30%;">
                                    <strong>Contact:</strong>
                                </div>
                                <div style="width: 70%;">
                                    <span t-field="o.partner_id.name"/>
                                </div>
                            </div>
                        </t>
                        <div class="row">
                            <div style="width: 30%;">
                                <strong>Address:</strong>
                            </div>
                            <div style="width: 70%;">
                                <span t-field="o.partner_id.street"/>
                                <br/>
                                <span t-field="o.partner_id.city"/>, 
          
                                
                                
                                <span t-field="o.partner_id.state_id.name"/>
                                <span t-field="o.partner_id.zip"/>
                                <br/>
                                <span t-field="o.partner_id.country_id.name"/>
                            </div>
                        </div>
                        <t t-if="o.partner_id.phone">
                            <div class="row">
                                <div style="width: 30%;">
                                    <strong>Phone:</strong>
                                </div>
                                <div style="width: 70%;">
                                    <span t-field="o.partner_id.phone"/>
                                </div>
                            </div>
                        </t>
                        <t t-if="o.partner_id.email">
                            <div class="row">
                                <div style="width: 30%;">
                                    <strong>Email:</strong>
                                </div>
                                <div style="width: 70%;">
                                    <span t-field="o.partner_id.email"/>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
                <!-- SHIP TO -->
                <div style="width: 49%;">
                    <div t-att-style="'background-color: %s; color: white; font-family: Montserrat, sans-serif; padding: 6px 10px;'   % ((o.company_id.primary_color or env.company.primary_color or '#EC008C'))">
                        <strong>SHIP TO</strong>
                    </div>
                    <div style="border: 1px solid #101820; border-top: none; padding: 10px; font-size: 11px;">
                        <t t-if="o.dest_address_id">
                            <t t-set="partner" t-value="o.dest_address_id"/>
                            <t t-if="partner.parent_id">
                                <div class="row">
                                    <div style="width: 30%;">
                                        <strong>Company Name:</strong>
                                    </div>
                                    <div style="width: 70%;">
                                        <span t-field="partner.parent_id.name"/>
                                    </div>
                                </div>
                            </t>
                            <div class="row">
                                <div style="width: 30%;">
                                    <strong>Contact:</strong>
                                </div>
                                <div style="width: 70%;">
                                    <t t-if="partner.name">
                                        <span t-field="partner.name"/>
                                    </t>
                                    <t t-else="">
                                        <span t-field="o.user_id.name"/>
                                    </t>
                                </div>
                            </div>
                            <div class="row">
                                <div style="width: 30%;">
                                    <strong>Address:</strong>
                                </div>
                                <div style="width: 70%;">
                                    <span t-field="partner.street"/>
                                    <br/>
                                    <span t-field="partner.city"/>, 
            
                                    
                                    
                                    <span t-field="partner.state_id.name"/>
                                    <span t-field="partner.zip"/>
                                    <br/>
                                    <span t-field="partner.country_id.name"/>
                                </div>
                            </div>
                            <t t-if="partner.phone">
                                <div class="row">
                                    <div style="width: 30%;">
                                        <strong>Contact No.:</strong>
                                    </div>
                                    <div style="width: 70%;">
                                        <span t-field="partner.phone"/>
                                    </div>
                                </div>
                            </t>
                            <t t-if="not partner.phone and o.user_id.partner_id.mobile">
                                <div class="row">
                                    <div style="width: 30%;">
                                        <strong>Contact No.:</strong>
                                    </div>
                                    <div style="width: 70%;">
                                        <span t-field="o.user_id.partner_id.mobile"/>
                                    </div>
                                </div>
                            </t>
                            <t t-if="partner.email">
                                <div class="row">
                                    <div style="width: 30%;">
                                        <strong>Email:</strong>
                                    </div>
                                    <div style="width: 70%;">
                                        <span t-field="partner.email"/>
                                    </div>
                                </div>
                            </t>
                        </t>
                        <t t-else="">
                            <t t-if="o.picking_type_id and o.picking_type_id.warehouse_id">
                                <t t-set="wh_partner" t-value="o.picking_type_id.warehouse_id.partner_id"/>
                                <div class="row">
                                    <div style="width: 30%;">
                                        <strong>Company Name:</strong>
                                    </div>
                                    <div style="width: 70%;">
                                        <span t-field="o.picking_type_id.warehouse_id.name"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <div style="width: 30%;">
                                        <strong>Contact:</strong>
                                    </div>
                                    <div style="width: 70%;">
                                        <span t-field="o.user_id.name"/>
                                    </div>
                                </div>
                                <div class="row">
                                    <div style="width: 30%;">
                                        <strong>Address:</strong>
                                    </div>
                                    <div style="width: 70%;">
                                        <span t-field="wh_partner.street"/>
                                        <br/>
                                        <span t-field="wh_partner.city"/>, 
              
                                        
                                        
                                        <span t-field="wh_partner.state_id.name"/>
                                        <span t-field="wh_partner.zip"/>
                                        <br/>
                                        <span t-field="wh_partner.country_id.name"/>
                                    </div>
                                </div>
                                <t t-if="wh_partner.phone">
                                    <div class="row">
                                        <div style="width: 30%;">
                                            <strong>Contact No.:</strong>
                                        </div>
                                        <div style="width: 70%;">
                                            <span t-field="wh_partner.phone"/>
                                        </div>
                                    </div>
                                </t>
                                <t t-if="not wh_partner.phone and o.user_id.partner_id.mobile">
                                    <div class="row">
                                        <div style="width: 30%;">
                                            <strong>Contact No.:</strong>
                                        </div>
                                        <div style="width: 70%;">
                                            <span t-field="o.user_id.partner_id.mobile"/>
                                        </div>
                                    </div>
                                </t>
                                <t t-if="wh_partner.email">
                                    <div class="row">
                                        <div style="width: 30%;">
                                            <strong>Email:</strong>
                                        </div>
                                        <div style="width: 70%;">
                                            <span t-field="wh_partner.email"/>
                                        </div>
                                    </div>
                                </t>
                                <div t-if="o.date_planned" class="row">
                                    <div style="width: 30%;">
                                        <strong>Exp. Arrival:</strong>
                                    </div>
                                    <div style="width: 70%;">
                                        <p t-field="o.date_planned" t-options="{'date_only': 'true'}"/>
                                    </div>
                                </div>
                                <div t-if="o.incoterm_id" class="col-2 bm-2">
                                    <strong>Incoterm:</strong>
                                    <p t-if="o.incoterm_location">
                                        <span t-field="o.incoterm_id.code"/>
                                        <br/>
                                        <span t-field="o.incoterm_location"/>
                                    </p>
                                    <p t-else="" t-field="o.incoterm_id.code" class="m-0"/>
                                </div>
                            </t>
                        </t>
                    </div>
                </div>
            </div>
            <!-- Item Table -->
            <div style="margin-top: 12px; width: 100%;">
                <table class="table table-sm table-bordered" style="width: 100%; font-family: 'Roboto', sans-serif; font-size: 11px;">
                    <thead t-att-style="'background-color: %s; color: white;' % ((o.company_id.primary_color or env.company.primary_color or '#EC008C'))">
                        <tr style="color: white;">
                            <th style="width: 7%; color: white;">Item #</th>
                            <th style="width: 45%; color: white;">Description</th>
                            <th class="text-end" style="width: 10%; color: white;">Qty</th>
                            <th style="width: 10%; color: white;">UOM</th>
                            <th class="text-end" style="width: 14%; color: white;">Unit Price</th>
                            <th class="text-end" style="width: 14%; color: white;">Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-set="counter" t-value="1"/>
                        <t t-foreach="o.order_line" t-as="line">
                            <tr>
                                <td class="text-center">
                                    <span t-out="counter"/>
                                </td>
                                <td>
                                    <span t-field="line.name"/>
                                </td>
                                <td class="text-end">
                                    <span t-field="line.product_qty" t-options="{'decimal_places': 2}"/>
                                </td>
                                <td>
                                    <span t-field="line.product_uom_id"/>
                                </td>
                                <td class="text-end">
                                    <span t-field="line.price_unit" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                </td>
                                <td class="text-end">
                                    <span t-field="line.price_subtotal" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                </td>
                            </tr>
                            <t t-set="counter" t-value="counter + 1"/></t>
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="5" class="text-end">
                                <strong>SUBTOTAL</strong>
                            </td>
                            <td class="text-end">
                                <span t-out="o.amount_untaxed" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="5" class="text-end">
                                <strong>12% TAX</strong>
                            </td>
                            <td class="text-end">
                                <span t-out="o.amount_tax" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                            </td>
                        </tr>
                        <tr>
                            <td colspan="5" class="text-end">
                                <strong>TOTAL</strong>
                            </td>
                            <td class="text-end" t-att-style="'background-color: %s; color: white;' % ((o.company_id.primary_color or env.company.primary_color or '#EC008C'))">
                                <span t-out="o.amount_total" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            <!-- ─────────────  TERMS + SIGNATURES  ──────────── -->
            <div class="row" style="margin-top:14px; font-size:11px;">
                <!-- Terms box (≈70%) -->
                <div class="col-8">
                    <div style="border:1px solid #101820; padding:10px;">
                        <strong>Terms and Conditions</strong>
                         <p t-field="o.note" style="margin:6px 0 0 0;"/>
                        <strong>Payment Terms</strong>
                        <span t-field="o.payment_term_id" class="d-block"/>
                    </div>
                </div>
                <!-- Signature block (≈30%) -->
                <div class="col-4" style="padding-left:12px;">
                    <!-- Created By / Buyer -->
                    <div style="margin-bottom:18px;">
                        <strong>Created By:</strong>
                        <br/>
                        <span t-field="o.user_id.name"/>
                        <br/>
                        
                        <t t-if="o.user_id">
                            <t t-set="approver" t-value="o.user_id.sudo()"/>
                            <t t-if="approver.sign_signature">
                                <img t-att-src="image_data_uri(approver.sign_signature)" style="max-height:60px; margin-top:4px;"/>
                            </t>
                            <t t-else="">
                                <div style="height:60px; border-bottom:1px solid #000; margin-top:4px;"/>
                            </t>
                        </t>
                    </div>
                    <!-- Approver -->
                    <div style="margin-bottom:18px;">
                        <strong>Approver:</strong>
                        <br/>
                        <span t-field="o.write_uid.name"/>
                        <br/>
                        <t t-if="o.write_uid">
                            <t t-set="approver" t-value="o.write_uid.sudo()"/>
                            <t t-if="approver.sign_signature">
                                <img t-att-src="image_data_uri(approver.sign_signature)" style="max-height:60px; margin-top:4px;"/>
                            </t>
                            <t t-else="">
                                <div style="height:60px; border-bottom:1px solid #000; margin-top:4px;"/>
                            </t>
                        </t>
                    </div>
                    <!-- Supplier acceptance signature (Studio field) -->
                    <div>
                        <strong>Confirmed PO Acceptance:</strong>
                        <br/>
                        
                        <t t-if="o.x_studio_supplier_signature">
                            <span t-field="o.x_studio_supplier_signature" widget="signature" style="display:block; height:80px; margin-top:6px; margin-bottom:4px;"/>
                        </t>
                        <t t-else="">
                            <div style="height:60px; border-bottom:1px solid #000; margin-top:4px;"/>
                        </t>
                        <span>Supplier Representative</span>
                    </div>
                </div>
            </div>
        </div>
    </t>
</t>