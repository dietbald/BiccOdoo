<form string="Salary Adjustment">
                <header>
                    <button name="action_close" type="object" string="Mark as Completed" invisible="state != 'open' or employee_count &gt; 1"/>
                    <button name="action_split" type="object" string="Create Individual Attachments" class="oe_highlight" invisible="state != 'open' or employee_count &lt;= 1"/>
                    <button name="action_open" type="object" string="Running" invisible="state != 'close' or employee_count &gt; 1"/>
                    <field name="state" widget="statusbar" invisible="employee_count &gt; 1"/>
                </header>
                <div role="alert" class="alert alert-warning text-center" invisible="not has_similar_attachment">
                    <field name="has_similar_attachment_warning"/>
                    <field name="has_similar_attachment" invisible="1"/>
                </div>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_open_payslips" class="oe_stat_button" icon="fa-money" id="open_payslips" invisible="payslip_count == 0">
                            <field name="payslip_count" widget="statinfo" string="Payslips"/>
                        </button>
                    </div>
                    <!-- invisible fields to compute fields visibility in the form view -->
                    <field name="company_id" invisible="1"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="has_total_amount" invisible="1"/>
                    <field name="attachment_name" invisible="1"/>
                    <field name="employee_count" invisible="1"/>
                    <field name="has_done_payslip" invisible="1"/>
                    <field name="is_quantity" invisible="1"/>
                    <group>
                        <field name="employee_ids" widget="many2many_avatar_employee" readonly="has_done_payslip" invisible="context.get('default_employee_ids')"/>
                        <field name="other_input_type_id" readonly="has_done_payslip" context="{'default_available_in_attachments': True}"/>
                        <label for="monthly_amount"/>
                        <span class="d-flex">
                            <span style="width: 150px">
                                <span invisible="not is_refund" class="me-1">-</span>
                                <field class="o_hr_narrow_field" name="monthly_amount" invisible="not is_quantity" widget="float"/>
                                <field class="o_hr_narrow_field" name="monthly_amount" invisible="is_quantity"/>
                            </span>
                            <label for="is_refund" class="me-4"/>
                            <field name="is_refund" readonly="has_done_payslip"/>
                        </span>
                        <field name="duration_type" widget="radio" options="{'horizontal': True}"/>
                        <span/>
                        <span>
                            from
                            <field name="date_start" style="width: 10ch;" readonly="has_done_payslip"/>
                            <span invisible="not duration_type == 'limited'">
                                until
                                <field name="total_amount" class="o_hr_narrow_field" invisible="not is_quantity or not has_total_amount" required="has_total_amount" widget="float"/>
                                <field name="total_amount" class="o_hr_narrow_field" invisible="is_quantity or not has_total_amount" required="has_total_amount"/>
                                <span invisible="is_quantity">paid</span>
                            </span>
                        </span>
                        <span invisible="(not date_estimated_end and not date_end and state == 'open') or duration_type != 'limited'"/>
                        <span class="text-muted" invisible="not date_estimated_end and (not date_end or state == 'open') or duration_type != 'limited'">
                            end in <field name="remaining_time" class="w-auto"/> :
                            <field name="date_estimated_end" style="width: 10ch;" invisible="not date_estimated_end"/>
                            <field name="date_end" style="width: 10ch;" invisible="not date_end or state == 'open'" readonly="has_done_payslip"/>
                        </span>
                        <field name="description" readonly="has_done_payslip" placeholder="Optional reason, or reference"/>
                    </group>
                </sheet>
                <chatter/>
            </form>