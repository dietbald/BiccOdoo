<data><xpath expr="//div[hasclass('o_social_post_preview_container')]" position="inside">
                <field name="display_instagram_preview" invisible="1"/>
                <field name="instagram_preview" nolabel="1" colspan="2" widget="social_post_preview" media_type="instagram" readonly="1" invisible="not display_instagram_preview" class="o_social_preview_wrapper m-0 px-4 py-4 bg-200"/>
            </xpath>
            <xpath expr="//notebook[@name='media_customization']" position="inside">
                <page string="Instagram" name="instagram_content" invisible="not has_instagram_account">
                    <group>
                        <group>
                            <field name="instagram_message" required="is_split_per_media and has_instagram_account and not instagram_image_ids" string="Message"/>
                            <field name="instagram_image_ids" widget="many2many_binary" required="is_split_per_media and has_instagram_account and not instagram_message" string="Images"/>
                        </group>
                        <group invisible="not display_instagram_preview">
                            <field name="instagram_preview" nolabel="1" widget="social_post_preview" media_type="instagram_preview" readonly="1" class="o_social_preview_wrapper m-0 px-4 py-4 bg-200"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </data>