<kanban highlight_color="color" class="o_quality_kanban" create="0" can_open="0">
                <field name="alias_email"/>
                <templates>
                    <t t-name="menu">
                        <div t-if="widget.editable" role="menuitem">
                            <a class="dropdown-item ps-0" type="open">Configuration</a>
                        </div>
                        <div t-if="widget.editable" role="menuitem" aria-haspopup="true">
                            <field name="color" widget="kanban_color_picker"/>
                        </div>
                    </t>
                    <t t-name="card">
                        <field name="name" class="fw-bold fs-4 ms-2"/>
                        <div t-if="record.alias_email.value" class="small ms-2">
                            <i class="fa fa-envelope-o" role="img" aria-label="Domain alias" title="Domain alias"/>&amp;nbsp; <field name="alias_id"/>
                        </div>
                        <div class="row mt-3">
                            <div class="col-6">
                                <button class="btn btn-primary ms-2" name="1172" type="action">
                                    <span><field name="alert_count"/> Quality Alerts</span>
                                </button>
                            </div>
                            <a name="1176" type="action" class="col-6">
                                <field name="check_count"/>
                                Checks In Progress
                            </a>
                        </div>
                    </t>
                </templates>
            </kanban>