<kanban class="o_kanban_mobile" sample="1" js_class="account_documents_kanban">
                    <field name="currency_id"/>
                    <templates>
                        <t t-name="card">
                            <div class="d-flex align-items-baseline mb-2">
                                <field name="name" class="fw-bolder fs-5 me-2" readonly="state != 'draft'"/>
                                <field name="amount" widget="monetary" class="fw-bolder ms-auto flex-shrink-0"/>
                            </div>
                             <footer class="align-items-end">
                                <div class="d-flex flex-wrap gap-1 text-muted text-nowrap">
                                    <field name="date"/>
                                    <field name="activity_ids" widget="kanban_activity"/>
                                </div>
                                <field name="state" class="ms-auto" widget="label_selection" options="{'classes': {'new': 'default', 'sent': 'default', 'reconciled': 'success'}}"/>
                            </footer>
                        </t>
                    </templates>
                </kanban>