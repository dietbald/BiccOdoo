<gantt js_class="hr_holidays_gantt" string="Time Off" date_start="start_datetime" date_stop="stop_datetime" default_range="month" default_group_by="employee_id" decoration-info="state in ['confirm', 'validate1']" decoration-danger="state == 'refused'" color="employee_id" total_row="True" display_unavailability="True" sample="1">
                    <field name="name"/>
                    <field name="state" invisible="1"/>
                    <field name="is_manager"/>
                <templates>
                    <div t-name="gantt-popover">
                        <t t-out="start_datetime.toFormat('f ')"/>
                        <i class="fa fa-long-arrow-right" title="Arrow"/>
                        <t t-out="stop_datetime.toFormat(' f')"/>
                        <footer replace="0">
                            <button name="action_approve" class="btn btn-secondary btn-sm" string="Approve" type="object" t-if="is_manager and ['confirm', 'refuse'].includes(state)"/>
                            <button name="action_approve" class="btn btn-secondary btn-sm" string="Validate" type="object" t-if="is_manager and state == 'validate1'"/>
                            <button name="action_refuse" class="btn btn-secondary btn-sm" string="Refuse" type="object" t-if="is_manager and state != 'refuse'"/>
                        </footer>
                    </div>
                </templates>
                </gantt>