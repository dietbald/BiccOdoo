<kanban>
                <field name="id"/>
                <field name="name"/>
                <field name="cost"/>
                <field name="awarded_employees"/>
                <field name="description"/>
                <templates>
                    <t t-name="card" class="flex-row">
                        <main>
                            <field name="name" class="fw-bolder fs-5"/>
                            <span><field name="cost"/> Points</span>
                            <span><field name="awarded_employees"/> Awarded Employees</span>
                            <field name="description" class="fst-italic text-muted"/>
                        </main>
                        <aside>
                            <field name="image" widget="image" alt="Reward" options="{'img_class': 'object-fit-contain'}" invisible="not image"/>
                            <field name="gift_manager_id" widget="referral_many2one_avatar_user"/>
                        </aside>
                    </t>
                </templates>
            </kanban>