<form string="Journal Item" js_class="bankrec_edit_line">
                <sheet>
                    <field name="has_invalid_analytics" invisible="1"/>
                    <div invisible="not has_invalid_analytics" class="alert alert-warning mb-3" role="alert">
                        This line requires analytic distribution.
                    </div>
                    <group>
                        <group name="left_group">
                            <field name="move_id" invisible="1"/>
                            <field name="amount_currency" invisible="1"/> <!-- Needed so that the onchange has the amount currency everytime -->
                            <label for="balance"/>
                            <div class="d-flex justify-space-between">
                                <field name="balance" no_label="1"/>
                                <field name="company_currency_id" invisible="1"/>
                                <field name="currency_id" groups="base.group_multi_currency" class="ms-2" invisible="not is_same_currency" options="{'no_create': True, 'no_open': True}"/>
                                <div invisible="is_same_currency" groups="base.group_multi_currency" class="d-flex gap-2">
                                    (
                                    <field name="amount_currency" class="w-50"/>
                                    <field name="currency_id" no_label="1" class="w-50" placeholder="secondary currency" options="{'no_create': True, 'no_open': True}"/>
                                    )
                                </div>
                            </div>
                            <field name="full_amount_switch_html" string="" widget="apply_amount_html" invisible="not reconciled_lines_excluding_exchange_diff_ids"/>
                            <field name="account_id" readonly="reconciled_lines_excluding_exchange_diff_ids"/>
                            <field name="partner_id" readonly="reconciled_lines_excluding_exchange_diff_ids"/>
                            <field name="name" readonly="reconciled_lines_excluding_exchange_diff_ids"/>
                        </group>
                        <group name="right_group">
                            <field name="date" readonly="reconciled_lines_excluding_exchange_diff_ids"/>
                            <field name="tax_ids" widget="many2many_tags" invisible="reconciled_lines_excluding_exchange_diff_ids" context="{'append_fields': ['type_tax_use']}"/>
                            <field name="analytic_distribution" groups="analytic.group_analytic_accounting" widget="analytic_distribution" options="{'account_field': 'account_id', 'business_domain': 'general'}"/>
                        </group>
                    </group>
                </sheet>
            </form>