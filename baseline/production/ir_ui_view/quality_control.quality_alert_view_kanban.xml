<kanban default_group_by="stage_id" class="o_kanban_small_column" sample="1">
                <templates>
                    <t t-name="card">
                        <field name="tag_ids"/>
                        <field name="product_tmpl_id" class="fw-bolder"/>
                        <field name="display_name"/>
                        <footer>
                            <div class="d-flex">
                                <field name="priority" widget="priority"/>
                                <field name="activity_ids" widget="kanban_activity" class="ms-2"/>
                            </div>
                            <field name="user_id" widget="many2one_avatar_user" class="ms-auto"/>
                        </footer>
                    </t>
                </templates>
            </kanban>