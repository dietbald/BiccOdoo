<t t-name="documents.folder_notification_move_in">
            <p t-if="len(documents) == 1">
                <span t-out="documents[0].display_name"/> was moved inside this folder.
            </p>
            <t t-else="">
                <p>The following documents were moved inside this folder:</p>
                <ul>
                    <li t-foreach="documents" t-as="document">
                        <span t-out="document.display_name"/>
                    </li>
                </ul>
            </t>
        </t>