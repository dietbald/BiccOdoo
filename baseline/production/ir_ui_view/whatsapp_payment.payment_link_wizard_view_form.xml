<xpath expr="//footer/button[@special='cancel']" position="before">
                <field name="can_send_whatsapp" invisible="1"/>
                <button name="action_send_whatsapp" string="Send by WhatsApp" class="btn btn-secondary rounded-2" type="object" invisible="not can_send_whatsapp or warning_message"/>
                <button string="Send by WhatsApp" class="btn btn-secondary rounded-2 disabled" invisible="not can_send_whatsapp or not warning_message"/>
            </xpath>