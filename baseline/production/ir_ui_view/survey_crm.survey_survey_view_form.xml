<data><xpath expr="//button[@name='action_survey_user_input_completed']" position="after">
                <button name="action_survey_see_leads" groups="sales_team.group_sale_salesman" type="object" class="oe_stat_button" invisible="not (survey_type in ['survey', 'live_session', 'custom'] and lead_count != 0)" icon="fa-star">
                    <field string="Leads" name="lead_count" widget="statinfo"/>
                </button>
            </xpath>

            <xpath expr="//field[@name='restrict_user_ids']" position="after">
                <field name="team_id" placeholder="Select a Sales team" invisible="not generate_lead"/>
            </xpath>

            <xpath expr="//list//field[@name='title']" position="after">
                <button type="button" icon="fa-star" title="This question generates leads" invisible="not (survey_type in ['survey', 'live_session', 'custom'] and generate_lead)"/>
            </xpath>
        </data>