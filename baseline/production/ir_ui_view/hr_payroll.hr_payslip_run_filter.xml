<search string="Search Pay Run">
                <field name="name" string="Pay Run"/>
                <filter string="Ready" name="ready" domain="[('state', '=', '01_ready')]" help="Ready Pay Runs"/>
                <filter string="Done" name="done_filter" domain="[('state', '=', '02_close')]" help="Done Pay Runs"/>
                <filter string="Paid" name="paid" domain="[('state', '=', '03_paid')]" help="Paid Pay Runs"/>
                <separator/>
                <filter string="Date" name="date_filter" date="date_start"/>
                <separator/>
                <filter string="Archived" name="filter_archived" domain="[('active', '=', 'False')]"/>
                <group>
                    <filter string="Status" name="groupby_state" context="{'group_by': 'state'}"/>
                </group>
            </search>