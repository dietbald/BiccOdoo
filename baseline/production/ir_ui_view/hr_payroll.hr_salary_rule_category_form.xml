<form string="Salary Categories">
            <sheet>
                <group name="category_details" col="4">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="parent_id"/>
                    <field name="country_id" options="{'no_create': True, 'no_open': True}"/>
                </group>
                <group name="notes" string="Notes" col="2">
                    <field name="note" nolabel="1"/>
                </group>
            </sheet>
            </form>