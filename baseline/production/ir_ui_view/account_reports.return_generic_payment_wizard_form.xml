<form string="Pay">
                <h2>
                    <group>
                        <field name="currency_id" invisible="1"/>
                        <field name="amount_to_pay" readonly="1"/>
                    </group>
                </h2>
                <footer>
                    <button name="action_mark_as_paid" string="Mark Paid" type="object" class="btn-primary" data-hotkey="q"/>
                    <button name="action_send_email_instructions" string="Send" type="object" class="btn-secondary" data-hotkey="s"/>
                    <button string="Discard" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
           </form>