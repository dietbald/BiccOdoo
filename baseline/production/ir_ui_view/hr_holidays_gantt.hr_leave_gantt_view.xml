<gantt js_class="hr_holidays_gantt_manager_hr_leave" date_start="date_from" date_stop="date_to" string="Days" color="color" default_group_by="employee_id" decoration-danger="state == 'refuse'" decoration-info="state in ['confirm', 'validate1']" decoration-secondary="state == 'cancel'" precision="{'week': 'day:half', 'month': 'day:half'}" plan="0" total_row="True" display_unavailability="1">
                    <field name="state" invisible="1"/>
                    <field name="holiday_status_id" invisible="1"/>
                    <field name="number_of_days" invisible="1"/>
                    <field name="can_approve" invisible="1"/>
                    <field name="can_validate" invisible="1"/>
                    <field name="can_refuse" invisible="1"/>
                    <templates>
                        <div t-name="gantt-popover">
                        <t t-set="start_date_formatted" t-value="date_from.toLocaleString({ month: 'numeric', day: 'numeric', year: 'numeric' })"/>
                        <t t-set="stop_date_formatted" t-value="date_to.toLocaleString({ month: 'numeric', day: 'numeric', year: 'numeric' })"/>
                            <div>
                                <strong>Name: </strong><t t-out="holiday_status_id[1]"/>
                            </div>
                            <div><strong>Start: </strong> <t t-out="start_date_formatted"/></div>
                            <div><strong>Stop: </strong> <t t-out="stop_date_formatted"/></div>
                            <footer>
                                <button name="action_approve" class="btn btn-primary btn-sm" string="Approve" type="object" t-if="can_approve"/>
                                <button name="action_approve" class="btn btn-secondary btn-sm" string="Validate" type="object" t-if="can_validate and !can_approve"/>
                                <button name="action_refuse" class="btn btn-secondary btn-sm" string="Refuse" type="object" t-if="can_refuse"/>
                            </footer>
                        </div>
                    </templates>
                </gantt>