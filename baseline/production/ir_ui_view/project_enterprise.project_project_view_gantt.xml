<gantt date_start="date_start" date_stop="date" default_scale="month" scales="week,month,quarter,year" string="Planning" display_unavailability="1" js_class="project_gantt" precision="{'week': 'day:full', 'month': 'day:full'}" default_group_by="user_id" total_row="True" kanban_view_id="1234" color="stage_id_color">
                <templates>
                    <div t-name="gantt-popover">
                        <footer replace="0">
                            <button name="action_view_tasks" type="object" string="View Tasks" class="btn btn-sm btn-secondary"/>
                        </footer>
                    </div>
                </templates>
                <field name="user_id"/>
                <field name="partner_id"/>
                <field name="stage_id_color" invisible="1"/>
            </gantt>