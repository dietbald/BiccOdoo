<t name="Left Logo" t-name="mass_mailing.s_mail_block_header_social">
    <section class="s_header_social o_mail_block_header_social o_mail_snippet_general pt16 pb16" data-name="Left Logo" data-vxml="001">
        <div class="container">
            <div class="row">
                <div class="col-md-4 pt16 pb16">
                    <div class="o_not_editable">
                        <a t-att-href="(company_id.website) or '#'" style="text-decoration:none;float:none;" target="_blank">
                            <img t-if="company_id.logo or user_id.company_id.logo" class="o_b64_image_to_save o_editable_media" t-att-src="image_data_uri(company_id.logo if company_id.logo else user_id.company_id.logo)" style="height:auto;max-width:100%;"/>
                        </a>
                    </div>
                </div>
                <div class="col-md-8 o_mail_header_social" style="text-align: right;">
                    <t t-call="mass_mailing.social_links"/>
                </div>
            </div>
        </div>
    </section>
</t>