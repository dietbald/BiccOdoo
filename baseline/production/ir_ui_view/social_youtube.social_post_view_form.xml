<data><xpath expr="//div[hasclass('o_social_post_empty_preview')]" position="inside">
                <field name="youtube_accounts_other_count" invisible="1"/>
            </xpath>
            <!-- Either there are accounts other than youtube and the message is not empty or there are images either there is a youtube account and youtube title is not empty, or we have a video -->
            <xpath expr="//div[hasclass('o_social_post_empty_preview')]" position="attributes">
                <attribute name="invisible">state in ['posting', 'posted'] or youtube_accounts_other_count != 0 and message and message != '' or image_ids or youtube_accounts_count != 0 and youtube_title and youtube_title != '' or youtube_video_id</attribute>
            </xpath>
            <xpath expr="//div[hasclass('o_social_post_preview_container')]" position="attributes">
                <attribute name="invisible">not (state in ['posting', 'posted'] or youtube_accounts_other_count != 0 and message and message != '' or image_ids or youtube_accounts_count != 0 and youtube_title and youtube_title != '' or youtube_video_id)</attribute>
            </xpath>
            <xpath expr="//field[@name='message']" position="attributes">
                <!-- If we only post on YouTube or we are splitting the post, hide the 'message' field as it is not used -->
                <attribute name="invisible">state in ['posting', 'posted'] or youtube_accounts_other_count == 0 and youtube_accounts_count != 0 or is_split_per_media</attribute>
                <attribute name="readonly">not has_active_accounts or state in ['posting', 'posted']</attribute>
            </xpath>
            <xpath expr="//field[@name='image_ids']" position="attributes">
                <!-- If we only post on YouTube or we are splitting the post, hide the 'image_ids' field as it is not used -->
                <attribute name="invisible">state in ['posting', 'posted'] or youtube_accounts_other_count == 0 and youtube_accounts_count != 0 or is_split_per_media</attribute>
                <attribute name="readonly">state in ['posting', 'posted']</attribute>
            </xpath>
            <xpath expr="//header" position="after">
                <div class="alert alert-danger text-center" role="alert" invisible="youtube_accounts_count &lt;= 1">
                    Please select a single YouTube account at a time.
                </div>
            </xpath>
            <xpath expr="//group[@name='social_post_global']" position="inside">
                <field name="youtube_accounts_count" invisible="1"/>
                <div name="notification_request_parameters" colspan="2" class="o_horizontal_separator mt-5" invisible="state in ['posting', 'posted'] or youtube_accounts_count == 0 or is_split_per_media">
                    YouTube Options
                </div>
                <field name="youtube_video_id" invisible="1"/>
                <field name="youtube_access_token" invisible="1"/>
                <field name="youtube_title" string="Video Title" onchange_on_keydown="True" placeholder="e.g. Odoo Social Tutorial" invisible="state in ['posting', 'posted'] or youtube_accounts_count != 1 or is_split_per_media" readonly="state != 'draft'" required="youtube_accounts_count != 0"/>
                <field name="youtube_description" string="Video Description" onchange_on_keydown="True" widget="text_emojis" placeholder="e.g. Engage your entire community with a single app! https://www.odoo.com/trial" invisible="state in ['posting', 'posted'] or youtube_accounts_count != 1 or is_split_per_media" readonly="state != 'draft'" required="youtube_video_id"/>
                <field name="youtube_video_privacy" invisible="state in ['posting', 'posted'] or youtube_accounts_count != 1 or is_split_per_media" required="youtube_accounts_count == 1" readonly="state != 'draft'"/>
                <field name="youtube_video" widget="youtube_upload" invisible="state in ['posting', 'posted'] or youtube_accounts_count != 1 or is_split_per_media" readonly="state != 'draft'"/>
            </xpath>
            <xpath expr="//div[hasclass('o_social_post_preview_container')]" position="inside">
                <field name="youtube_preview" nolabel="1" colspan="2" widget="social_post_preview" readonly="1" invisible="youtube_accounts_count != 1 or ((not youtube_title or youtube_title == '') and not youtube_video_id)" class="o_social_preview_wrapper m-0 px-4 py-4 bg-200"/>
            </xpath>
            <xpath expr="//notebook[@name='media_customization']" position="inside">
                <page string="YouTube" name="youtube_content" invisible="youtube_accounts_count == 0 or state in ['posting', 'posted']">
                    <group>
                        <group>
                            <field name="youtube_title" string="Video Title" onchange_on_keydown="True" placeholder="e.g. Odoo Social Tutorial" invisible="youtube_accounts_count != 1" readonly="state != 'draft'" required="is_split_per_media and youtube_accounts_count != 0"/>
                            <field name="youtube_description" string="Video Description" onchange_on_keydown="True" widget="text_emojis" placeholder="e.g. Engage your entire community with a single app! https://www.odoo.com/trial" invisible="youtube_accounts_count != 1" readonly="state != 'draft'" required="is_split_per_media and youtube_video_id"/>
                            <field name="youtube_video_privacy" invisible="youtube_accounts_count != 1" readonly="state != 'draft'" required="youtube_accounts_count == 1"/>
                            <field name="youtube_video" widget="youtube_upload" invisible="youtube_accounts_count != 1" readonly="state != 'draft'"/>
                        </group>
                        <group invisible="youtube_accounts_count != 1 or ((not youtube_title or youtube_title == '') and not youtube_video_id)">
                            <field name="youtube_preview" nolabel="1" widget="social_post_preview" readonly="1" class="o_social_preview_wrapper m-0 px-4 py-4 bg-200"/>
                        </group>
                    </group>
                </page>
            </xpath>
            <xpath expr="//group[@name='live_posts']//div[hasclass('o_live_post_content')]" position="inside">
                <field name="youtube_title" invisible="media_type != 'youtube'" class="fw-bold"/>
                <field name="youtube_description" invisible="media_type != 'youtube'"/>
                <field name="youtube_video_privacy" invisible="media_type != 'youtube'"/>
            </xpath>
        </data>