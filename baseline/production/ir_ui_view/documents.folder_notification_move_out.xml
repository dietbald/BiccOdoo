<t t-name="documents.folder_notification_move_out">
            <p t-if="len(documents) == 1">
                <span t-out="documents[0].display_name"/> was been moved outside this folder.
            </p>
            <t t-else="">
                <p>The following documents were moved outside this folder:</p>
                <ul>
                    <li t-foreach="documents" t-as="document">
                        <span t-out="document.display_name"/>
                    </li>
                </ul>
            </t>
        </t>