<group name="general" position="after">
                    <group string="Invoice Follow-ups" name="invoice_followups" groups="account.group_account_invoice">
                        <field name="company_id" invisible="1"/>
                        <div colspan="2" invisible="not followup_line_id">
                            <field name="followup_line_id" widget="statusbar" invisible="not unreconciled_aml_ids" options="{'clickable': '1'}" domain="[('company_id','=', current_company_id)]"/>
                        </div>
                        <label for="followup_status"/>
                        <div class="d-flex">
                            <field name="followup_status" widget="badge" decoration-danger="followup_status == 'in_need_of_action'" decoration-warning="followup_status == 'with_overdue_invoices'" class="w-50"/>
                            <a name="action_open_partner_followup_journal_items" invisible="followup_status not in ('in_need_of_action', 'with_overdue_invoices')" class="fw-bold w-50" type="object">
                                Journal Items
                            </a>
                        </div>
                        <label for="followup_reminder_type"/>
                        <div class="d-flex">
                            <field name="followup_reminder_type" widget="radio" class="w-50" options="{'horizontal': true}"/>
                            <a name="342" type="action" class="fw-bold w-50">
                                Send
                            </a>
                        </div>
                        <field name="followup_next_action_date"/>
                        <field name="followup_responsible_id"/>
                    </group>
                </group>