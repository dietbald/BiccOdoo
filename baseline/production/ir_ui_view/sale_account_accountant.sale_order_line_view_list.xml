<list string="Sales Order Lines" create="false" js_class="accrual_list_view">
                <header>
                    <button string="Create Accrual Entries" groups="account.group_account_user" name="1704" type="action" class="btn btn-primary" data-hotkey="r"/>
                </header>
                <field name="currency_id" column_invisible="True"/> <!-- Needed for monetary widget -->
                <field name="order_id"/>
                <field name="order_partner_id"/>
                <field name="name" optional="show"/>
                <field name="salesman_id" optional="show"/>
                <field name="product_uom_qty"/>
                <field name="qty_delivered_at_date"/>
                <field name="qty_invoiced_at_date"/>
                <field name="product_uom_id" groups="uom.group_uom" widget="many2one_uom"/>
                <field name="price_unit" widget="monetary"/>
                <field name="amount_to_invoice_at_date" widget="monetary"/>
            </list>