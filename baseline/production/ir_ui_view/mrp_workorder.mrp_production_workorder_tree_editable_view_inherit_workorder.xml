<data><xpath expr="//field[@name='state']" position="after">
                <field name="production_state" column_invisible="True"/>
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                    <field name="allowed_employees" column_invisible="True"/>
                    <field name="all_employees_allowed" column_invisible="True"/>
                    <field name="employee_assigned_ids" widget="many2many_avatar_employee" domain="not all_employees_allowed and [('id','in',allowed_employees)] or []" optional="hidden"/>
            </xpath>
        </data>