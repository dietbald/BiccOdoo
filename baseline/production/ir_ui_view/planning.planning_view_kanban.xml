<kanban highlight_color="color" group_create="false" sample="1" js_class="planning_kanban">
                <field name="employee_id"/>
                <field name="resource_type"/>
                <field name="resource_color"/>
                <field name="repeat" invisible="1"/>
                <templates>
                    <t t-name="menu" groups="planning.group_planning_manager">
                        <t t-if="widget.editable"><a role="menuitem" type="open" class="dropdown-item">Edit</a></t>
                        <t t-if="widget.deletable"><a role="menuitem" type="delete" class="dropdown-item">Delete</a></t>
                    </t>
                    <t t-name="AllocatedTimeSpan">
                    </t>
                    <t t-name="card">
                        <div name="card_top">
                            <span class="d-inline-flex fw-bold ps-1">
                                <i class="me-1 mt-1 fa fa-clock-o" role="img" aria-label="Date" title="Date"/>
                                <field class="me-1" name="start_datetime" widget="daterange" options="{'end_date_field': 'end_datetime'}"/>
                                <t t-if="record.start_datetime.raw_value and record.end_datetime.raw_value"> (<field name="allocated_hours" widget="float_time"/>)</t>
                                <t t-else="">
                                    <field name="allocated_hours" widget="float_time"/>
                                </t>
                                <t t-if="record.resource_type.raw_value == 'user'"> (<field name="allocated_percentage" digits="[0,0]"/>%)</t>
                            </span>
                        </div>
                        <div>
                            <t t-if="record.resource_type.raw_value == 'user'">
                                <span name="role"><field name="role_id"/></span>
                            </t>
                            <t t-elif="record.resource_type.raw_value == 'material'">
                                <span name="resource"><field name="resource_id"/></span>
                            </t>
                            <t t-else="" name="role">
                                <span name="role"><field name="role_id"/></span>
                            </t>
                        </div>
                        <field name="slot_properties" widget="properties"/>
                        <footer class="pt-0">
                            <div class="d-flex ms-auto align-items-center">
                                <field name="state" widget="label_selection" options="{'classes': {'draft': 'default', 'published': 'success'}}" groups="planning.group_planning_manager" class="me-1"/>
                                <field name="resource_id" widget="many2one_avatar_resource"/>
                            </div>
                        </footer>
                    </t>
                </templates>
            </kanban>