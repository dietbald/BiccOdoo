<xpath expr="//div[@name='button_box']" position="inside">
                <button name="open_employee_sign_requests" class="oe_stat_button" icon="fa-pencil" type="object" invisible="not is_user or sign_request_count == 0" groups="sign.group_sign_user">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value"><field name="sign_request_count"/></span>
                            <span class="o_stat_text">Signature Requests</span>
                    </div>
                </button>
            </xpath>