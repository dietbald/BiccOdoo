<data>
  <xpath expr="/form//button[@name='action_talent_pool_add_applicants']" position="after">
    <button string="Req Info" name="1475" type="action" invisible="stage_id != 2"/>
    <button string="n8n" name="1477" type="action" invisible="stage_id not in [1]"/>
    <button string="Remind" type="action" invisible="stage_id not in [7]" name="1780"/>
  </xpath>
  <xpath expr="/form//button[@name='action_generate_offer']" position="attributes">
    <attribute name="invisible">stage_id not in [5, 9] or user_email != "xxx"</attribute>
  </xpath>
  <xpath expr="/form//button[@name='action_send_survey']" position="attributes">
    <attribute name="invisible">True</attribute>
  </xpath>
  <xpath expr="/form//field[@name='linkedin_profile']" position="after">
    <field name="x_studio_ai_rating"/>
    <field name="x_studio_alternative_position_recommendation"/>
  </xpath>
  <xpath expr="/form//field[@name='partner_id']" position="attributes">
    <attribute name="invisible">False</attribute>
  </xpath>
  <xpath expr="/form//field[@name='response_ids']" position="after">
    <group name="studio_group_950528">
      <field name="x_studio_emotional_quiz_score"/>
      <field name="x_studio_tech_quiz_score"/>
      <field name="x_studio_logical_quiz_score"/>
    </group>
  </xpath>
  <xpath expr="/form/sheet/notebook/page[3]" position="after">
    <page string="Driver Info" name="studio_page_19f_1htqmvr1i">
      <group name="studio_group_19f">
        <group name="studio_group_19f_left">
          <field name="x_studio_years_of_experience_driving"/>
          <field name="x_studio_date_of_birth"/>
          <field name="x_studio_complete_address"/>
          <field name="x_studio_apply_for"/>
        </group>
        <group name="studio_group_19f_right">
          <field name="x_studio_license_code" widget="many2many_checkboxes"/>
        </group>
      </group>
    </page>
    <page string="Assessments" name="assessments">
      <field name="x_assessment_ids">
        <list string="Survey User inputs" decoration-muted="test_entry == True" create="false">
          <field name="create_date"/>
          <field name="survey_id"/>
          <field name="applicant_id" optional="show"/>
          <field name="nickname" optional="hide"/>
          <field name="email" optional="show"/>
          <field name="attempts_number"/>
          <field optional="show" name="x_studio_completion_time"/>
          <field name="end_datetime" optional="show" string="Completed on"/>
          <field name="deadline"/>
          <field name="test_entry" column_invisible="True"/>
          <field name="scoring_success"/>
          <field name="scoring_percentage"/>
          <field name="state" widget="badge" decoration-success="state == 'done'" decoration-info="state == 'new'" decoration-warning="state == 'in_progress'"/>
        </list>
      </field>
    </page>
    <page string="Recruitment" name="studio_page_2rg_1jc8s14af">
      <group name="studio_group_2rg">
        <group name="studio_group_2rg_left" string="Application Information">
          <field name="x_studio_reminder_sent" force_save="1" readonly="True" string="First Reminder Sent"/>
          <field name="x_studio_sms_reminder_sent"/>
          <field name="x_studio_final_reminder_sent" force_save="1" readonly="True"/>
        </group>
        <group name="studio_group_2rg_right" string="Assessment Information">
          </group>
      </group>
    </page>
  </xpath>
  <xpath expr="/form//field[@name='availability']" position="after">
    <field name="x_studio_can_start"/>
  </xpath>
  <xpath expr="/form//field[@name='type_id']" position="attributes">
    <attribute name="options">{"no_create":true}</attribute>
  </xpath>
  <xpath expr="/form//field[@name='department_id']" position="attributes">
    <attribute name="options">{"no_create":true}</attribute>
  </xpath>
  <xpath expr="/form/sheet/notebook/page[@name='application_details']/group[2]/group[@name='recruitment_contract']/div" position="after">
    <field name="x_studio_on_time_incentive"/>
    <field name="x_studio_daily_"/>
    <field name="x_studio_proposed_start_date"/>
  </xpath>
  <xpath expr="/form/sheet/notebook/page[@name='application_details']/group[2]/group[@name='recruitment_contract']/div[2]" position="after">
    <field name="x_studio_salary_details" string="Additional Salary Details"/>
    <field name="x_studio_project_duration_months" invisible="False"/>
  </xpath>
</data>