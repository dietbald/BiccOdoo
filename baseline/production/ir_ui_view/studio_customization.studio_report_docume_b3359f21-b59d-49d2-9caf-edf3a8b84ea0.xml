                    </tr>
                    <tr>
                        <th>ABC:</th>
                        <td><span t-field="doc.expected_revenue"/></td>
                    </tr>
                </tbody>
            </table>
            
            
                        <!-- Closing -->
            <p>Sincerely,</p>

            <p><strong>Cyril Hanson Cembrano</strong><br/>
            Authorized Managing Officer<br/>
            <strong><span t-field="doc.company_id.name"/></strong><br/>
            <span t-field="doc.company_id.street"/> <span t-field="doc.company_id.city"/>, 
