                          <div class="page">
                            
                            <div class="oe_structure"/>
                        
                                    <!-- Letter Header -->
            <h2 class="text-center">LETTER OF INTENT</h2>
            <p>Good day!</p>
            <p>
                I, <strong>Cyril Hanson Cembrano</strong>, Authorized Managing Officer of 
                <strong><span t-field="doc.company_id.name"/></strong>, located in 
