<search>
                <field name="name"/>
                <field name="root_article_id"/>
                <field name="body"/>
                <field name="last_edition_uid"/>
                <field name="article_properties"/>
                <field name="stage_id"/>

                <filter name="filter_my_items" string="My Items" domain="[('create_uid', '=', uid)]"/>
                <filter name="filter_favorites" string="My Favorites" domain="[('is_user_favorite', '=', True)]"/>
                <separator/>
                <filter name="filter_active" string="Archived" domain="[('active', '=', False)]"/>
                <group>
                    <filter name="group_by_stage" string="Stage" domain="[]" context="{'group_by': 'stage_id'}"/>
                    <separator/>
                    <filter name="group_by_article_properties" domain="[]" context="{'group_by': 'article_properties'}"/>
                </group>
            </search>