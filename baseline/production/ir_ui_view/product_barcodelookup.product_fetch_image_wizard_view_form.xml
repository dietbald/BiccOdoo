<form>
                <sheet>
                    <p>
                        Out of <field name="nb_products_selected"/> selected products,
                        <field name="nb_products_to_process"/> will be processed.
                        <span invisible="nb_products_unable_to_process == 0">
                            <field name="nb_products_unable_to_process"/> won't be
                            processed because they either already have an image or
                            lack a barcode
                        </span>
                        <span invisible="nb_products_selected &lt;= 1000">
                            As only 1000 products can be processed per day, the remaining will be
                            done tomorrow.
                        </span>
                    </p>
                    <p invisible="nb_products_to_process == 0">
                        <strong>Note: </strong>
                        Some images may not be royalty-free and should not be published online.
                    </p>
                    <footer>
                        <button name="action_fetch_image" type="object" string="Get Pictures" class="oe_highlight" invisible="nb_products_to_process == 0"/>
                        <button special="cancel" string="Cancel" invisible="nb_products_to_process == 0"/>
                        <button special="cancel" string="Cancel" class="oe_highlight" invisible="nb_products_to_process != 0"/>
                    </footer>
                </sheet>
            </form>