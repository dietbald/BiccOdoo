<t name="Message: Alert on purchase orders when sales orders are cancelled" t-name="sale_purchase.exception_purchase_on_sale_cancellation">
    <div>
        <p>
            Exception(s) occurred on the sale order(s):
            <t t-foreach="sale_orders" t-as="sale_order">
                <a href="#" data-oe-model="sale.order" t-att-data-oe-id="sale_order.id"><t t-esc="sale_order.name"/></a>
            </t>.
            Manual actions may be needed.
        </p>
        <div class="mt16">
            <p>Exception(s):</p>
            <ul t-foreach="sale_order_lines" t-as="sale_line">
                <li>
                    <a href="#" data-oe-model="sale.order" t-att-data-oe-id="sale_line.order_id.id"><t t-esc="sale_line.order_id.name"/></a>: <t t-esc="sale_line.product_uom_qty"/> <t t-esc="sale_line.product_uom_id.name"/> of <t t-esc="sale_line.product_id.name"/> cancelled
                </li>
            </ul>
        </div>
    </div>
</t>