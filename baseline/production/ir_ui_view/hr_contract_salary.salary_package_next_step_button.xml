<t t-name="hr_contract_salary.salary_package_next_step_button">
        <t t-if="redirect_to_job">
            <div class="container">
                <div class="row">
                    <div class="col-lg-3 mb8">
                        <a t-att-href="'https://www.odoo.com/jobs/' + redirect_to_job" target="_new"><button type="button" id="apply_now" class="hr_cs_btn_submit btn btn-primary">Apply Now</button></a>
                    </div>
                </div>
            </div>
        </t>
        <t t-if="submit">
            <div class="container">
                <div class="row">
                    <div class="col-lg-3">
                        <button type="button" id="hr_cs_submit" class="hr_cs_btn_submit btn btn-primary" name="submit2">Review Contract &amp; Sign</button>
                    </div>
                </div>
            </div>
        </t>
    </t>