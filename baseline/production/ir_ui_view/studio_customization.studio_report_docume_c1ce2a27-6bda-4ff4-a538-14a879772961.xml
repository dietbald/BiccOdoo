<t t-name="custom_interview_evaluation_report">
    <t t-call="web.external_layout">
        <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)"/>
        <div class="page">
            <div class="oe_structure"/>
            <!-- Candidate Details -->
            <div class="row mt-4">
                <div class="col-6">
                    <strong>Name:</strong>
                    <span t-field="doc.partner_name"/>
                </div>
                <div class="col-6">
                    <strong>Position Applied For:</strong>
                    <span t-field="doc.job_id"/>
                </div>
                <div class="col-6 mt-2">
                    <strong>Department/Section:</strong>
                    <span t-field="doc.department_id"/>
                </div>
                <div class="col-6 mt-2">
                    <strong>Recruiter:</strong>
                    <span t-field="doc.user_id"/>
                </div>
            </div>
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Testing</th>
                        <th>Logical</th>
                        <th>Emotional</th>
                        <th>Technical</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Score</td>
                        <td>______</td>
                        <td>______</td>
                        <td>______</td>
                    </tr>
                </tbody>
            </table>
            <!-- Rating Section -->
            <span class="mt-4">Please rate the applicant by encircling the rating:</span>
            <table class="table" style="border: none; border-collapse: collapse; width: 100%;">
                <tbody>
                    <tr>
                        <td style="width: 20%; border: none;">1 – Poor	</td>
                        <td style="width: 20%; border: none;">2 – Below Average	</td>
                        <td style="width: 20%; border: none;">3 – Average	</td>
                        <td style="width: 20%; border: none;">4 – Above Average	</td>
                        <td style="width: 20%; border: none;">5 – Excellent	</td>
                    </tr>
                </tbody>
            </table>
            <table class="table" style="border-collapse: collapse; width: 100%;">
                <tbody>
                    <tr>
                        <td style="width: 40%;">Personality</td>
                        <td style="text-align: center;">1</td>
                        <td style="text-align: center;">2</td>
                        <td style="text-align: center;">3</td>
                        <td style="text-align: center;">4</td>
                        <td style="text-align: center;">5</td>
                    </tr>
                    <tr>
                        <td>Communication skills</td>
                        <td style="text-align: center;">1</td>
                        <td style="text-align: center;">2</td>
                        <td style="text-align: center;">3</td>
                        <td style="text-align: center;">4</td>
                        <td style="text-align: center;">5</td>
                    </tr>
                    <tr>
                        <td>Ability to answer questions</td>
                        <td style="text-align: center;">1</td>
                        <td style="text-align: center;">2</td>
                        <td style="text-align: center;">3</td>
                        <td style="text-align: center;">4</td>
                        <td style="text-align: center;">5</td>
                    </tr>
                    <tr>
                        <td>Attitude towards employment</td>
                        <td style="text-align: center;">1</td>
                        <td style="text-align: center;">2</td>
                        <td style="text-align: center;">3</td>
                        <td style="text-align: center;">4</td>
                        <td style="text-align: center;">5</td>
                    </tr>
                    <tr>
                        <td>Skill and Competence</td>
                        <td style="text-align: center;">1</td>
                        <td style="text-align: center;">2</td>
                        <td style="text-align: center;">3</td>
                        <td style="text-align: center;">4</td>
                        <td style="text-align: center;">5</td>
                    </tr>
                    <tr>
                        <td>Objectivity and Critical thinking</td>
                        <td style="text-align: center;">1</td>
                        <td style="text-align: center;">2</td>
                        <td style="text-align: center;">3</td>
                        <td style="text-align: center;">4</td>
                        <td style="text-align: center;">5</td>
                    </tr>
                    <tr>
                        <td>Leadership</td>
                        <td style="text-align: center;">1</td>
                        <td style="text-align: center;">2</td>
                        <td style="text-align: center;">3</td>
                        <td style="text-align: center;">4</td>
                        <td style="text-align: center;">5</td>
                    </tr>
                    <tr>
                        <td>Job Knowledge</td>
                        <td style="text-align: center;">1</td>
                        <td style="text-align: center;">2</td>
                        <td style="text-align: center;">3</td>
                        <td style="text-align: center;">4</td>
                        <td style="text-align: center;">5</td>
                    </tr>
                </tbody>
            </table>
            <!-- Additional Remarks -->
            <h3 class="mt-4">Additional Remarks:</h3>
            <p class="mt-4">_____________________________________</p>
            <!-- Interview Details -->
            <h3 class="mt-4">Interview Details</h3>
            <div class="row">
                <div class="col-6">
                    <strong>Interviewer:</strong> _________________________
                
                
                
                </div>
                <div class="col-6">
                    <strong>Date:</strong> _________________________
                
                
                
                </div>
                <div class="col-6 mt-2">
                    <strong>Recommendation:</strong> _________________________
                
                
                
                </div>
            </div>
            <div class="oe_structure"/></div>
    </t>
</t>