<data><xpath expr="//header" position="inside">
                <!--
                    hr.group_hr_manager implies sign.group_sign_manager
                    https://github.com/odoo/enterprise/blob/435fa269064d358c8b78a957b8201dc6b6aeb6af/hr_contract_sign/security/security.xml#L4
                 -->
                <button name="663" string="Signature Request" type="action" invisible="not id" groups="hr.group_hr_manager" context="{'default_version_id': version_id}"/>
            </xpath>
            <button name="action_open_versions" position="before">
                <button groups="hr.group_hr_manager" name="open_employee_sign_requests" type="object" class="oe_stat_button" icon="fa-pencil" invisible="sign_request_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value"><field name="sign_request_count"/></span>
                        <span class="o_stat_text">Signature Requests</span>
                    </div>
                </button>
            </button>
            <xpath expr="//field[@name='hr_responsible_id']" position="after">
                <field name="sign_request_ids" invisible="1" groups="sign.group_sign_user"/>
            </xpath>
        </data>