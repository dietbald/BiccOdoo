<xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button class="oe_stat_button" name="action_view_equipments_records" type="object" icon="fa-wrench" invisible="equipment_count == 0">
                    <div class="o_stat_info">
                        <span class="o_stat_value">
                            <field name="equipment_count"/>
                        </span>
                        <span class="o_stat_text">
                            Equipments
                        </span>
                    </div>
                </button>
            </xpath>