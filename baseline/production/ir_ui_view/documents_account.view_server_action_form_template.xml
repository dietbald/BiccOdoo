<xpath expr="//t[@name='action_content']//notebook" position="before">
                    <group invisible="state != 'documents_account_record_create'">
                        <group>
                            <field name="documents_account_create_model" string="Create" placeholder="Choose an accounting document type..." required="state == 'documents_account_record_create'"/>
                            <field name="documents_account_journal_id" string="Journal" placeholder="Choose a journal..."/>
                        </group>
                    </group>
                </xpath>