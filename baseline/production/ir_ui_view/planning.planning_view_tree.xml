<list string="Shift List" multi_edit="1" sample="1" editable="bottom" js_class="planning_tree" open_form_view="True">
                <header>
                    <button name="action_planning_publish_and_send" class="btn btn-secondary mx-1" string="Publish &amp; Send" type="object" groups="planning.group_planning_manager" invisible="context.get('my_planning_action')"/>
                </header>
                <field name="resource_color" column_invisible="1"/>
                <field name="start_datetime" string="Planned Date" widget="planned_date_range_with_allocated_hours" options="{'end_date_field': 'end_datetime'}" width="425px"/>
                <field name="end_datetime" column_invisible="True"/>
                <field name="allocated_percentage" avg="Allocated Percentage" optional="hide" decoration-danger="allocated_percentage &gt; 100" readonly="1" invisible="resource_type == 'material'"/>
                <field name="resource_id" widget="many2one_avatar_resource" optional="show" readonly="not start_datetime or not end_datetime" placeholder="Open Shift" context="{'from_planning': True, 'search_view_ref': 'planning.resource_resource_search_view_roles',                             'search_default_role_ids': role_id,                             'form_view_ref': 'planning.resource_resource_with_employee_form_view_inherit',                             'list_view_ref': 'planning.resource_resource_tree_view_inherit'}"/>
                <field name="resource_type" column_invisible="True"/>
                <field name="role_id" optional="show" context="{'search_default_resource_ids': resource_id}" placeholder="e.g. Bartender"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide" readonly="1"/>
                <field name="company_id" column_invisible="True"/>
                <field name="name" optional="hide"/>
                <field name="state" decoration-success="state == 'published'" widget="badge" optional="hide" groups="planning.group_planning_manager" readonly="1"/>
                <field name="recurrency_id" column_invisible="True"/>
                <field name="is_users_role" column_invisible="1"/>
                <field name="allow_self_unassign" column_invisible="1"/>
                <field name="is_past" column_invisible="1"/>
                <field name="is_unassign_deadline_passed" column_invisible="1"/>
                <field name="resource_id" column_invisible="1"/>
                <field name="request_to_switch" column_invisible="1"/>
                <field name="user_id" column_invisible="1"/>
                <button name="action_self_unassign" type="object" title="I Am Unavailable" string="I Am Unavailable" class="btn btn-link float-end" invisible="not context.get('my_planning_action') or user_id != uid or not allow_self_unassign or is_past or is_unassign_deadline_passed or resource_type == 'material'" groups="!planning.group_planning_manager"/>
                <button name="action_self_assign" type="object" title="I Take It" string="I Take It" class="btn btn-link float-end" invisible="not context.get('my_planning_action') or is_past or not start_datetime or not end_datetime or resource_id and not request_to_switch or user_id == uid and (allow_self_unassign or request_to_switch)" groups="!planning.group_planning_manager"/>
                <button name="action_cancel_switch" class="btn btn-link float-end" type="object" string="Cancel Switch" groups="!planning.group_planning_manager" invisible="not context.get('my_planning_action') or not start_datetime or not end_datetime or not request_to_switch or allow_self_unassign or user_id != uid and request_to_switch"/>
                <button name="action_switch_shift" class="btn btn-link  float-end" type="object" string="Ask To Switch" groups="!planning.group_planning_manager" invisible="not context.get('my_planning_action') or user_id != uid or is_past or request_to_switch or allow_self_unassign"/>
            </list>