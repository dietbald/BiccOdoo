<data name="Website Appointment: Your Data" inherit_id="appointment.appointment_form">
        <xpath expr="//input[@type='phone']" position="after">
            <small t-if="isPartnerPhoneQuestion and appointment_type.reminder_ids.filtered(lambda r:r.alarm_type == 'sms')" class="form-text">
                <i class="fa fa-lightbulb-o me-1"/>
                We will use it to remind you of this appointment.
            </small>
        </xpath>
    </data>