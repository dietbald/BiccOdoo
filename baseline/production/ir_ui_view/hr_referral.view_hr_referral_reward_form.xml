<form>
                <field name="active" invisible="1"/>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_get_employee_awarded" class="oe_stat_button" icon="fa-user" type="object" invisible="awarded_employees == 0">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value">
                                    <field name="awarded_employees"/> Employees
                                </span>
                                <span class="o_stat_text">
                                    Awarded
                                </span>
                            </div>
                        </button>
                    </div>

                    <field name="image" widget="image" class="oe_avatar" nolabel="1" readonly="not is_gift_manager"/>
                    <group>
                        <group name="main_details">
                            <field name="name" readonly="not is_gift_manager"/>
                            <label for="cost" string="Cost"/>
                            <div>
                                <field name="cost" nolabel="1" class="w-25" readonly="not is_gift_manager"/>
                                <span class="ml8">Points</span>
                            </div>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}" readonly="not is_gift_manager"/>
                            <field name="gift_manager_id" options="{'no_create': True}" readonly="not is_gift_manager"/>
                        </group>
                        <group name="image"/>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" widget="html" nolabel="1" readonly="not is_gift_manager"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>