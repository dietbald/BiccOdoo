<search string="Search Salary Adjustment">
                <field name="employee_ids"/>
                <field name="description"/>
                <field name="other_input_type_id"/>
                <field name="state"/>
                <filter string="Active" name="active_this_year" domain="[                         '&amp;', ('state', '=', 'open'),                                  ('date_start', '&lt;=', ('today'))                     ]"/>
                <filter string="Refunds" name="search_is_refund" domain="[('is_refund', '=', True)]"/>
                <filter string="One Shots" name="search_one_shot" domain="[('duration_type', '=', 'one')]"/>
                <filter string="Employee" name="employee_id_group" context="{'group_by': 'employee_ids'}"/>
                <filter string="Type" name="other_input_type_id" context="{'group_by': 'other_input_type_id'}"/>
                <filter string="Status" name="state" context="{'group_by': 'state'}"/>
                <filter string="Duration" name="duration_type" context="{'group_by': 'duration_type'}"/>
            </search>