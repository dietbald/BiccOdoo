<t name="Question: text box" t-name="survey.question_char_box">
        <div class="o_survey_comment_container p-0">
            <input t-att-type="'email' if question.validation_email else 'text'" class="form-control o_survey_question_text_box bg-transparent rounded-0 p-0" t-att-name="question.id" t-att-placeholder="question.question_placeholder" t-att-value="answer_lines[0].value_char_box if answer_lines else None" t-att-data-question-type="question.question_type" t-att-data-validation-length-min="question.validation_length_min if question.validation_required else False" t-att-data-validation-length-max="question.validation_length_max if question.validation_required else False"/>
        </div>
    </t>