<form>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Group Name"/>
                            </h1>
                        </div>

                        <group>
                            <group>
                                <field name="report_ids" widget="many2many_tags"/>
                            </group>
                        </group>
                        <field name="rule_ids">
                            <form>
                                <group>
                                    <field name="field_name"/>
                                    <field name="res_model_name" invisible="1"/>
                                    <field name="domain" widget="domain" options="{'model': 'res_model_name'}"/>
                                </group>
                            </form>
                            <list>
                                <field name="field_name"/>
                                <field name="domain"/>
                            </list>
                        </field>
                    </sheet>
                </form>