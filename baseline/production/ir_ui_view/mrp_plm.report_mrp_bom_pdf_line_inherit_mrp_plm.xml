<data inherit_id="mrp.report_mrp_bom_pdf_line">
        <xpath expr="//td[@name='td_mrp_code']" position="after">
            <td t-if="data['has_ecos']">
                <span t-if="l.get('version')" t-esc="l['version']"/>
            </td>
            <td t-if="data['has_ecos']">
                <span t-if="l.get('ecos')" t-esc="l['ecos']"/>
            </td>
        </xpath>
    </data>