<data><xpath expr="//header" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <div name="button_box" position="attributes">
                <attribute name="invisible">1</attribute>
            </div>
            <xpath expr="//field[@name='holiday_status_id']" position="attributes">
                <attribute name="domain">[('overtime_deductible', '=', True), ('requires_allocation', '=', True)]</attribute>
                <attribute name="options">{'no_create': True, 'no_open': True}</attribute>
            </xpath>
            <xpath expr="//sheet" position="after">
                <footer>
                    <button string="Save" special="save" class="btn btn-primary" close="1"/>
                    <button string="Discard" special="cancel" class="btn-secondary" close="1"/>
                </footer>
            </xpath>
        </data>