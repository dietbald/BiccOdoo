<form string="Appointment Type" js_class="appointment_type_form_view">
                <field name="active" invisible="1"/>
                <field name="is_published" invisible="1"/>
                <header>
                    <button name="action_share_invite" string="Share" type="object" class="btn btn-primary" invisible="not active"/>
                    <button name="action_customer_preview" string="Preview" type="object" class="btn btn-secondary" invisible="not active"/>
                </header>
                <div class="o_appointment_cal_sync_alert alert alert-info d-flex flex-wrap gap-2 align-items-center" role="alert" invisible="not connectors_displayed">
                    Synchronize your Calendar to avoid double-booking
                </div>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <field name="image_1920" widget="image" class="oe_avatar"/>
                    <div class="oe_button_box" name="button_box" groups="base.group_user">
                        <button class="oe_stat_button" type="action" name="appointment.appointment_invite_action_stat" icon="fa-link" context="{ 'schedule_based_on': 'users' }" invisible="appointment_invite_count == 0 or schedule_based_on == 'resources'">
                            <field string="Shared Links" name="appointment_invite_count" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" type="action" name="appointment.appointment_invite_action_stat" icon="fa-link" context="{ 'schedule_based_on': 'resources' }" invisible="appointment_invite_count == 0 or schedule_based_on == 'users'">
                            <field string="Shared Links" name="appointment_invite_count" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" type="action" name="appointment.appointment_resource_action_stat" icon="fa-cubes" invisible="schedule_based_on == 'users'">
                            <field string="Resources" name="resource_count" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button" type="object" name="action_calendar_meetings" icon="fa-calendar">
                            <field string="Appointments" name="appointment_count" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title mb-4">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. &quot;Technical Demo&quot;" widget="text" options="{'line_breaks': False}"/></h1>
                    </div>
                    <group>
                        <group name="left_details">
                            <label for="appointment_duration"/>
                            <div invisible="category == 'custom'">
                                <field name="appointment_duration" class="oe_inline me-1 o_input_5ch" widget="float_time"/><span> hours</span>
                            </div>
                            <span class="text-muted" invisible="category != 'custom'">Depending on the Slots</span>
                            <label for="location_id"/>
                            <div>
                                <field name="location_id" context="{'show_address': True, 'default_is_company': True}" placeholder="Online Meeting"/>
                                <button name="add_videocall_source" type="button" class="btn btn-link p-0" invisible="not location_id or event_videocall_source">
                                    <i class="oi oi-plus o_button_icon"/> Add Video
                                </button>
                            </div>
                            <field name="event_videocall_source" placeholder="None" invisible="not event_videocall_source and location_id"/>
                        </group>
                        <group name="right_details">
                            <field name="staff_user_count" invisible="1"/>
                            <field name="resource_count" invisible="1"/>
                            <field name="schedule_based_on" widget="radio" options="{'horizontal': true}" required="1" readonly="category == 'anytime'"/>
                            <!-- Users Details -->
                            <field name="staff_user_ids" widget="many2many_avatar_user" invisible="schedule_based_on == 'resources'" options="{'no_open': False}" placeholder="Select Users..."/>
                            <!-- Resources Details-->
                            <field name="resource_ids" string="Resources" widget="many2many_tags" options="{'no_quick_create': True, 'edit_tags': True}" invisible="schedule_based_on == 'users'" placeholder="Select Resources..."/>
                            <field name="is_auto_assign" invisible="1"/>
                            <field name="is_date_first" invisible="1"/>
                            <field name="assignment_method" widget="radio" options="{'horizontal': true}" invisible="staff_user_count &lt;= 1 and resource_count &lt;= 1"/>
                            <field name="select_first" widget="radio" options="{'horizontal': true}" invisible="is_auto_assign or (staff_user_count &lt;= 1 and resource_count &lt;= 1)"/>
                            <label for="manage_capacity"/>
                            <div class="d-flex">
                                <field name="manage_capacity" class="oe_inline"/>
                                <div invisible="not manage_capacity or schedule_based_on == 'users'">
                                    <span invisible="not resource_total_capacity">
                                        Total: <field name="resource_total_capacity" class="oe_inline o_input_5ch me-1"/> seats max
                                    </span>
                                    <a type="action" invisible="resource_total_capacity &gt; 0" name="appointment.appointment_resource_action_stat" class="btn btn-link btn-sm p-0 oe_inline" role="button">
                                        <i class="oi oi-fw o_button_icon oi-arrow-right"/> Create Resources
                                    </a>
                                </div>
                                <div invisible="not manage_capacity or schedule_based_on == 'resources'">
                                    <field name="user_capacity" class="oe_inline o_appointment_capacity o_input_3ch mx-1"/>
                                    <span>seats max</span>
                                </div>
                                <div invisible="manage_capacity">
                                    Allow <field name="max_bookings" class="oe_inline o_appointment_capacity o_input_3ch mx-1"/> simultaneous appointment(s) 
                                    per <span invisible="schedule_based_on != 'users'">user</span>
                                    <span invisible="schedule_based_on != 'resources'">resource</span>
                                </div>
                            </div>
                        </group>
                    </group>
                    <notebook>
                        <page string="Availabilities" name="slots">
                            <field name="category" invisible="1"/>
                            <field name="slot_ids">
                                <list editable="bottom" class="o_appointment_slots_list">
                                    <field name="weekday" string="Every" column_invisible="parent.category == 'custom'"/>
                                    <field name="start_hour" string="From" widget="float_time" column_invisible="parent.category == 'custom'"/>
                                    <button name="durationArrow" class="fa fa-long-arrow-right text-center text-secondary" title="Until (max)" column_invisible="parent.category == 'custom'"/>
                                    <field name="end_hour" string="To" widget="float_time" column_invisible="parent.category == 'custom'"/>
                                    <field name="start_datetime" string="Slots" widget="daterange" options="{'end_date_field': 'end_datetime', 'always_range': '1'}" column_invisible="parent.category != 'custom'"/>
                                    <field name="allday" column_invisible="parent.category != 'custom'" groups="base.group_no_one"/>
                                    <field name="restrict_to_user_ids" widget="many2many_avatar_user" domain="[('id', 'in', parent.staff_user_ids)]" column_invisible="parent.schedule_based_on != 'users'" options="{'no_create': True}" optional="hide"/>
                                    <field name="restrict_to_resource_ids" widget="many2many_tags_avatar" domain="[('id', 'in', parent.resource_ids)]" column_invisible="parent.schedule_based_on == 'users'" options="{'no_create': True}" optional="hide"/>
                                </list>
                            </field>
                        </page>
                        <page string="Questions" name="questions">
                            <field name="question_ids" domain="[('is_reusable', '=', True)]">
                                <list>
                                    <field name="name"/>
                                    <field name="question_type"/>
                                    <field name="answer_ids" widget="many2many_tags" string="Answers"/>
                                    <field name="question_required" string="Mandatory"/>
                                    <field name="is_default" optional="hide"/>
                                    <field name="is_reusable" optional="hide"/>
                                    <button name="action_view_question_answer_inputs" context="{'search_default_appointment_type_id': parent.id}" type="object" class="fa fa-bar-chart p-0" title="Answer Breakdown"/>
                                </list>
                            </field>
                        </page>
                        <page string="Communication" name="messages">
                            <group>
                                <group>
                                    <separator string="Introduction Page"/>
                                    <field colspan="2" name="message_intro" class="border border-1 rounded" nolabel="1" options="{'height': 120}" placeholder="e.g. &quot;During this meeting, we will...&quot;"/>
                                    <separator string="Confirmation Page"/>
                                    <field colspan="2" name="message_confirmation" class="border border-1 rounded" nolabel="1" options="{'height': 120}" placeholder="e.g. &quot;Thank you for your trust, we look forward to meeting you!&quot;"/>
                                </group>
                                <group string="Emails &amp; SMS">
                                    <field name="reminder_ids" widget="many2many_tags"/>
                                    <field name="booked_mail_template_id" placeholder="If empty, Odoo will not send emails" context="{'default_model': 'calendar.attendee', 'default_subject': name}"/>
                                    <field name="canceled_mail_template_id" placeholder="If empty, Odoo will not send emails" context="{'default_model': 'calendar.event', 'default_subject': name}"/>
                                </group>
                            </group>
                        </page>
                        <page string="Options" name="options">
                            <group>
                                <group name="options_left_details">
                                    <label for="allow_guests"/>
                                    <div class="d-flex">
                                        <field name="allow_guests" class="oe_inline"/>
                                        <div invisible="not allow_guests">
                                            <span>by visitor</span>
                                        </div>
                                    </div>
                                    <label for="auto_confirm"/>
                                    <div class="d-flex">
                                        <field name="auto_confirm" class="oe_inline"/>
                                        <div invisible="not auto_confirm">
                                            <span>
                                                up to
                                                <field name="manual_confirmation_percentage" class="oe_inline o_input_4ch mx-1" widget="percentage"/>
                                                of total capacity
                                            </span>
                                        </div>
                                    </div>
                                    <field name="show_avatars" required="1"/>
                                </group>
                                <group name="options_right_details">
                                    <field name="category_slot_scheduling" class="mb-0" widget="radio" options="{'horizontal': true}" invisible="category == 'anytime'"/>
                                    <label for="category_time_display" string="Allow Bookings"/>
                                    <div>
                                        <div invisible="category == 'custom'">
                                            <field name="category_time_display" class="oe_inline" invisible="category == 'anytime'" required="1"/>
                                            <span invisible="category_time_display != 'recurring_fields'">
                                                <field name="max_schedule_days" class="oe_inline mx-1 o_input_5ch"/> days,
                                            </span>
                                            <field name="start_datetime" widget="daterange" options="{'always_range': True, 'end_date_field': 'end_datetime'}" invisible="category_time_display != 'punctual_fields'" required="category_time_display == 'punctual_fields'"/>
                                            <field name="end_datetime" invisible="1"/>
                                            <div>
                                                at least <field name="min_schedule_hours" class="oe_inline mx-1 o_input_5ch" widget="float_time"/>
                                                hour(s) before start time
                                            </div>
                                        </div>
                                        <div invisible="category != 'custom'">
                                            <div class="text-muted mb-1">
                                                Within availabilities,
                                            </div>
                                            <div>
                                                at least <field name="min_schedule_hours" class="oe_inline mx-1 o_input_5ch" widget="float_time"/>
                                                hour(s) before start time
                                            </div>
                                        </div>
                                    </div>
                                    <label for="slot_creation_interval" invisible="category == 'custom'"/>
                                    <div invisible="category == 'custom'">
                                        <field name="slot_creation_interval" class="oe_inline me-1 o_input_5ch" widget="float_time"/><span>hours</span>
                                    </div>
                                    <label for="min_cancellation_hours" string="Cancellation"/>
                                    <div>
                                        <span>up to<field name="min_cancellation_hours" class="oe_inline mx-1 o_input_5ch" widget="float_time"/>hour(s) before the booking</span>
                                    </div>
                                    <field name="appointment_tz"/>
                                    <field name="country_ids" widget="many2many_tags" groups="base.group_no_one"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>