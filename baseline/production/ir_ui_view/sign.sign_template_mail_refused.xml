<t t-name="sign.sign_template_mail_refused">
<table border="0" cellpadding="0" style="background-color: white; padding: 0px; border-collapse:separate;">
    <tr><td valign="top">
        <p>Hello <t t-out="recipient.name"/>,</p>
        <t t-if="recipient.id == refuser.id">You have refused the document</t>
        <t t-else="">
            <t t-out="refuser.name"/>
            (<a t-att-href="record._get_mail_link(refuser.email, subject)" style="color:#428BCA; text-decoration:none;" target="_blank"><t t-out="refuser.email"/></a>)
            has refused to sign the document <t t-out="record.reference"/> with the following reason
        </t>
    </td></tr>
    <tr t-if="body"><td valign="top">
        <div style="margin: 16px 0px 16px 0px; padding: 8px 16px 8px 16px; background-color: #F1F1F1;">
            <span>
                <t t-out="body"/>
            </span>
        </div>
    </td></tr>
    <tr><td valign="top">
        <div style="margin:16px auto; text-align:center;">
            <a t-att-href="link" t-attf-style="padding: 8px 16px 8px 16px; border-radius: 3px; background-color: {{record.communication_company_id.email_secondary_color or '#875A7B'}}; text-align:center; text-decoration:none; color: {{record.communication_company_id.email_primary_color or '#FFFFFF'}};">
                View document
            </a>
        </div>
    </td></tr>
    <tr><td valign="top">
        <div style="opacity: 0.7;">
            <strong>Warning</strong> do not forward this email to other people!<br/>
        </div>
    </td></tr>
</table>
    </t>