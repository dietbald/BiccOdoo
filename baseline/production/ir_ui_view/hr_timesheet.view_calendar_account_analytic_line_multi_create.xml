<form>
                    <group>
                        <field name="project_id" options="{'no_create_edit': True}" context="{'search_default_my_projects': True}" required="1"/>
                        <field name="task_id" widget="task_with_hours" context="{'default_project_id': project_id, 'search_default_my_tasks': True, 'search_default_open_tasks': True}"/>
                        <field name="unit_amount" string="Time Spent" widget="timesheet_uom" decoration-danger="unit_amount &gt; 24" decoration-muted="unit_amount == 0"/>
                        <field name="name" required="0" placeholder="e.g. Sending E-mails"/>
                    </group>
                </form>