<t name="Centered Logo" t-name="mass_mailing.s_mail_block_header_logo">
    <section class="s_header_logo o_mail_block_header_logo o_mail_snippet_general" data-name="Centered Logo" data-vxml="001">
        <div class="container">
            <div class="row">
                <div class="col-md-3"/>
                <div class="col-md-6" style="text-align: center;">
                    <div class="o_not_editable">
                        <a t-att-href="(company_id.website) or '#'" style="text-decoration:none;" target="_blank">
                            <img t-if="company_id.logo or user_id.company_id.logo" class="py-4 o_b64_image_to_save o_editable_media" t-att-src="image_data_uri(company_id.logo if company_id.logo else user_id.company_id.logo)" style="height:auto;max-width:100%;"/>
                        </a>
                    </div>
                </div>
                <div class="col-md-3" style="text-align: right;"/>
            </div>
        </div>
    </section>
</t>