<data><field name="achieved_amount" position="before">
                <field name="committed_amount" decoration-danger="(committed_amount &gt; budget_amount) and parent.budget_type in ('expense', 'both')" sum="Committed" optional="show" column_invisible="parent.budget_type == 'revenue' or parent.state in ('draft','canceled')"/>
            </field>
            <field name="achieved_percentage" position="before">
                <field name="committed_percentage" widget="percentage" optional="hide" column_invisible="parent.budget_type == 'revenue' or parent.state in ('draft','canceled')"/>
            </field>
        </data>