<data><div class="oe_title" position="before">
                <field name="rental_status" widget="badge" decoration-success="rental_status == 'pickup'" decoration-warning="rental_status == 'return'" decoration-default="rental_status == 'returned'" class="float-end"/>
            </div>
            <field name="order_id" position="attributes">
                <attribute name="context">
                    {
                        'form_view_ref': 'sale_renting.rental_order_primary_form_view',
                        'in_rental_app': 1,
                    }
                </attribute>
            </field>
            <field name="name" position="after">
                <field name="start_date" widget="remaining_days" invisible="rental_status != 'pickup'"/>
                <field name="return_date" widget="remaining_days" invisible="rental_status != 'return'"/>
            </field>
            <sheet position="after">
                <footer>
                    <button type="button" string="Ok" special="cancel" data-hotkey="x" class="btn-primary" close="1"/>
                </footer>
            </sheet>
        </data>