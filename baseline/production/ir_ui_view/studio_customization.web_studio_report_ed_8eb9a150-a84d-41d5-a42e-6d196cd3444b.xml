<data><xpath expr="/t[@t-name='web.external_layout_boxed']" position="replace" mode="inner">  
<div t-attf-class="header o_company_#{company.id}_layout" t-att-style="report_header_style">
      <img src="/web/image/23756-07a1fe27/Letterhead%20Header.png" alt="" class="img img-fluid o_we_custom_image"/></div><div t-attf-class="article o_report_layout_boxed o_company_#{company.id}_layout {{  'o_report_layout_background' if company.layout_background in ['Geometric', 'Custom']  else  '' }}"><t t-out="0"/></div>
      <div t-attf-class="footer o_boxed_footer o_company_#{company.id}_layout">

            <div style="margin-top: 20px; text-align: center; font-family: Helvetica, Arial, sans-serif;">
  <!-- Simulated two-colored line using a table -->
  <table style="width: 100%; border-collapse: collapse; height: 4px; margin-bottom: 6px;">
    <tr>
      <td style="background-color: #35c5f1; width: 50%; height: 4px;"/>
      <td style="background-color: #0e395d; width: 50%; height: 4px;"/>
    </tr>
  </table>

  <!-- Footer Text -->
  <div style="font-weight: bold; font-size: 11pt;">
    General Contractor - Heavy Equipment Rental - Construction Supplies - Logistics
  </div>
</div>
          <div class="text-center">
              <div t-if="report_type == 'pdf'">
                  Page: <span class="page"/> / <span class="topage"/>
              </div>
              <div t-if="report_type == 'pdf' and display_name_in_footer" class="text-muted">
                  <span t-out="o.name">(document name)</span>
              </div>
          </div>
      </div>
    </xpath></data>