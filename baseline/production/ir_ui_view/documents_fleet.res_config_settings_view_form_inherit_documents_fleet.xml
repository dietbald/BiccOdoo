<data><xpath expr="//app[@name='documents']" position="attributes">
                <attribute name="notApp">0</attribute>
            </xpath>
            <xpath expr="//block[@id='files_centralization_section']" position="attributes">
                <attribute name="invisible">0</attribute>
            </xpath>
            <xpath expr="//block[@id='files_centralization_section']" position="inside">
                <setting company_dependent="1" help="Centralize your Fleet' documents (fines, etc.)">
                    <field name="documents_fleet_settings"/>
                    <div class="content-group" invisible="not documents_fleet_settings">
                        <div class="row mt16">
                            <label class="o_form_label col-lg-3" for="documents_fleet_folder" string="Folder"/>
                            <field name="documents_fleet_folder" required="documents_fleet_settings" widget="documents_folder_many2one" options="{'no_create': True, 'no_create_edit': True}"/>
                        </div>
                        <div class="row">
                            <label class="o_form_label col-lg-3" for="documents_fleet_tags" string="Tags"/>
                            <field name="documents_fleet_tags" widget="many2many_tags"/>
                        </div>
                    </div>
                </setting>
            </xpath>
        </data>