<pivot string="Planning / Attendance Analysis" sample="1" disable_linking="1">
                <field name="entry_date" interval="month" type="row"/>
                <field name="planned_hours" type="measure" widget="float_time"/>
                <field name="effective_hours" type="measure" widget="float_time"/>
                <field name="time_difference" type="measure" widget="float_time"/>
                <field name="planned_costs" widget="monetary"/>
                <field name="effective_costs" widget="monetary"/>
                <field name="cost_difference" widget="monetary"/>
             </pivot>