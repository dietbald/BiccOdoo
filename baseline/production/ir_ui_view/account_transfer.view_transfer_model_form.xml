<form string="Move Model" class="o_auto_transfer_form">
                <header>
                    <button name="action_perform_auto_transfer" type="object" string="Compute Transfer" class="oe_highlight btn btn-primary" invisible="not active"/>
                    <button name="action_disable" type="object" string="Disable" invisible="state == 'disabled' and active" help="Puts the transfer model in a state in which it will not automatically recompute its draft entries' values every day."/>
                    <button name="action_enable" type="object" string="Enable" invisible="state == 'in_progress' and active" help="Puts the transfer model in a state in which it will automatically recompute its draft entries' values every day."/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div name="button_box" class="oe_button_box" invisible="not id">
                        <button class="oe_stat_button" type="action" name="302" icon="fa-book" context="{'search_default_transfer_model_id': id, 'default_transfer_model_id': id}" invisible="has_draft_moves">
                            <field name="move_ids_count" string="Transfers" widget="statinfo"/>
                        </button>
                        <button class="oe_stat_button text-info" type="action" name="302" icon="fa-book" context="{'search_default_transfer_model_id': id, 'default_transfer_model_id': id}" invisible="not has_draft_moves">
                            <field name="move_ids_count" string="Transfers" widget="statinfo"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name" string="Description"/>
                        <h1>
                            <field name="name" placeholder="e.g. Monthly Expense Transfer"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <label for="date_start" string="Period"/>
                            <div>
                                <field name="date_start" class="oe_inline"/>
                                <span> to </span>
                                <field name="date_stop" class="oe_inline" placeholder="forever"/>
                            </div>
                            <field name="account_ids" string="Accounts" required="1" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="journal_id" string="Journal" domain="[('type', '=', 'general')]"/>
                            <field name="frequency"/>
                        </group>
                        <field name="conditions" widget="domain" options="{'model': 'account.move.line'}"/>
                    </group>
                    <group string="Destination">
                        <field name="line_ids" nolabel="1" colspan="2">
                            <list editable="bottom">
                                <field name="account_id" string="Account" placeholder="Keep Original"/>
                                <field name="percent" string="Rate (%)"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>