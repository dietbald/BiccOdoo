<data>
    <!-- 1. Statutory Enrollment as right-column sibling of Contract Overview -->
    <xpath expr="//group[@name='payroll_group']/group[@name='contract']" position="after">
        <group string="Statutory Enrollment &amp; On-Time Incentive" name="bicc_statutory">
            <field name="x_ot_premium_exempt"/>
            <field name="x_sss_enrolled"/>
            <field name="x_hdmf_enrolled"/>
            <field name="x_phic_enrolled"/>
            <field name="x_ontinc_eligible"/>
        </group>
    </xpath>

    <!-- 2. Contract Allowances — full width at bottom of Payroll page -->
    <xpath expr="//page[@name='payroll_information']" position="inside">
        <group string="Contract Allowances" name="bicc_allowances" colspan="2">
            <field name="x_allowance_ids" nolabel="1" colspan="2">
                <list editable="bottom">
                    <field name="x_name" string="Allowance Name" required="1" placeholder="e.g. Position Allowance"/>
                    <field name="x_type" string="Type" required="1" widget="selection" selection="[['monthly','Fixed per Period'],['daily','Per Working Day']]"/>
                    <field name="x_amount" string="Amount" required="1"/>
                    <field name="x_cutoff" string="Apply On" required="1" widget="selection" selection="[['both','Both Cutoffs'],['1q_only','1st Cutoff Only'],['2q_only','2nd Cutoff Only']]"/>
                    <field name="x_notes" string="Notes" optional="show"/>
                </list>
            </field>
        </group>
    </xpath>

    <!-- 3. Move Employer Costs block to the bottom (after Contract Allowances).
         Each move is its own top-level instruction. The destination xpath
         targets our bicc_allowances group (created above) and uses
         position="after" so the elements land in order below it. -->
    <xpath expr="//group[@name='bicc_allowances']" position="after">
        <xpath expr="//separator[@name='employer_costs']" position="move"/>
    </xpath>
    <xpath expr="//separator[@name='employer_costs']" position="after">
        <xpath expr="//label[@name='final_yearly_costs']" position="move"/>
    </xpath>
    <xpath expr="//label[@name='final_yearly_costs']" position="after">
        <xpath expr="//div[@name='final_yearly_costs']" position="move"/>
    </xpath>
    <xpath expr="//div[@name='final_yearly_costs']" position="after">
        <xpath expr="//label[@name='monthly_yearly_costs']" position="move"/>
    </xpath>
    <xpath expr="//label[@name='monthly_yearly_costs']" position="after">
        <xpath expr="//div[@name='monthly_yearly_costs']" position="move"/>
    </xpath>
    <xpath expr="//div[@name='monthly_yearly_costs']" position="after">
        <xpath expr="//label[@name='wage_on_signature']" position="move"/>
    </xpath>
    <xpath expr="//label[@name='wage_on_signature']" position="after">
        <xpath expr="//div[@name='wage_on_signature']" position="move"/>
    </xpath>
</data>