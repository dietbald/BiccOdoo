<data><t t-name="menu" position="inside">
                <button name="action_open_move" class="oe_stat_button" icon="fa-dollar" type="object" help="Generated Journal Entries" invisible="not move_id" groups="account.group_account_readonly" options="{'is_smart_button': 1}">
                    <div class="o_stat_info">
                        <span class="o_stat_text">
                            Journal Entry <br/>
                            <t invisible="move_state != 'draft'">(Draft)</t>
                            <t invisible="move_state != 'posted'">(Posted)</t>
                            <t invisible="move_state != 'cancel'">(Canceled)</t>
                        </span>
                    </div>
                </button>
            </t>
            <button name="action_validate" position="replace">
                <button name="action_validate" type="object" string="Create Draft Entry" invisible="state != '01_ready' or empty_payslips or not payslip_count" class="oe_highlight" context="{'payslip_generate_pdf': True}" confirm="Are you sure you want to proceed?"/>
            </button>
        </data>