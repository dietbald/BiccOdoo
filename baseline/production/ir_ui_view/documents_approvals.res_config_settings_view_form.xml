<data><xpath expr="//app[@name='documents']" position="attributes">
                <attribute name="notApp">0</attribute>
            </xpath>
            <xpath expr="//block[@id='files_centralization_section']" position="attributes">
                <attribute name="invisible">0</attribute>
            </xpath>
            <xpath expr="//block[@id='files_centralization_section']" position="inside">
                <setting company_dependent="1" help="Centralize files attached to Approvals">
                    <field name="documents_approvals_settings"/>
                    <div class="content-group" invisible="not documents_approvals_settings">
                        <div class="row mt16">
                            <label class="o_form_label col-lg-3" for="approvals_folder_id" string="Folder"/>
                            <field name="approvals_folder_id" required="documents_approvals_settings" widget="documents_folder_many2one" options="{'no_create': True, 'no_create_edit': True}"/>
                        </div>
                        <div class="row">
                            <label class="o_form_label col-lg-3" for="approvals_tag_ids" string="Tags"/>
                            <field name="approvals_tag_ids" widget="many2many_tags"/>
                        </div>
                    </div>
                </setting>
            </xpath>
        </data>