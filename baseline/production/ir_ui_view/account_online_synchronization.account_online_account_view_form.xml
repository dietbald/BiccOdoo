<form create="false">
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="account_number" readonly="1"/>
                                <field name="journal_ids" widget="many2many_tags" domain="[('type', 'in', ('bank', 'credit')), ('account_online_account_id', '=', False), ('company_id', '=', company_id)]"/>
                                <field name="company_id" invisible="1"/>
                            </group>
                            <group>
                                <field name="last_sync" groups="account.group_account_manager"/>
                                <field name="balance" readonly="1"/>
                                <field name="available_balance" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>