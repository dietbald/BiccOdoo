<data>
  <xpath expr="/list//field[@name='department_id']" position="after">
    <field name="x_studio_application_information" optional="hide"/>
    <field name="survey_id" optional="show"/>
    <field name="x_studio_logical_assessment" optional="hide"/>
    <field name="x_studio_emotional_assessment" optional="hide"/>
  </xpath>
  <xpath expr="/list//field[@name='is_published']" position="after">
    <field name="x_studio_resume_required" optional="hide"/>
    <field name="x_studio_salary_max" optional="hide" groups="hr_payroll.group_hr_payroll_user"/>
  </xpath>
</data>