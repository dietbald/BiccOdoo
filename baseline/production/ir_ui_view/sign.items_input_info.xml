<t name="Items input info" t-name="sign.items_input_info">
        <t t-if="sign_items">
            <t t-foreach="sign_items" t-as="item">
                <input type="hidden" class="o_sign_item_input_info" t-att-data-id="item.id" t-att-data-type_id="item.type_id.id" t-att-data-required="item.required" t-att-data-constant="item.constant" t-att-data-name="item.name" t-att-data-responsible="item.responsible_id.id" t-att-data-responsible_name="item.responsible_id.name" t-att-data-page="item.page" t-att-data-option_ids="item.option_ids.ids" t-att-data-template_id="item.template_id.id" t-att-data-radio_set_id="item.radio_set_id.id" t-att-data-num_options="item.num_options" t-att-data-pos-x="str(item.posX)" t-att-data-pos-y="str(item.posY)" t-att-data-width="item.width" t-att-data-height="item.height" t-att-data-alignment="item.alignment" t-att-data-value="item_values.get(item.id) if item_values else None" t-att-data-frame_value="frame_values.get(item.id) if frame_values else None" t-att-data-document_id="item.document_id.id"/>
            </t>
        </t>
    </t>