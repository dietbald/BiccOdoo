<list js_class="accrual_list_view" create="0">
                <header>
                    <button string="Create Accrual Entries" groups="account.group_account_user" name="573" type="action" class="btn btn-primary" data-hotkey="r"/>
                </header>
                <field name="currency_id" column_invisible="True"/> <!-- Needed for monetary widget -->
                <field name="order_id"/>
                <field name="partner_id"/>
                <field name="product_id"/>
                <field name="product_qty"/>
                <field name="qty_received_at_date" string="Received"/>
                <field name="qty_invoiced_at_date" string="Billed"/>
                <field name="product_uom_id" groups="uom.group_uom"/>
                <field name="price_unit" widget="monetary"/>
                <field name="amount_to_invoice_at_date" widget="monetary"/>
            </list>