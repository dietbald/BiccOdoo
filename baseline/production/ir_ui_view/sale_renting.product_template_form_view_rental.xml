<data><page name="sales" position="after">
                <page string="Rental prices" name="pricing" invisible="not rent_ok">
                    <group>
                        <group name="pricing" string="Pricing">
                            <field name="product_pricing_ids" nolabel="1" colspan="2">
                                <list editable="bottom">
                                    <control>
                                        <create name="add_product_pricing" string="Add a price"/>
                                    </control>
                                    <field name="product_variant_ids" widget="many2many_tags" groups="product.group_product_variant" domain="[('product_tmpl_id', '=', parent.id)]" column_invisible="parent.product_variant_count &lt; 2"/>
                                    <field name="recurrence_id" string="Period"/>
                                    <field name="pricelist_id" groups="product.group_product_pricelist"/>
                                    <field name="currency_id" column_invisible="True"/>
                                    <field name="price"/>
                                </list>
                            </field>
                        </group>
                        <group string="Reservations" name="extra_rental" invisible="not rent_ok">
                            <label for="extra_hourly"/>
                            <div>
                                <field name="extra_hourly" widget="monetary" class="oe_inline"/>
                                <span> per hour late</span>
                            </div>
                            <label for="extra_daily"/>
                            <div>
                                <field name="extra_daily" widget="monetary" class="oe_inline"/>
                                <span> per day late</span>
                            </div>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                </page>
            </page>
            <span name="sale_option" position="after">
                <span class="d-inline-flex">
                    <field name="rent_ok"/>
                    <label for="rent_ok"/>
                </span>
            </span>
            <xpath expr="//notebook/page[@name='sales']" position="attributes">
                <attribute name="invisible" add="not rent_ok" separator=" and "/>
            </xpath>
        </data>