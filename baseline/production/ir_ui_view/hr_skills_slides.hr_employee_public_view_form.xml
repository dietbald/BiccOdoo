<xpath expr="//div[@name='button_box']" position="inside">
               <field name="has_subscribed_courses" invisible="1" groups="website_slides.group_website_slides_officer"/>
                <button name="action_open_courses" class="oe_stat_button" groups="website_slides.group_website_slides_officer" icon="fa-graduation-cap" type="object" invisible="not is_user or not user_id or not has_subscribed_courses">
                    <field name="courses_completion_text" widget="statinfo" string="Courses"/>
                </button>
            </xpath>