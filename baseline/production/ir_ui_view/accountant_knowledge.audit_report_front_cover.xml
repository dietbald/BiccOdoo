<t t-name="accountant_knowledge.audit_report_front_cover">
        &lt;!DOCTYPE html&gt;
        <html>
            <head>
                <meta charset="UTF-8"/>
                <base t-att-href="base_url"/>
                <t t-call-assets="accountant_knowledge.report_assets" t-autoprefix="true"/>
            </head>
            <body>
                <div class="o-cover">
                    <div style="height: 350px"/>
                    <h1 t-out="audit_report.title"/>
                    <h2>Fiscal period from <t t-out="format_date(audit_report.start_date)"/> to <t t-out="format_date(audit_report.end_date)"/></h2>
                    <div style="height: 35px"/>
                    <hr/>
                    <div style="height: 35px"/>
                    <img t-if="audit_report.company_id.logo" t-att-src="image_data_uri(audit_report.company_id.logo)"/>
                    <h3 t-out="audit_report.company_id.name"/>
                    <t t-if="audit_report.company_id.vat">
                        <p>VAT: <t t-out="audit_report.company_id.vat"/></p>
                    </t>
                    <p t-out="audit_report.company_id.street"/>
                    <p><t t-out="audit_report.company_id.zip"/> <t t-out="audit_report.company_id.city"/></p>
                </div>
            </body>
        </html>
    </t>