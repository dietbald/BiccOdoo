<form>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Rule Name"/>
                        <h2>
                            <field name="name" readonly="is_system_default" placeholder="Mail Template extra prompt"/>
                        </h2>
                    </div>
                    <group>
                        <group>
                            <field name="interface_key" readonly="is_system_default" string="When users need to" placeholder="Select an action... "/>
                        </group>
                        <group>
                            <label for="focused_models" string="On the Model"/>
                            <field name="focused_models" widget="many2many_tags" readonly="is_system_default" placeholder="All Models" nolabel="1" invisible="is_system_default and not focused_models or interface_key == 'systray_ai_button'"/>
                            <span class="text-muted" invisible="(not is_system_default or focused_models) and interface_key != 'systray_ai_button'">All Models</span>
                        </group>
                        <group>
                            <field name="ai_agent" widget="many2one_avatar" options="{'no_create': True}" string="Call the Agent"/>
                        </group>
                    </group>
                    <group>
                        <field name="default_prompt" placeholder="Write your prompt..."/>
                    </group>
                    <notebook>
                        <page name="user_prompts_page" string="Buttons">
                            <field name="available_prompts" mode="list">
                                <list editable="bottom" open_form_view="False">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>