<form string="Convert to Task" js_class="todo_conversion_form">
                <sheet>
                    <group>
                        <!-- company_id field is used in the domain filtering project_id in
                             hr_timesheet. Creating a bridge module just to add that field is
                             overkill so it is added here. -->
                        <field name="company_id" invisible="1"/>
                        <field name="project_id" required="1" default_focus="1"/>
                        <field name="user_ids" class="o_task_user_field" options="{'no_open': True}" widget="many2many_avatar_user"/>
                        <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color', 'no_create_edit': True}" context="{'project_id': project_id}" placeholder="Choose tags from the selected project"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_convert_to_task" string="Convert to Task" type="object" class="btn-primary"/>
                    <button string="Discard" special="cancel"/>
                </footer>
            </form>