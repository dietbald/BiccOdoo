<search string="Search Challenges">
                <filter name="inprogress" string="Running Challenges" domain="[('state', '=', 'inprogress')]"/>
                <filter name="hr_challenges" string="HR Challenges" domain="[('challenge_category', '=', 'hr')]"/>
                <field name="name"/>
                <group>
                    <filter string="State" name="state" domain="[]" context="{'group_by':'state'}"/>
                    <filter string="Period" name="period" domain="[]" context="{'group_by':'period'}"/>
                </group>
            </search>