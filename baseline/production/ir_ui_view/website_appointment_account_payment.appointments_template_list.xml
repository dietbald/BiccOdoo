<data inherit_id="website_appointment.dynamic_filter_template_appointment_type_list">
    <xpath expr="//div[hasclass('o_wappointment_card_location')]" position="after">
        <div t-if="appointment.has_payment_step and appointment.product_id" class="text-primary small">
            <strong t-out="appointment.product_lst_price" t-options="{'widget': 'monetary', 'display_currency': appointment.product_currency_id}"/>
        </div>
    </xpath>
</data>