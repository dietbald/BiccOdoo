<div name="button_box" position="inside">
                    <button groups="account.group_account_basic" type="object" class="oe_stat_button" name="open_follow_up_report" icon="fa-list" invisible="not has_moves">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_value">
                                <field name="total_all_due" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </span>
                            <span class="o_stat_text">Due</span>
                        </div>
                    </button>
                </div>