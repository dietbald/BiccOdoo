<xpath expr="//block[@name='sign']" position="inside">
                <setting string="Send Requests through WhatsApp" id="sign_whatsapp" groups="base.group_no_one">
                    <div class="content-group">
                        <div class="row mt16">
                            <label class="o_light_label col-lg-3" string="Request template" for="send_request_wa_template_id"/>
                            <field name="send_request_wa_template_id" class="col-lg-9"/>
                        </div>
                        <div class="row mt16">
                            <label class="o_light_label col-lg-3" string="Completed template" for="request_completion_wa_template_id"/>
                            <field name="request_completion_wa_template_id" class="col-lg-9"/>
                        </div>
                        <div class="row mt16">
                            <label class="o_light_label col-lg-3" string="Refusal template" for="request_refusal_wa_template_id"/>
                            <field name="request_refusal_wa_template_id" class="col-lg-9"/>
                        </div>
                    </div>
                </setting>
            </xpath>