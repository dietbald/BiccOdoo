<form string="Multiple Signature Requests">
                <field name="share_link" invisible="1"/>
                <group invisible="not share_link" col="3">
                    <group colspan="3">
                        <field name="share_link" widget="CopyClipboardChar" readonly="1"/>
                    </group>
                    <group colspan="1">
                        <field name="validity" options="{'min_date': 'today'}"/>
                    </group>
                </group>
                <footer>
                    <button string="Stop sharing" name="action_stop_sharing" class="btn-primary" type="object" invisible="not is_shared" data-hotkey="q"/>
                    <button string="Copy link" class="btn-primary" name="action_copy_and_close" type="object" invisible="not is_shared" data-hotkey="x"/>
                    <button string="Close" name="action_close_request" type="object" data-hotkey="q"/>
                </footer>
            </form>