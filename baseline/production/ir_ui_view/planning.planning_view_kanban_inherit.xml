<xpath expr="//footer" position="before">
                <field name="overlap_slot_count" invisible="1"/>
                <field name="publication_warning" invisible="1"/>
                <field name="request_to_switch" invisible="1"/>
                <field name="name" invisible="1"/>
                <field name="allow_self_unassign" invisible="1"/>
                <field name="is_past" invisible="1"/>
                <p class="mt-2 mb-0" t-if="record.name.raw_value"><t t-out="record.name.raw_value.slice(0, 200) + (record.name.raw_value.length &gt; 200?'…':'')"/></p>
                <p t-if="record.publication_warning.raw_value and !record.overlap_slot_count.raw_value" class="text-warning mt-2 mb-0">
                    Some changes were made since this shift was published.
                </p>
                <p t-if="record.request_to_switch.raw_value and !record.is_past.raw_value and !record.allow_self_unassign.raw_value" class="text-warning mt-2 mb-0">
                    <span>The employee assigned would like to switch shifts with someone else.</span>
                </p>
                <p t-if="record.overlap_slot_count.raw_value" class="text-danger mt-2 mb-0">
                    <t t-out="record.overlap_slot_count.raw_value"/> other shift(s) in conflict.
                </p>
           </xpath>