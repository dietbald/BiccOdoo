<data><xpath expr="//list" position="attributes">
                <attribute name="open_form_view">True</attribute>
            </xpath>
            <xpath expr="//field[@name='parent_id']" position="after">
                <field name="timesheet_manager_id" optional="hide" string="Timesheet Approver" widget="many2one_avatar_user"/>
            </xpath>
            <xpath expr="//field[@name='resource_calendar_id']" position="after">
                <field string="Monthly Billing Time Target" name="billable_time_target" widget="timesheet_uom_no_toggle" avg="Average"/>
            </xpath>
        </data>