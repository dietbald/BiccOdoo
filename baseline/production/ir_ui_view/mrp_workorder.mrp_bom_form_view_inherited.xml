<xpath expr="//div[@name='button_box']/button[1]" position="before">
                <button name="1084" type="action" context="{'search_default_bom_id': id, 'bom_id_invisible': True}" class="oe_stat_button" icon="fa-cogs" groups="mrp.group_mrp_routings" invisible="operation_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <div class="d-flex align-items-baseline gap-1">
                            <span class="o_stat_value order-1">
                                <field name="operation_count" nolabel="1"/>
                            </span>
                            <span class="o_stat_text order-2">Operations</span>
                        </div>
                        <div class="d-flex align-items-baseline gap-1">
                            <span class="o_stat_value">
                                <field name="quality_point_count" nolabel="1"/>
                            </span>
                            <span class="o_stat_text order-2">Instructions</span>
                        </div>
                    </div>
                </button>
            </xpath>