<data><xpath expr="//field[@name='tax_ids']" position="after">
                <field name="fiscal_category_id" string="Fiscal Category" invisible="internal_group not in ('asset', 'expense', 'income')"/>
            </xpath>
            <xpath expr="//page[@name='Description']" position="after">
                <page name="fiscal_rates" string="Fiscal Rates" invisible="not fiscal_category_id">
                    <field name="rate_ids" nolabel="1">
                        <list order="date_from desc" editable="bottom">
                            <field name="date_from" width="200px"/>
                            <field name="rate" width="200px"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </data>