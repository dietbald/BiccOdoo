<form string="Budget">
                <header>
                    <button string="Reset to Draft" name="action_budget_draft" invisible="state == 'draft'" type="object" class="btn-primary"/>
                    <button string="Open" name="action_budget_confirm" invisible="state != 'draft'" type="object" class="btn-primary"/>
                    <button string="Revise" name="create_revised_budget" invisible="state != 'confirmed'" type="object" class="btn-secondary"/>
                    <button string="Done" name="action_budget_done" invisible="state != 'confirmed'" type="object" class="btn-secondary"/>
                    <button string="Cancel Budget" name="action_budget_cancel" invisible="state != 'draft'" type="object" class="btn-secondary"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet string="Budget">
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" name="action_open_budget_report" type="object" icon="fa-bar-chart">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Budget Report</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="state != 'draft'" placeholder="e.g. Budget 2023"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id" readonly="state != 'draft'" domain="[('share', '=', False)]" widget="many2one_avatar" options="{'no_create': True}"/>
                            <field name="parent_id" readonly="state != 'draft'" invisible="not parent_id"/>
                            <field name="budget_type" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <label for="date_from" string="Period"/>
                            <div class="o_row">
                                <field name="date_from" nolabel="1" class="oe_inline" readonly="state != 'draft'"/>
                                <i class="fa fa-long-arrow-right mx-2" aria-label="to" title="to"/>
                                <field name="date_to" nolabel="1" class="oe_inline" readonly="state != 'draft'"/>
                            </div>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Budget Lines" name="budget_lines">
                            <field name="budget_line_ids" colspan="4" nolabel="1" readonly="state != 'draft'">
                                <list string="Budget Lines" editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="account_id" optional="show"/>
                                    <field name="currency_id" column_invisible="True"/>
                                    <field name="budget_amount" sum="Budget"/>
                                    <field name="achieved_amount" decoration-danger="(achieved_amount &gt; budget_amount) and parent.budget_type in ('expense', 'both')" sum="Achieved" column_invisible="parent.state in ('draft','canceled')"/>
                                    <field name="theoritical_amount" sum="Theoretical" optional="hide" column_invisible="parent.state in ('draft','canceled')"/>
                                    <field name="achieved_percentage" widget="percentage" optional="hide" column_invisible="parent.state in ('draft','canceled')"/>
                                    <field name="theoritical_percentage" widget="percentage" optional="hide" column_invisible="parent.state in ('draft','canceled')"/>
                                    <button type="object" name="action_open_budget_entries" string="Audit" width="60px" column_invisible="parent.state in ('draft','canceled')"/>
                                    <field name="company_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>