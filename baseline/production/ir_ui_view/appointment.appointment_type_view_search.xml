<search string="Appointment Types">
                <field name="name"/>
                <field name="location_id"/>
                <field name="staff_user_ids"/>
                <field name="resource_ids"/>
                <field name="category"/>
                <filter string="My Appointments" name="my_appointments" domain="['|', ('staff_user_ids', 'in', [uid]), ('create_uid', '=', uid)]"/>
                <filter string="My Calendar Link" name="my_calendar_link" domain="[('category', '=', 'anytime'), ('staff_user_ids', 'in', [uid])]"/>
                <separator/>
                <filter string="Weekly Schedule" name="filter_category_recurring" domain="[('category', '=', 'recurring')]"/>
                <filter string="Flexible Schedule" name="filter_category_custom" domain="[('category', '=', 'custom')]"/>
                <filter string="Date-limited" name="filter_category_punctual" domain="[('category', '=', 'punctual')]"/>
                <filter string="Calendar Links" name="filter_category_anytime" domain="[('category', '=', 'anytime')]"/>
                <separator/>
                <filter name="filter_active" string="Archived" domain="[('active', '=', False)]"/>
                <group>
                    <filter string="Category" name="group_by_category" context="{'group_by': 'category'}"/>
                    <filter string="Timezone" name="group_by_timezone" context="{'group_by': 'appointment_tz'}"/>
                </group>
            </search>