<kanban class="o_kanban_mobile">
                   <field name="currency_id"/>
                   <templates>
                        <t t-name="card">
                            <div t-attf-class="#{!selection_mode ? 'text-center' : ''}">
                                <field class="fw-bold fs-5" name="display_name"/>
                            </div>
                            <hr class="mt-2 mb-2"/>
                            <div t-attf-class="#{!selection_mode ? 'text-center' : ''}">
                                Balance: <field name="balance" widget="monetary"/>
                            </div>
                        </t>
                    </templates>
                </kanban>