<form string="Salary Rule Parameter">
                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button name="action_open_salary_rules" class="oe_stat_button" icon="fa-list-ul" type="object" groups="hr_payroll.group_hr_payroll_manager">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Salary Rules</span>
                                <span class="o_stat_value"><field name="salary_rule_count"/></span>
                            </div>
                        </button>
                    </div>
                    <h1 class="w-100"><field name="name"/></h1>
                    <group>
                        <field name="code"/>
                        <field name="description" type="html" options="{'collaborative': true, 'resizable': false}" placeholder="Note a description of your parameter, when it's used, how is it computed, what's the source, ..."/>
                    </group>
                    <notebook>
                        <page string="History" name="history">
                            <field name="parameter_version_ids" nolabel="1" context="{'default_rule_parameter_id': id}">
                                <list editable="top">
                                    <field name="date_from"/>
                                    <field name="parameter_value" widget="code" options="{'mode': 'python'}"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>