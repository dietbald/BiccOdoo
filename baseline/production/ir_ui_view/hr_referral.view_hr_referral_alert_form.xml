<form>
                <header>
                    <button name="1533" type="action" string="Send Mail"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group name="duration_details">
                            <field name="date_from"/>
                            <field name="active" invisible="1"/>
                            <field name="date_to"/>
                            <field name="company_id" groups="base.group_multi_company" options="{'no_create': True}" placeholder="Visible to all"/>
                        </group>
                        <group name="alert_type">
                            <field name="onclick" widget="radio"/>
                            <field name="url" invisible="onclick != 'url'" required="onclick == 'url'" placeholder="https://www.google.com"/>
                        </group>
                    </group>
                    <group col="1">
                        <group name="name_details">
                            <field name="name"/>
                        </group>
                    </group>
                </sheet>
            </form>