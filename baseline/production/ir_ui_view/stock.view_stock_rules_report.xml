<form string="Product Routes Report">
                <group>
                    <field name="product_tmpl_id" invisible="1"/>
                    <field name="product_has_variants" invisible="1"/>
                    <field name="product_id" domain="[('product_tmpl_id', '=', product_tmpl_id)]" readonly="not product_has_variants" options="{'no_create': True}"/>
                    <field name="warehouse_ids" groups="stock.group_stock_multi_warehouses" widget="many2many_tags"/>
                </group>
                <footer>
                    <button name="print_report" string="Overview" type="object" data-hotkey="q" class="btn-primary"/>
                    <button string="Cancel" class="btn-default" special="cancel" data-hotkey="x"/>
                </footer>
            </form>