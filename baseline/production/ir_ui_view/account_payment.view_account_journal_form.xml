<data><xpath expr="//field[@name='inbound_payment_method_line_ids']//field[@name='payment_account_id']" position="after">
                <field name="code" column_invisible="True"/>
                <field name="payment_provider_id" options="{'no_open': True, 'no_create': True}" optional="hide" readonly="payment_provider_state in ('enabled', 'test')"/>
                <field name="payment_provider_state" column_invisible="True"/>
                <button name="action_open_provider_form" type="object" string="SETUP" class="float-end btn-secondary" invisible="not payment_provider_id" groups="base.group_system"/>
            </xpath>
            <xpath expr="//field[@name='inbound_payment_method_line_ids']/list" position="attributes">
                <attribute name="decoration-muted">payment_provider_state == 'disabled'</attribute>
            </xpath>
        </data>