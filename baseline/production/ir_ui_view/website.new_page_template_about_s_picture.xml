<data inherit_id="website.new_page_template_s_picture" primary="True">
    <xpath expr="//section" position="attributes">
        <attribute name="class" add="o_colored_level" separator=" "/>
    </xpath>
    <xpath expr="//h1|//h2" position="replace">
