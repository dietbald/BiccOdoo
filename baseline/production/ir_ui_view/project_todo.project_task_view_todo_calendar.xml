<calendar string="To-dos" date_start="date_deadline" mode="month" color="personal_stage_type_id" hide_time="true" event_open_popup="true" quick_create="1" show_unusual_days="True" scales="day,week,month,year">
                <field name="name"/>
                <field name="priority" widget="priority"/>
                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}" invisible="not tag_ids"/>
                <field name="personal_stage_id" string="Personal Stage" options="{'no_open': True}" invisible="not personal_stage_id"/>
            </calendar>