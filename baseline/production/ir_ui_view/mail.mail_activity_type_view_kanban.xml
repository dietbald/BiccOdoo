<kanban class="o_kanban_mobile">
                <field name="icon"/>
                <templates>
                    <t t-name="card">
                        <div class="fw-bold fs-5">
                            <i t-if="record.icon.value" t-attf-class="fa #{record.icon.value} fa-fw" role="img" aria-label="Activity Type Name" title="Activity Type Name"/>
                            <field name="name"/>
                        </div>
                        <field t-if="record.res_model.value" name="res_model"/>
                        <div t-if="record.summary.raw_value">
                            Default Summary: <field name="summary"/>
                        </div>
                        <footer>
                            <field class="ms-auto" name="default_user_id" widget="many2one_avatar_user" readonly="1"/>
                        </footer>
                    </t>
                </templates>
            </kanban>