<t t-name="hr_contract_salary.salary_package_benefits">
        <div id="hr_cs_configurator" class="col-lg-9 col-xl-8">
            <t t-if="not benefits">
                <h2>There is no available option to customize your salary</h2>
            </t>
            <t t-foreach="benefit_types" t-as="benefit_type">
                <h2><t t-esc="benefit_type.name"/></h2>
                <t t-foreach="benefits[benefit_type]" t-as="benefit">
                    <div t-att-class="'py-4 mb-0 border-top' if benefit.show_name else ''">
                        <div class="row">
                            <label class="col-md-3 pt-0 ps-4 col-form-label" t-att-for="benefit.field">
                                <i t-att-class="(benefit.icon or '') + ' fa-1x fa-fw bg-odoo'"/> <t t-if="benefit.show_name"><t t-esc="benefit.name"/></t>
                            </label>
                            <div class="col-md-6">
                                <t t-if="benefit.folded">
                                    <label class="hr_cs_control hr_cs_control_checkbox mb-2">
                                        <t t-esc="benefit.fold_label"/>
                                        <input type="checkbox" class="benefit_input folded" applies-on="version" t-att-name="'fold_' + benefit.field" t-att-checked="initial_values['fold_' + benefit.field]" t-att-data-requested_documents="benefit.requested_documents" t-att-data-benefit_ids-dependent="dependent_benefits[benefit]" t-att-data-benefit_ids-mandatory="mandatory_benefits[benefit]" t-att-data-benefit_ids-mandatory-names="mandatory_benefits_names[benefit]"/>
                                        <div class="hr_cs_control_indicator"/>
                                    </label>
                                </t>
                                <div t-att-class="'folded_content ' + ('d-none' if (benefit.res_field_id and 'fold_' + benefit.field in initial_values and not initial_values['fold_' + benefit.field]) else '')">
                                    <t t-if="benefit.display_type == 'slider'">
                                        <span class="badge text-bg-secondary"><t t-esc="benefit.slider_min"/></span>
                                        <input type="range" class="benefit_input hr_cs_control_range" t-att-step="benefit.slider_step or 1" t-att-min="benefit.slider_min" t-att-max="benefit.slider_max" applies-on="version" t-att-value="initial_values[benefit.field]" t-att-list="benefit.field + '_range'" t-att-name="benefit.field + '_slider'" t-att-data-benefit_ids-dependent="dependent_benefits[benefit]" t-att-data-benefit_ids-mandatory="mandatory_benefits[benefit]" t-att-data-benefit_ids-mandatory-names="mandatory_benefits_names[benefit]"/>
                                        <span class="badge text-bg-secondary"><t t-esc="benefit.slider_max"/></span>
                                        <datalist t-att-id="benefit.field + '_range'">
                                            <t t-set="step" t-value="(benefit.slider_max - benefit.slider_min) / 10.0"/>
                                            <t t-foreach="range(1, 10)" t-as="i">
                                                <option><t t-esc="step * i"/></option>
                                            </t>
                                        </datalist>
                                    </t>
                                    <t t-if="benefit.display_type == 'radio'">
                                        <t t-foreach="benefit.value_ids.filtered(lambda v: v.display_type == 'line')" t-as="value">
                                            <label class="hr_cs_control hr_cs_control_radio benefit_input">
                                                <input type="radio" t-att-name="benefit.field + '_radio'" t-att-data-value="str(value.value)" applies-on="version" t-att-checked="not initial_values[benefit.field] if (len(benefit.value_ids) &lt;= 2 and value.value == 0) else (initial_values[benefit.field] if (len(benefit.value_ids) &lt;= 2 and value.value != 0) else (initial_values[benefit.field] == float(value.value)))" t-att-class="'hide_description' if not value.always_show_description else ''" t-att-data-requested_documents="benefit.requested_documents" t-att-data-benefit_ids-dependent="dependent_benefits[benefit]" t-att-data-benefit_ids-mandatory="mandatory_benefits[benefit]" t-att-data-benefit_ids-mandatory-names="mandatory_benefits_names[benefit]"/>
                                                <t t-esc="value.name"/>
                                                <div t-att-class="'hr_cs_control_indicator' + (' hr_cs_control_no' if value.selector_highlight == 'red' else '')"/>
                                            </label>
                                        </t>
                                    </t>
                                    <t t-if="benefit.display_type == 'manual'">
                                        <input type="number" min="0" applies-on="version" class="form-control form-control-primary mb8 benefit_input" t-att-name="benefit.field + '_manual'" t-att-data-field-type="benefit.manual_res_field_id.sudo().ttype" t-att-data-requested_documents="benefit.requested_documents" t-att-value="initial_values[benefit.field + '_manual']" t-att-data-benefit_ids-dependent="dependent_benefits[benefit]" t-att-data-benefit_ids-mandatory="mandatory_benefits[benefit]" t-att-data-benefit_ids-mandatory-names="mandatory_benefits_names[benefit]"/>
                                    </t>
                                    <t t-if="benefit.display_type == 'text'">
                                        <textarea rows="6" cols="60" applies-on="version" class="form-control form-control-primary mb8 benefit_input" t-att-name="benefit.field + '_text'" t-att-data-field-type="benefit.manual_res_field_id.sudo().ttype" t-att-data-requested_documents="benefit.requested_documents"><t t-esc="initial_values[benefit.field + '_text']"/></textarea>
                                    </t>
                                    <t t-if="benefit.display_type == 'dropdown'">
                                        <select class="form-control form-select form-select-primary mt16 mb8 benefit_input" applies-on="version" t-att-name="'select_' + benefit.field">
                                            <t t-set="options" t-value="dropdown_options[benefit.field]"/>
                                            <t t-foreach="options" t-as="option">
                                                <option t-att-value="option[0]" t-att-selected="initial_values['select_' + benefit.field] == option[0]"><t t-esc="option[1]"/></option>
                                            </t>
                                        </select>
                                    </t>
                                    <t t-if="benefit.display_type == 'dropdown-group'">
                                        <select class="form-control form-select form-select-primary mt16 mb8 benefit_input" applies-on="version" t-att-name="'select_' + benefit.field" t-att-required="True">
                                            <t t-set="groups" t-value="dropdown_group_options[benefit.field]"/>
                                            <t t-foreach="groups" t-as="group">
                                                <optgroup t-att-label="group">
                                                    <t t-set="options" t-value="groups[group]"/>
                                                    <t t-foreach="options" t-as="option">
                                                        <option t-att-value="option[0]" t-att-selected="initial_values['select_' + benefit.field] == option[0]">
                                                            <t t-esc="option[1]"/>
                                                        </option>
                                                    </t>
                                                </optgroup>
                                            </t>
                                        </select>
                                    </t>
                                    <span class="form-text" t-att-name="'description_' + (benefit.field or 'undefined')"><t t-out="version._get_benefit_description(benefit)"/></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <t t-if="benefit.res_field_id">
                                    <div class="input-group">
                                        <div t-if="version.company_id.currency_id.position == 'before' and benefit.uom == 'currency'" t-out="version.company_id.currency_id.symbol" class="w-25 input-group-text form-control o_left text-end d-block"/>
                                        <t t-if="not benefit.folded and benefit.display_type in ['dropdown', 'slider', 'dropdown-group']">
                                            <t t-if="benefit.display_type == 'dropdown'">
                                                <t t-set="init_field_value" t-value="initial_values[benefit.field]"/>

                                                <t t-if="init_field_value == 0.0 and len(dropdown_options[benefit.field]) &gt; 0">
                                                    <t t-set="init_field_value" t-value="dropdown_options[benefit.field][0][1]"/>
                                                </t>
                                                <input t-att-class="'form-control text-start' if version.company_id.currency_id.position == 'before' and benefit.uom == 'currency' else 'form-control mw-50 text-end'" type="text" disabled="disabled" placeholder="0" t-att-name="benefit.field" t-att-value="init_field_value" applies-on="version"/>
                                            </t>
                                            <t t-elif="benefit.display_type == 'slider'">
                                                <t t-set="init_field_value" t-value="initial_values[benefit.field]"/>
                                                <t t-if="init_field_value == 0.0">
                                                    <t t-set="init_field_value" t-value="benefit.slider_min"/>
                                                </t>
                                                <input t-att-class="'form-control text-start' if version.company_id.currency_id.position == 'before' and benefit.uom == 'currency' else 'form-control mw-50 text-end'" type="text" disabled="disabled" placeholder="0" t-att-name="benefit.field" t-att-value="init_field_value" applies-on="version"/>
                                            </t>
                                            <t t-elif="benefit.display_type == 'dropdown-group'">
                                                <t t-set="groups" t-value="dropdown_group_options[benefit.field]"/>
                                                <t t-set="init_field_value" t-value="initial_values[benefit.field]"/>

                                                <t t-if="init_field_value == 0.0 ">
                                                    <t t-foreach="groups.values()" t-as="values">
                                                        <t t-if="len(values)&gt;0 and not init_field_value">
                                                            <t t-set="init_field_value" t-value="values[0][1]"/>
                                                        </t>
                                                    </t>
                                                </t>
                                                <input t-att-class="'form-control text-start' if version.company_id.currency_id.position == 'before' and benefit.uom == 'currency' else 'form-control mw-50 text-end'" type="text" disabled="disabled" placeholder="0" t-att-name="benefit.field" t-att-value="init_field_value" applies-on="version"/>
                                            </t>
                                        </t>
                                        <t t-else="">
                                            <input t-att-class="'form-control text-start' if version.company_id.currency_id.position == 'before' and benefit.uom == 'currency' else 'form-control mw-50 text-end'" type="text" disabled="disabled" placeholder="0" t-att-name="benefit.field" t-att-value="initial_values[benefit.field]" applies-on="version"/>
                                        </t>
                                        
                                        <div class="input-group-text">
                                            <t t-if="benefit.uom == 'days'">Days</t>
                                            <t t-if="benefit.uom == 'percent'">%</t>
                                            <t t-if="benefit.uom == 'currency' and version.company_id.currency_id.position == 'after'">
                                                <t t-out="version.company_id.currency_id.symbol"/>
                                            </t>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </div>
    </t>