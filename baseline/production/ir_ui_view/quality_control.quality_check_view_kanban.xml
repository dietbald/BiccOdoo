<kanban class="o_kanban_small_column" sample="1">
                <field name="quality_state"/>
                <templates>
                    <t t-name="card">
                        <div class="row">
                            <field name="name" class="col-6 fw-bolder"/>
                            <div class="col-6">
                                <span t-attf-class="float-end text-end badge #{['none'].indexOf(record.quality_state.raw_value) &gt; -1 ? 'text-bg-secondary' : ['fail'].indexOf(record.quality_state.raw_value) &gt; -1 ? 'text-bg-danger' : ['done'].indexOf(record.quality_state.raw_value) &gt; -1 ? 'text-bg-primary' : 'text-bg-success'}"><field name="quality_state"/></span>
                            </div>
                        </div>
                        <div class="row text-muted">
                            <field name="product_id" class="col-8"/>
                            <field name="lot_ids" class="col-4" widget="many2many_tags"/>
                        </div>
                        <field name="user_id" widget="many2one_avatar_user" class="ms-auto"/>
                    </t>
                </templates>
            </kanban>