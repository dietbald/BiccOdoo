<data><xpath expr="//button[@name='archive_applicant']" position="before">
                <button name="action_send_survey" string="Send Interview" type="object" invisible="not active or not survey_id"/>
            </xpath>
            <xpath expr="//button[@name='action_create_meeting']" position="after">
                <button name="action_print_survey" class="oe_stat_button" icon="fa-pencil-square-o" type="object" help="See interview report" invisible="not survey_id or not response_ids">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Consult</span>
                        <span class="o_stat_text">Interview</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//field[@name='job_id']" position="before">
                <field name="survey_id" invisible="1"/>
                <field name="response_ids" invisible="1"/>
            </xpath>
        </data>