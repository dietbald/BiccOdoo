<form>
                <field name="slot_count" invisible="1"/>
                <div class="alert alert-warning text-center py-2 mb-2" role="status" invisible="not employee_id or slot_count != 0">
                    This employee has no published shifts scheduled for this period.
                </div>
                <sheet>
                    <group>
                        <field name="employee_id" widget="many2one_avatar_employee"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_preview_shift" type="object" string="Preview" class="btn-primary" data-hotkey="q" disabled="1" invisible="slot_count &gt; 0"/>
                    <button name="action_preview_shift" type="object" string="Preview" class="btn-primary" data-hotkey="q" invisible="slot_count == 0"/>
                    <button name="discard" string="Discard" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>