<data name="User Sign In redirect" inherit_id="portal.user_sign_in" primary="True">
        <xpath expr="//a" position="attributes">
            <attribute name="t-attf-href">/web/login?redirect={{request.httprequest.path}}</attribute>
        </xpath>
    <xpath expr="." position="attributes"><attribute name="t-name">portal.user_sign_in_redirect</attribute></xpath></data>