<form string="Payslip Correction">
                <div class="alert alert-warning d-flex align-items-center" role="alert" invisible="not is_multi_payslip">
                    <button type="object" class="btn btn-link me-1 p-0" name="action_show_related_payslips">
                        <field name="payslip_count"/> payslips
                    </button>
                    have been affected by this version's changes.
                </div>
                <field name="payslip_id" widget="many2one" readonly="1" invisible="is_multi_payslip"/>
                <field name="correction_choice" widget="radio" invisible="not is_multi_payslip"/>
                <footer>
                    <button name="action_correct_payslips" string="Correct payslip" type="object" class="oe_highlight"/>
                    <button name="action_revert_payslips" string="Revert only" type="object" class="btn-secondary"/>
                    <button string="Discard" special="cancel" data-hotkey="x" class="btn-secondary"/>
                </footer>
            </form>