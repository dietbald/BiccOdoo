<t t-name="accountant_knowledge.audit_report_table_of_content">
        &lt;!DOCTYPE html&gt;
        <html>
            <head>
                <meta charset="UTF-8"/>
                <base t-att-href="base_url"/>
                <t t-call-assets="accountant_knowledge.report_assets" t-autoprefix="true"/>
            </head>
            <body>
                <div class="o-toc">
                    <h1>Table of content</h1>
                    <t t-foreach="headings" t-as="heading">
                        <a t-attf-class="o-toc-h#{heading['depth'] + 1}" href="http://odoo.com">
                            <div class="o-toc-title" t-out="heading['outline']['/Title']"/>
                            <div t-out="heading['outline']['/Page'] + 1 + heading['page_offset_in_body'] + offset"/>
                        </a>
                    </t>
                </div>
            </body>
        </html>
    </t>