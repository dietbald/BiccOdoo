<list string="Edit Billable Time Target" multi_edit="1" editable="bottom" open_form_view="True">
                <field name="name"/>
                <field name="company_id" optional="hide" options="{'no_open': True}"/>
                <field name="department_id" optional="hide" options="{'no_open': True}"/>
                <field name="job_id" context="{'default_no_of_recruitment': 0, 'default_is_favorite': False}" options="{'no_open': True}" optional="hide"/>
                <field name="parent_id" optional="hide" widget="many2one_avatar_employee"/>
                <field name="timesheet_manager_id" optional="hide" string="Timesheet Approver" widget="many2one_avatar_user"/>
                <field name="resource_calendar_id" optional="show" options="{'no_open': True}"/>
                <field name="billable_time_target" widget="timesheet_uom_no_toggle" avg="Average"/>
            </list>