<t t-name="portal.portal_my_contact">
        <div t-attf-class="o_portal_contact_details d-flex flex-column gap-2 #{_spacingClass}">
            <div class="d-flex gap-2">
                <img class="o_avatar rounded" t-att-src="_contactAvatar" alt="Contact"/>
                <div>
                    <span t-attf-class="d-block lh-1 mb-1 {{ 'pt-1' if not _contactLink else '' }}" t-out="_contactName"/>
                    <a t-if="_contactLink" href="#discussion" class="d-flex align-items-center gap-2 small lh-1">Send message</a>
                </div>
            </div>
            <t t-out="0"/>
        </div>
    </t>