<kanban class="o_kanban_mobile">
                <templates>
                    <t t-name="card">
                        <div class="row mb4">
                            <field name="name" class="fw-bold fs-5 col-8" readonly="state == 'done'"/>
                            <div class="col-4">
                                <field name="state" class="float-end" widget="label_selection" options="{'classes': {'draft': 'default', 'done': 'success'}}"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-10">
                                <i class="fa fa-clock-o me-1" role="img" aria-label="Period" title="Period"/>
                                <field name="date_from"/> -
                                <field name="date_to"/>
                            </div>
                            <div class="col-2">
                                <field name="user_id" class="float-end" widget="many2one_avatar_user"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>