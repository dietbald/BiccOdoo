<t t-name="report_offer_letter">
    <t t-call="web.basic_layout">
        <div class="page">
            <div class="oe_structure"/>
            <t t-foreach="docs" t-as="doc">
                <!-- Company Header -->
                <table class="table-borderless" style="width: 100%; font-family: Arial, sans-serif; margin-bottom: 10px; border-collapse: collapse; border: none;">
                    <tbody>
                        <tr style="vertical-align: middle">
                            <td style="width: 50%; vertical-align: middle; padding: 0; border: none">
                                <img t-att-src="image_data_uri(doc.company_id.logo)" t-if="doc and doc.company_id and doc.company_id.logo" alt="BiCC Logo" style="max-width: 120px; max-height: 80px"/>
                            </td>
                            <td style="width: 50%; text-align: right; vertical-align: bottom; padding: 0; border: none;">
                                <p style="font-size: 14px; margin: 0; font-weight: bold; line-height: 1.5;">
                                    Block 21 Lot 4, Ledesco Village
                                </p>
                                <p style="font-size: 14px; margin: 0; font-weight: bold; line-height: 1.5;">
                                    Brgy. Cubay, Jaro, Iloilo City, 5000
                                </p>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <!-- Contact Details -->
                <table style="width: 100%; background-color: #ec008c; color: white; font-family: Arial, sans-serif; margin-bottom: 20px; border-collapse: collapse; border: none;">
                    <tbody>
                        <tr style="border: none">
                            <td style="width: 50%; text-align: left; padding: 10px 20px; font-size: 14px; border: 1px solid #ec008c;">
                                <b>0917/568.60.30</b>
                            </td>
                            <td style="width: 50%; text-align: right; padding: 10px 20px; font-size: 14px; border: 1px solid #ec008c;">
                                <a href="http://www.bicc.ph" style="color: #ffffff; text-decoration: none" target="_blank">
                                    <b>www.bicc.ph</b>
                                </a>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <!-- Letter Title -->
                <h2 style="color: #333; text-align: center; margin: 20px 0">Letter of Offer</h2>
                <h4 style="color: #333; text-align: center; margin: 20px 0">
                    <span t-field="doc.job_id.name" t-if="doc and doc.job_id and doc.job_id.name"/>
                </h4>

                <!-- Letter Content -->
                <div style="font-family: Arial, sans-serif; color: #333; margin-bottom: 20px">
                    <p>Dear <strong><span t-field="doc.partner_name" t-if="doc and doc.partner_name"/></strong>,</p>
                    <p>
                        We are pleased to offer you the position of
                        <span t-field="doc.job_id.name" t-if="doc and doc.job_id and doc.job_id.name"/> at
                        <strong><span t-field="doc.company_id" t-if="doc and doc.company_id"/></strong>.
                        After reviewing your qualifications and the discussions we have had during your interviews,
                        we believe that your background and skills are an excellent match for our team.
                    </p>
                </div>

                <!-- Offer Details -->
                <div style="flex: 1; font-family: Arial, sans-serif; padding: 20px">
                    <ol style="font-family: Arial, sans-serif; color: #333; line-height: 1.6">
                        <li>
                            <strong>Start Date:</strong>
                            <br/>
                            Your start date will be on
                            <t t-if="doc and doc.x_studio_proposed_start_date">
                                <span t-esc="doc.x_studio_proposed_start_date.strftime('%A %d %B %Y')"/>.
                            </t>
                            <t t-else="">
                                <span style="color: red; font-weight: bold;">Field Missing</span>
                            </t>
                            Please report to our office on or before 9AM.
                        </li>
                        <li>
                            <strong>Salary and Compensation:</strong>
                            <br/>
                            Your starting salary will be
                            <span t-if="doc and doc.salary_proposed">
                                PHP <span t-field="doc.salary_proposed" t-options="{'widget': 'float', 'precision': 2}" style="font-weight: bold;"/>
                            </span>
                            <span t-else="" style="color: red; font-weight: bold;">Field Missing</span>
                            per month.
                            <span t-if="doc and doc.x_studio_on_time_incentive">
                                In addition to this, you will receive a PHP 1000 On Time Incentive.
                            </span>
                            <span t-field="doc.x_studio_salary_details" t-if="doc and doc.x_studio_salary_details"/>
                        </li>
                        <li>
                            <strong>Work Hours and Location:</strong>
                            <br/>
                            Your usual hours of work will be from 8AM to 5PM, Monday to Saturday.
                            This position is based at Block 21 Lot 4, Ledesco Village, Brgy. Cubay, Jaro, Iloilo City.
                        </li>
                        <li>
                            <strong>Employment Status:</strong>
                            <br/>
                            This position is probationary for 6 months, following regularization on successfully passing probation evaluation.
                        </li>
                    </ol>
                </div>

                <!-- Closing Statement -->
                <div style="margin-top: 20px; font-family: Arial, sans-serif; color: #333; line-height: 1.6">
                    <p>
                        Please sign and return a scan of this letter as a formal acceptance of this job offer within 48 hours.
                        We are excited about the possibility of you joining our team and look forward to your contributions.
                        If you have any questions, please do not hesitate to contact us.
                    </p>
                    <p>Welcome to BiCC!</p>
                </div>

                <!-- Signature Section -->
                <table class="table-borderless" style="width: 100%; margin-top: 40px; font-family: Arial, sans-serif; border-collapse: collapse; border: none;">
                    <tbody>
                        <tr>
                            <td style="width: 50%; vertical-align: top; border: none">
                                <p>Warm regards,</p>
                                <p><strong><span t-field="doc.user_id" t-if="doc and doc.user_id"/></strong></p>
                                <p>BiCC</p>
                                <p>0917/324.88.90</p>
                            </td>
                            <td style="width: 50%; vertical-align: top; border: none; padding-right: 20px;">
                                <span>Accepted by:</span>
                                <div class="o_sign_signature" data-signature="doc.sign" data-signature-type="signature" style="border: 1px solid #ccc; width: 300px; height: 80px; margin: 10px auto;">
                                    <span>Sign Here</span>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </t>
        </div>
    </t>
</t>