<form>
                <sheet class="o_ai_topic_form">
                    <div class="oe_title mb-4">
                        <div>
                            <label for="name"/>
                            <h1 class="mb-0">
                                <field name="name" placeholder="e.g. Chat with customers"/>
                            </h1>
                            <h4>
                                <field name="description" options="{'line_breaks': 0}" placeholder="Summarize what this topic does"/>
                            </h4>
                        </div>
                    </div>
                    <group>
                        <field name="instructions" placeholder="Explain to the Agent what they need to do..."/>
                        <field name="tool_ids" widget="many2many_tags" options="{'no_quick_create': True, 'edit_tags': True}" context="{'default_use_in_ai': True}"/>
                    </group>
                </sheet>
            </form>