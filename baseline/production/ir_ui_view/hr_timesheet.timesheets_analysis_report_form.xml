<form string="Timesheets Analysis">
                    <sheet>
                        <group>
                            <group>
                                <field name="project_id"/>
                                <field name="task_id"/>
                            </group>
                            <group>
                                <field name="employee_id"/>
                                <field name="date"/>
                                <field name="amount" invisible="1"/>
                                <field name="unit_amount" string="Time Spent" widget="timesheet_uom" decoration-danger="unit_amount &gt; 24" decoration-muted="unit_amount == 0"/>
                            </group>
                        </group>
                        <field name="name" widget="text" nolabel="1"/>
                    </sheet>
                </form>