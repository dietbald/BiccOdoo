<search>
                    <field name="name"/>
                    <field name="return_type"/>
                    <field name="cycle"/>
                    <filter name="filter_manual" string="Manual" domain="[('type', '=', 'check'), ('model', '=', False)]"/>
                    <filter name="filter_automated" string="Automated" domain="[('type', '=', 'check'), ('model', '!=', False)]"/>
                    <filter name="filter_file_upload" string="Document Upload" domain="[('type', '=', 'file')]"/>

                    <filter name="groupby_cycle" string="Cycle" context="{'group_by': 'cycle'}"/>
                    <filter name="groupby_type" string="Type" context="{'group_by': 'type'}"/>
                    <filter name="groupby_return_type" string="Return/Audit" context="{'group_by': 'return_type'}"/>
                </search>