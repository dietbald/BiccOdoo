<data>
  <xpath expr="//group[@name='studio_group_d673aa_right']" position="replace"/>
  <xpath expr="//field[@name='x_name']" position="attributes">
    <attribute name="invisible">True</attribute>
    <attribute name="required">False</attribute>
  </xpath>
  <xpath expr="//field[@name='x_studio_currency_id']" position="after">
    <field name="x_studio_leads_opportunity_link" options="{&quot;no_create&quot;:true}" required="True" force_save="0" readonly="False"/>
    <field name="x_studio_partner_id" options="{&quot;no_create&quot;:true}" domain="[(&quot;is_company&quot;, &quot;=&quot;, True)]"/>
    <field name="x_studio_results" widget="selection"/>
  </xpath>
  <xpath expr="//field[@name='x_studio_value']" position="attributes">
    <attribute name="string">Bid Amount</attribute>
  </xpath>
  <xpath expr="//field[@name='x_studio_value']" position="after">
    <field name="x_studio_dive" force_save="1" readonly="True" widget="percentage"/>
    <field name="x_studio_remarks"/>
  </xpath>
</data>