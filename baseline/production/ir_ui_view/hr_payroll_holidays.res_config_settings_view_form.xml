<xpath expr="//block[@id='hr_payroll_accountant']" position="after">
                <block title="Time Off" id="hr_payroll_time_off_settings">
                    <setting string="Deferred Time Off" help="Postpone time off after payslip validation">
                        <div class="content-group">
                            <div class="row mt16 ms-2">
                                <label string="Responsible" for="deferred_time_off_manager" class="col-md-6 p-0 m-0 o_light_label"/>
                                <field name="deferred_time_off_manager" class="col-lg-6 p-0" placeholder="No one will be notified"/>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>