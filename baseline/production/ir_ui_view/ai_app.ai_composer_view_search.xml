                <filter name="group_by_key" string="Key" context="{'group_by': 'interface_key'}"/>
                <filter name="group_by_models" context="{'group_by': 'focused_models'}"/>
                <filter name="group_by_agent" context="{'group_by': 'ai_agent'}"/>
            </search>