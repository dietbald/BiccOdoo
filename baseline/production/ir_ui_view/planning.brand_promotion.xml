<data inherit_id="web.brand_promotion" primary="True">
        <xpath expr="//t[@t-call='web.brand_promotion_message']" position="replace">
            <t t-call="web.brand_promotion_message">
                <t t-set="_message">
                        Give depth to your <a target="_blank" href="https://www.odoo.com/app/planning?utm_source=db&amp;utm_medium=planning">Plans</a>
                </t>
                <t t-set="_utm_medium" t-valuef="planning"/>
            </t>
        </xpath>
    <xpath expr="." position="attributes"><attribute name="t-name">planning.brand_promotion</attribute></xpath></data>