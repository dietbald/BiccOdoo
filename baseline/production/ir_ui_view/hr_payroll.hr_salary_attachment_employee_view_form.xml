<data><header position="replace">
                <field name="state" widget="statusbar" class="w-100" invisible="not id or employee_count &gt; 1"/>
            </header>
            <div role="alert" position="after">
                <div role="alert" class="alert alert-info d-flex align-items-center justify-content-center" invisible="employee_count &lt;= 1">
                    Multiple employees are attached to this salary adjustment.<button class="btn-link p-0" type="object" name="action_split">Split it in individual adjustment</button>
                </div>
            </div>
            <chatter position="after">
                <footer>
                    <button string="Save" special="save" data-hotkey="q" class="btn-primary"/>
                    <button string="Discard" special="cancel" data-hotkey="x" class="btn-secondary"/>
                    <button name="action_open" type="object" string="Restart" close="0" invisible="state != 'close'"/>
                    <button name="action_close" type="object" string="Stop" close="0" invisible="state != 'open' or not id or employee_count &gt; 1"/>
                    <button name="action_unlink" type="object" string="Remove" class="btn-danger ms-auto me-0" invisible="state != 'close' or employee_count &lt;= 1 or not id"/>
                    <button name="action_unlink" type="object" string="Delete" class="btn-danger ms-auto me-0" invisible="state != 'close' or employee_count &gt; 1 or not id"/>
                </footer>
            </chatter>
        </data>